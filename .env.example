PORT=4000
WEB_ORIGIN=http://localhost:5173

# Twilio outbound send requires the account SID plus either the auth token
# or an API key and secret. Webhook signature validation always requires
# the auth token.
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_API_KEY=
TWILIO_API_SECRET=

# Configure either a direct phone number or a Messaging Service SID.
TWILIO_PHONE_NUMBER=+15555550123
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_DEFAULT_STORE_CODE=PBC-FTL

# Must be a public HTTPS base URL that Twilio can call.
TWILIO_WEBHOOK_BASE_URL=https://your-public-api.example.com
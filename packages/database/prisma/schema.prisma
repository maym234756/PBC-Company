generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "sqlite"
}

model DealerGroup {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  users       User[]
  stores      Store[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String
  title         String
  avatarInitial String
  dealerGroupId String
  dealerGroup   DealerGroup @relation(fields: [dealerGroupId], references: [id])
  userStores    UserStore[]
  activities    StoreActivity[] @relation("StoreActivityActor")
  tasks         StoreTask[] @relation("StoreTaskActor")
  assignedTasks StoreTask[] @relation("StoreTaskAssignee")
  updatedTasks  StoreTask[] @relation("StoreTaskUpdatedBy")
  taskComments  StoreTaskComment[] @relation("StoreTaskCommentAuthor")
  latestCommentedTasks StoreTask[] @relation("StoreTaskLatestCommentBy")
  role          String      @default("writer")
  status        String      @default("Active")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Store {
  id            String        @id @default(cuid())
  code          String        @unique
  name          String
  city          String
  state         String
  dealerGroupId String
  dealerGroup   DealerGroup   @relation(fields: [dealerGroupId], references: [id])
  userStores    UserStore[]
  modules       StoreModule[]
  activities    StoreActivity[]
  tasks         StoreTask[]
  taskSlaPolicies StoreTaskSlaPolicy[]
  salesDeals    SalesDeal[]
  salesDealDeposits SalesDealDeposit[]
  serviceOrders ServiceOrder[]
  partsLines    PartsOrderLine[]
  websiteFeeds  WebsiteFeed[]
  posConnectors PosConnector[]
  posConnectionRequests PosConnectionRequest[]
  vendors         Vendor[]
  pricingRules    PricingRule[]
  approvalRequests ApprovalRequest[]
  boatInventoryUnits BoatInventoryUnit[]
  sandboxTemplates SandboxTemplate[]
  sandboxes        Sandbox[]
  sandboxHistory   SandboxHistoryEntry[]
  sandboxPromotionDiffs SandboxPromotionDiff[]
  crmContacts      CrmContact[]
  crmConversations CrmConversation[]
  crmMessages      CrmMessage[]
  crmReviews       CrmReview[]
  crmPayments      CrmPayment[]
  crmActivities    CrmActivity[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SandboxTemplate {
  id                  String    @id @default(cuid())
  name                String
  description         String    @default("")
  selectedModulesJson String    @default("[]")
  storeId             String
  store               Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sandboxes           Sandbox[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([storeId, name])
  @@index([storeId, updatedAt])
}

model Sandbox {
  id                  String    @id @default(cuid())
  name                String
  type                String
  status              String
  location            String
  releaseType         String
  currentOrgId        String
  description         String
  copiedFromLabel     String
  selectedModulesJson String    @default("[]")
  diffSummary         String    @default("")
  requestedBy         String    @default("")
  activatedBy         String    @default("")
  createdByName       String    @default("")
  createdByEmail      String    @default("")
  loginEmail          String    @default("")
  apiKey              String    @default("")
  completedAt         DateTime?
  refreshedAt         DateTime?
  activatedAt         DateTime?
  deletedAt           DateTime?
  templateId          String?
  template            SandboxTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  storeId             String
  store               Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  historyEntries      SandboxHistoryEntry[] @relation("SandboxHistorySandbox")
  promotionDiffs      SandboxPromotionDiff[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([storeId, name])
  @@index([storeId, updatedAt])
  @@index([storeId, deletedAt])
}

model SandboxHistoryEntry {
  id          String   @id @default(cuid())
  sandboxId   String?
  sandbox     Sandbox? @relation("SandboxHistorySandbox", fields: [sandboxId], references: [id], onDelete: SetNull)
  sandboxName String
  eventType   String
  detail      String
  diffSummary String   @default("")
  requestedBy String
  activatedBy String   @default("")
  refreshedAt DateTime?
  finishedAt  DateTime?
  activatedAt DateTime?
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([sandboxId, createdAt])
}

model SandboxPromotionDiff {
  id              String   @id @default(cuid())
  moduleName      String
  leafName        String
  viewName        String
  entityName      String
  fieldName       String
  productionValue String
  sandboxValue    String
  sourceFile      String
  impactSummary   String
  riskLevel       String
  sandboxId       String
  sandbox         Sandbox  @relation(fields: [sandboxId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([sandboxId, moduleName])
  @@index([storeId, moduleName])
}

model UserStore {
  id      String @id @default(cuid())
  userId  String
  storeId String
  user    User   @relation(fields: [userId], references: [id])
  store   Store  @relation(fields: [storeId], references: [id])

  @@unique([userId, storeId])
}

model AppModule {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  category     String
  description  String
  ownerTeam    String
  navGroup     String
  storeModules StoreModule[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model StoreModule {
  id          String    @id @default(cuid())
  status      String
  headline    String
  priority    Int
  storeId     String
  appModuleId String
  store       Store     @relation(fields: [storeId], references: [id])
  appModule   AppModule @relation(fields: [appModuleId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([storeId, appModuleId])
}

model WebsiteFeed {
  id             String   @id @default(cuid())
  brand          String
  domain         String
  status         String
  inventoryCount Int
  leadsToday     Int
  lastSyncAt     DateTime
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, brand])
}

model PosConnector {
  id                String   @id
  externalKey       String
  sourceKind        String
  sourceLabel       String
  provider          String
  label             String
  location          String
  deviceType        String
  networkHost       String
  merchantId        String
  connectionMode    String
  discoverySource   String
  lastSeenLabel     String
  connectionStatus  String
  isConnected       Boolean  @default(false)
  requiresCredential Boolean @default(false)
  isInventoryActive Boolean  @default(true)
  lastSyncedAt      DateTime @default(now())
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  request           PosConnectionRequest?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([storeId, externalKey])
  @@index([storeId, provider])
  @@index([storeId, isConnected])
  @@index([storeId, isInventoryActive])
}

model PosConnectionRequest {
  id          String      @id @default(cuid())
  mode        String
  state       String
  requestedAt DateTime    @default(now())
  connectorId String      @unique
  connector   PosConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([storeId, createdAt])
}

model SalesDeal {
  id           String   @id @default(cuid())
  openedAt     DateTime
  worksheet    String
  stockNumber  String
  make         String
  model        String
  cashPrice    Int
  stage        String
  customerName String
  modelYear    Int
  vin          String
  tone         String
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  deposits     SalesDealDeposit[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([storeId, worksheet])
  @@index([storeId, openedAt])
}

model SalesDealDeposit {
  id          String   @id @default(cuid())
  invoice     String
  dateLabel   String
  cashier     String
  method      String
  arName      String
  amountCents Int
  description String
  notes       String
  reference   String
  salesDealId String
  salesDeal   SalesDeal @relation(fields: [salesDealId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  activities  SalesDealDepositActivity[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([salesDealId, createdAt])
  @@index([storeId, createdAt])
}

model SalesDealDepositActivity {
  id                 String   @id @default(cuid())
  title              String
  detail             String
  meta               String
  salesDealDepositId String
  salesDealDeposit   SalesDealDeposit @relation(fields: [salesDealDepositId], references: [id], onDelete: Cascade)
  createdAt          DateTime @default(now())

  @@index([salesDealDepositId, createdAt])
}

model ServiceOrder {
  id            String   @id @default(cuid())
  inDate        DateTime
  roNumber      String
  orderType     String   @default("Repair Order")
  customerName  String
  stockNumber   String
  model         String
  serviceWriter String
  roStatus      String
  category      String
  maker         String
  note          String
  detailSnapshot String?
  tone          String
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  serviceJobs   ServiceJob[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, roNumber])
  @@index([storeId, inDate])
}

model BoatInventoryUnit {
  id              String   @id @default(cuid())
  stockNumber     String
  vinHin          String
  status          String   @default("Available")
  condition       String   @default("New")
  year            Int
  make            String
  model           String
  lengthFt        Int      @default(0)
  engine          String
  exteriorColor   String
  interiorColor   String
  location        String
  ageDays         Int      @default(0)
  costCents       Int      @default(0)
  priceCents      Int      @default(0)
  photosJson      String   @default("[]")
  notes           String   @default("")
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([storeId, stockNumber])
  @@index([storeId, status, condition])
  @@index([storeId, vinHin])
}

model ServiceJob {
  id              String   @id @default(cuid())
  jobNumber       Int      @default(1)
  title           String
  status          String   @default("Open")
  technician      String   @default("")
  unitLabel       String   @default("")
  description     String   @default("")
  recommendations String   @default("")
  resolution      String   @default("")
  serviceOrderId  String
  serviceOrder    ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  parts           ServiceJobPart[]
  laborLines      ServiceLaborLine[]
  subletLines     ServiceSubletLine[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([serviceOrderId, status])
}

model ServiceJobPart {
  id             String   @id @default(cuid())
  partNumber     String
  description    String
  quantity       Int      @default(1)
  unitPriceCents Int      @default(0)
  serviceJobId   String
  serviceJob     ServiceJob @relation(fields: [serviceJobId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([serviceJobId, partNumber])
}

model ServiceLaborLine {
  id           String   @id @default(cuid())
  technician   String
  hours        Int      @default(0)
  rateCents    Int      @default(0)
  status       String   @default("Open")
  serviceJobId String
  serviceJob   ServiceJob @relation(fields: [serviceJobId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([serviceJobId, status])
}

model ServiceSubletLine {
  id           String   @id @default(cuid())
  vendor       String
  description  String
  amountCents  Int      @default(0)
  status       String   @default("Open")
  serviceJobId String
  serviceJob   ServiceJob @relation(fields: [serviceJobId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([serviceJobId, status])
}

model PartsOrderLine {
  id              String   @id @default(cuid())
  partNumber      String
  secondaryNumber String
  description     String
  supplier        String
  category        String
  orderType       String
  quantity        Int
  orderCost       Int
  source          String
  tone            String
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([storeId, partNumber, source])
  @@index([storeId, partNumber])
}

model StoreActivity {
  id           String    @id @default(cuid())
  workspaceId  String
  label        String
  detail       String
  tone         String
  actorUserId  String?
  actorUser    User?     @relation("StoreActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName    String    @default("Operator")
  actorInitial String    @default("OP")
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id])
  createdAt    DateTime  @default(now())

  @@index([storeId, workspaceId, createdAt])
  @@index([actorUserId, storeId, createdAt])
}

model StoreTask {
  id              String    @id @default(cuid())
  workspaceId     String
  action          String
  detail          String
  status          String    @default("Queued")
  tone            String
  slaMinutes      Int?
  dueAt           DateTime?
  completedAt     DateTime?
  actorUserId     String?
  actorUser       User?     @relation("StoreTaskActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName       String
  actorInitial    String
  assignedUserId  String?
  assignedUser    User?     @relation("StoreTaskAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedName    String?
  assignedInitial String?
  lastUpdatedByUserId String?
  lastUpdatedByUser   User?  @relation("StoreTaskUpdatedBy", fields: [lastUpdatedByUserId], references: [id], onDelete: SetNull)
  lastUpdatedByName   String @default("Operator")
  lastUpdatedByInitial String @default("OP")
  commentCount     Int       @default(0)
  latestCommentPreview String?
  latestCommentAt  DateTime?
  latestCommentByUserId String?
  latestCommentByUser   User? @relation("StoreTaskLatestCommentBy", fields: [latestCommentByUserId], references: [id], onDelete: SetNull)
  latestCommentByName   String?
  latestCommentByInitial String?
  resolutionNote   String?
  payloadSnapshot String
  storeId         String
  store           Store     @relation(fields: [storeId], references: [id])
  comments        StoreTaskComment[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([storeId, workspaceId, createdAt])
  @@index([storeId, workspaceId, status, updatedAt])
  @@index([actorUserId, storeId, updatedAt])
  @@index([assignedUserId, storeId, updatedAt])
  @@index([lastUpdatedByUserId, storeId, updatedAt])
  @@index([latestCommentByUserId, storeId, updatedAt])
  @@index([dueAt, status, updatedAt])
}

model StoreTaskComment {
  id            String    @id @default(cuid())
  kind          String
  body          String
  taskId        String
  task          StoreTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUserId  String?
  authorUser    User?     @relation("StoreTaskCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorName    String    @default("Operator")
  authorInitial String    @default("OP")
  createdAt     DateTime  @default(now())

  @@index([taskId, createdAt])
  @@index([authorUserId, createdAt])
}

model StoreTaskSlaPolicy {
  id               String   @id @default(cuid())
  workspaceId      String
  action           String
  slaMinutes       Int
  updatedByUserId  String?
  updatedByName    String   @default("Operator")
  updatedByInitial String   @default("OP")
  storeId          String
  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([storeId, workspaceId, action])
  @@index([storeId, workspaceId, updatedAt])
}

model Vendor {
  id          String   @id @default(cuid())
  name        String
  contact     String
  phone       String
  email       String
  terms       String
  leadDays    Int      @default(5)
  notes       String
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storeId, name])
}

model PricingRule {
  id            String   @id @default(cuid())
  category      String
  costMin       Int      @default(0)
  costMax       Int      @default(9999)
  markupPct     Int      @default(30)
  retailMethod  String   @default("Cost + Markup")
  minMarginPct  Int      @default(20)
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeId, category])
}

model ApprovalRequest {
  id           String   @id @default(cuid())
  type         String
  reference    String
  requestedBy  String
  impact       String
  status       String   @default("Pending")
  reason       String
  reviewedBy   String?
  reviewNote   String?
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeId, status, createdAt])
}

model CrmContact {
  id               String           @id @default(cuid())
  name             String
  owner            String
  location         String
  phone            String           @default("")
  email            String           @default("")
  company          String           @default("")
  stage            String           @default("Lead")
  tagsJson         String           @default("[]")
  consentText      String           @default("Pending")
  consentEmail     String           @default("Pending")
  lastTouchLabel   String           @default("Just now")
  lastTouchAt      DateTime         @default(now())
  lastChannel      String           @default("SMS")
  nextAction       String           @default("")
  healthScore      Int              @default(72)
  openBalance      Int              @default(0)
  opportunityValue Int              @default(0)
  reviewScore      Float            @default(0)
  integrationId    String           @default("")
  dealReference    String           @default("")
  storeId          String
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversations    CrmConversation[]
  messages         CrmMessage[]
  reviews          CrmReview[]
  payments         CrmPayment[]
  activities       CrmActivity[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([storeId, lastTouchAt])
  @@index([storeId, phone])
  @@index([storeId, name])
}

model CrmConversation {
  id             String       @id @default(cuid())
  channel        String       @default("SMS")
  subject        String
  preview        String       @default("")
  queueLabel     String       @default("Open Conversations")
  assignment     String
  status         String       @default("Open")
  unreadCount    Int          @default(0)
  lastTouchLabel String       @default("Just now")
  lastTouchAt    DateTime     @default(now())
  storeId        String
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contactId      String
  contact        CrmContact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages       CrmMessage[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([storeId, lastTouchAt])
  @@index([contactId, lastTouchAt])
}

model CrmMessage {
  id             String          @id @default(cuid())
  twilioSid      String?         @unique
  author         String
  body           String
  timeLabel      String          @default("Just now")
  direction      String
  status         String          @default("Queued")
  channel        String          @default("SMS")
  source         String          @default("Communicate")
  storeId        String
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contactId      String
  contact        CrmContact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   CrmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([conversationId, createdAt])
  @@index([contactId, createdAt])
  @@index([storeId, createdAt])
}

model CrmReview {
  id            String     @id @default(cuid())
  author        String
  platform      String
  rating        Int
  postedAtLabel String
  postedAt      DateTime
  body          String
  owner         String
  state         String
  storeId       String
  store         Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contactId     String
  contact       CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([storeId, postedAt])
  @@index([contactId, postedAt])
}

model CrmPayment {
  id             String     @id @default(cuid())
  createdAtLabel String
  recordedAt     DateTime
  customer       String
  confirmation   String
  invoice        String
  amount         Int
  type           String
  status         String
  reconciled     Boolean    @default(false)
  owner          String
  detail         String
  storeId        String
  store          Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contactId      String
  contact        CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([storeId, recordedAt])
  @@index([contactId, recordedAt])
}

model CrmActivity {
  id           String     @id @default(cuid())
  kind         String
  title        String
  detail       String
  owner        String
  source       String
  timeLabel    String
  priority     String
  state        String
  occurredAt   DateTime
  storeId      String
  store        Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  contactId    String
  contact      CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([storeId, occurredAt])
  @@index([contactId, occurredAt])
}

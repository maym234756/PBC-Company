g: 0.04em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sandbox-access-item strong {\r\n  color: #263645;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.92rem;\r\n}\r\n\r\n.sandbox-access-value-row {\r\n  align-items: center;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 10px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.sandbox-access-value {\r\n  background: #f3f6f9;\r\n  border: 1px solid #d7dee7;\r\n  border-radius: 4px;\r\n  color: #233444;\r\n  display: inline-flex;\r\n  font-family: \"Consolas\", \"Courier New\", monospace;\r\n  font-size: 0.8rem;\r\n  max-width: 100%;\r\n  overflow-wrap: anywhere;\r\n  padding: 6px 8px;\r\n}\r\n\r\n.sandbox-info-pill {\r\n  align-items: center;\r\n  background: #eef3f8;\r\n  border: 1px solid #c7d2de;\r\n  border-radius: 3px;\r\n  color: #5a6d83;\r\n  display: inline-flex;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.72rem;\r\n  font-style: normal;\r\n  font-weight: 700;\r\n  height: 14px;\r\n  justify-content: center;\r\n  width: 14px;\r\n}\r\n\r\n.sandbox-status-pill {\r\n  background: #edf4ec;\r\n  border: 1px solid #bfd3bd;\r\n  border-radius: 999px;\r\n  color: #4f6950;\r\n  display: inline-flex;\r\n  font-size: 0.72rem;\r\n  font-weight: 700;\r\n  padding: 3px 8px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sandbox-status-pill.is-active {\r\n  background: #eef4fb;\r\n  border-color: #c8d7ea;\r\n  color: #47637d;\r\n}\r\n\r\n.sandbox-status-pill.is-promoted {\r\n  background: #fbf3e9;\r\n  border-color: #e8cda8;\r\n  color: #8a6131;\r\n}\r\n\r\n.sandbox-table-templates,\r\n.sandbox-table-history {\r\n  min-width: 960px;\r\n}\r\n\r\n.sandbox-table-history {\r\n  min-width: 1360px;\r\n}\r\n\r\n.sandbox-table-sandboxes {\r\n  min-width: 1580px;\r\n}\r\n\r\n.sandbox-template-builder-shell {\r\n  background: #ffffff;\r\n  display: grid;\r\n  gap: 0;\r\n}\r\n\r\n.sandbox-template-builder-header {\r\n  align-items: center;\r\n  border-bottom: 1px solid #b9c4d1;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.sandbox-template-builder-header h3 {\r\n  color: #2f3640;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 1rem;\r\n  font-weight: 400;\r\n  margin: 0;\r\n}\r\n\r\n.sandbox-template-purpose-strip {\r\n  background: #eef4fb;\r\n  border-bottom: 1px solid #d3deeb;\r\n  color: #40505f;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.8rem;\r\n  line-height: 1.45;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.sandbox-template-action-row {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 6px;\r\n  justify-content: center;\r\n  padding: 8px 12px;\r\n}\r\n\r\n.sandbox-template-action-row-top {\r\n  border-bottom: 1px solid #dbe2ea;\r\n}\r\n\r\n.sandbox-template-action-row-bottom {\r\n  border-top: 1px solid #dbe2ea;\r\n}\r\n\r\n.sandbox-template-section {\r\n  border-top: 1px solid #dbe2ea;\r\n}\r\n\r\n.sandbox-template-section-title {\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.sandbox-required-label {\r\n  color: #4b5661;\r\n  font-size: 0.74rem;\r\n  font-weight: 400;\r\n  position: relative;\r\n}\r\n\r\n.sandbox-required-label::before {\r\n  color: #c61f1a;\r\n  content: \"| \";\r\n}\r\n\r\n.sandbox-template-form-grid {\r\n  display: grid;\r\n  gap: 10px 18px;\r\n  grid-template-columns: 340px minmax(260px, 1fr);\r\n  padding: 10px 18px 14px;\r\n}\r\n\r\n.sandbox-template-field {\r\n  align-items: start;\r\n  display: grid;\r\n  gap: 4px 10px;\r\n  grid-template-columns: 96px 1fr;\r\n}\r\n\r\n.sandbox-template-field span {\r\n  color: #3a4450;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.76rem;\r\n  line-height: 1.6;\r\n  text-align: right;\r\n}\r\n\r\n.sandbox-template-field input,\r\n.sandbox-template-field select,\r\n.sandbox-template-field textarea,\r\n.sandbox-template-search-row input {\r\n  border: 1px solid #aeb9c5;\r\n  color: #24303c;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.8rem;\r\n  padding: 4px 6px;\r\n}\r\n\r\n.sandbox-template-field-name input {\r\n  box-shadow: inset 2px 0 0 #c61f1a;\r\n}\r\n\r\n.sandbox-template-field-description {\r\n  grid-column: 1 / span 2;\r\n}\r\n\r\n.sandbox-template-field-description textarea {\r\n  min-height: 52px;\r\n  resize: vertical;\r\n}\r\n\r\n.sandbox-template-objects-intro {\r\n  color: #2f3640;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.8rem;\r\n  padding: 10px 18px 6px;\r\n}\r\n\r\n.sandbox-template-object-layout {\r\n  display: grid;\r\n  gap: 18px;\r\n  grid-template-columns: minmax(540px, 0.78fr) minmax(260px, 1fr);\r\n  padding: 0 18px 18px;\r\n}\r\n\r\n.sandbox-template-object-panel,\r\n.sandbox-template-detail-panel {\r\n  min-width: 0;\r\n}\r\n\r\n.sandbox-template-object-header {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.sandbox-template-object-header strong,\r\n.sandbox-template-detail-title,\r\n.sandbox-template-selection-count {\r\n  color: #2f3640;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.78rem;\r\n}\r\n\r\n.sandbox-template-filter-links {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 4px;\r\n}\r\n\r\n.sandbox-template-filter-links button {\r\n  background: none;\r\n  border: 0;\r\n  color: #2f73b7;\r\n  cursor: pointer;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.72rem;\r\n  padding: 0;\r\n}\r\n\r\n.sandbox-template-filter-links button.is-active {\r\n  color: #2f3640;\r\n  font-weight: 700;\r\n}\r\n\r\n.sandbox-template-helper-copy {\r\n  color: #5c6875;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.72rem;\r\n}\r\n\r\n.sandbox-template-object-table-shell {\r\n  border: 1px solid #b9c4d1;\r\n}\r\n\r\n.sandbox-template-search-row {\r\n  border-bottom: 1px solid #cfd8e2;\r\n  padding: 4px;\r\n}\r\n\r\n.sandbox-template-search-row input {\r\n  width: 220px;\r\n}\r\n\r\n.sandbox-template-object-scroll {\r\n  max-height: 412px;\r\n  overflow: auto;\r\n}\r\n\r\n.sandbox-template-object-table {\r\n  font-size: 0.78rem;\r\n  min-width: 0;\r\n}\r\n\r\n.sandbox-template-object-table th,\r\n.sandbox-template-object-table td {\r\n  cursor: default;\r\n  padding: 5px 6px;\r\n}\r\n\r\n.sandbox-template-object-table tbody tr.is-active {\r\n  background: #e8f2ff;\r\n}\r\n\r\n.sandbox-template-selected-column {\r\n  text-align: center;\r\n  width: 120px;\r\n}\r\n\r\n.sandbox-template-selected-column input {\r\n  height: 16px;\r\n  width: 16px;\r\n}\r\n\r\n.sandbox-template-selection-count {\r\n  border-top: 1px solid #cfd8e2;\r\n  padding: 8px 10px;\r\n  text-align: center;\r\n}\r\n\r\n.sandbox-template-summary-strip {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n  padding: 0 18px 14px;\r\n}\r\n\r\n.sandbox-template-detail-title {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 6px;\r\n  margin-top: 20px;\r\n}\r\n\r\n.sandbox-template-detail-title span {\r\n  color: #4b5661;\r\n}\r\n\r\n.sandbox-template-detail-card {\r\n  background: #f8fafc;\r\n  border: 1px solid #d6dde6;\r\n  margin-top: 10px;\r\n  padding: 14px;\r\n}\r\n\r\n.sandbox-template-detail-card h4 {\r\n  color: #2f3640;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.95rem;\r\n  margin: 0 0 8px;\r\n}\r\n\r\n.sandbox-template-detail-card p,\r\n.sandbox-template-detail-meta span,\r\n.sandbox-template-detail-meta strong {\r\n  font-family: Arial, Helvetica, sans-serif;\r\n}\r\n\r\n.sandbox-template-detail-card p {\r\n  color: #4b5661;\r\n  font-size: 0.8rem;\r\n  line-height: 1.45;\r\n  margin: 0 0 12px;\r\n}\r\n\r\n.sandbox-template-detail-meta {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 6px 0;\r\n}\r\n\r\n.sandbox-template-detail-meta + .sandbox-template-detail-meta {\r\n  border-top: 1px solid #dde5ee;\r\n}\r\n\r\n.sandbox-template-detail-meta span {\r\n  color: #5b6875;\r\n  font-size: 0.76rem;\r\n}\r\n\r\n.sandbox-template-detail-meta strong {\r\n  color: #2f3640;\r\n  font-size: 0.8rem;\r\n}\r\n\r\n@media (max-width: 1100px) {\r\n  .sandbox-license-grid {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n\r\n  .sandbox-page-header {\r\n    flex-direction: column;\r\n  }\r\n\r\n  .sandbox-template-object-layout {\r\n    grid-template-columns: minmax(0, 1fr);\r\n  }\r\n\r\n  .sandbox-template-detail-title {\r\n    margin-top: 0;\r\n  }\r\n}\r\n\r\n@media (max-width: 700px) {\r\n  .sandbox-license-grid {\r\n    grid-template-columns: minmax(0, 1fr);\r\n  }\r\n\r\n  .sandbox-page-title-row {\r\n    align-items: start;\r\n    flex-direction: column;\r\n    gap: 6px;\r\n  }\r\n\r\n  .sandbox-template-form-grid {\r\n    grid-template-columns: minmax(0, 1fr);\r\n  }\r\n\r\n  .sandbox-template-field,\r\n  .sandbox-template-field-description {\r\n    grid-column: auto;\r\n    grid-template-columns: minmax(0, 1fr);\r\n  }\r\n\r\n  .sandbox-template-field span {\r\n    text-align: left;\r\n  }\r\n}\r\n\r\n.website-feed-retired-panel {\r\n  display: none;\r\n}\r\n\r\n.website-feed-workspace {\r\n  align-items: stretch;\r\n  grid-template-columns: minmax(360px, 0.36fr) minmax(0, 1fr);\r\n}\r\n\r\n.website-feed-sidebar,\r\n.website-feed-main,\r\n.website-feed-preview-panel {\r\n  align-items: start;\r\n}\r\n\r\n.website-feed-sidebar {\r\n  max-height: none;\r\n}\r\n\r\n.website-feed-main {\r\n  align-self: stretch;\r\n}\r\n\r\n.website-feed-sidebar-card,\r\n.website-feed-queue-panel,\r\n.website-feed-history-panel,\r\n.website-feed-support-card {\r\n  min-width: 0;\r\n}\r\n\r\n.website-feed-sidebar-card .website-feed-setup-grid,\r\n.website-feed-sidebar-card .website-feed-contract-list,\r\n.website-feed-sidebar-card .website-feed-map-grid,\r\n.website-feed-sidebar-card .website-feed-profile-grid,\r\n.website-feed-sidebar-card .legacy-feed-health-strip,\r\n.website-feed-sidebar-card .legacy-website-filter-row {\r\n  grid-template-columns: 1fr;\r\n}\r\n\r\n.website-feed-sidebar-card .website-feed-generated-list,\r\n.website-feed-endpoint-list {\r\n  max-height: 520px;\r\n  overflow: auto;\r\n}\r\n\r\n.website-feed-sidebar-workspace .website-feed-generated-list.is-compact,\r\n.website-feed-setup .website-feed-generated-list.is-compact,\r\n.website-feed-contract-summary {\r\n  max-height: none;\r\n}\r\n\r\n.website-feed-main-grid {\r\n  align-items: start;\r\n  grid-template-columns: minmax(300px, 0.62fr) minmax(0, 0.38fr);\r\n}\r\n\r\n.website-feed-support-grid {\r\n  align-items: start;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-hero {\r\n  align-items: start;\r\n  background: linear-gradient(180deg, #fbfdff 0%, #eef5f9 100%);\r\n  border-color: #cfdee8;\r\n  grid-template-columns: minmax(0, 1fr) auto;\r\n}\r\n\r\n.website-feed-hero.is-collapsed {\r\n  align-items: center;\r\n  gap: 10px;\r\n}\r\n\r\n.website-feed-hero-copy {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.website-feed-hero-copy h3 {\r\n  margin: 0;\r\n}\r\n\r\n.website-feed-hero-collapsed-meta {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 6px;\r\n}\r\n\r\n.website-feed-hero-actions {\r\n  align-items: start;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n  justify-content: flex-end;\r\n}\r\n\r\n.website-feed-summary-strip,\r\n.website-feed-stage-strip {\r\n  grid-column: 1 / -1;\r\n}\r\n\r\n.website-feed-summary-strip {\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-summary-card,\r\n.website-feed-stage-pill,\r\n.website-feed-endpoint,\r\n.website-feed-map-card,\r\n.website-feed-control-panel,\r\n.website-feed-generated-endpoint,\r\n.website-feed-contract-card {\r\n  background: #f8fbfd;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 8px;\r\n}\r\n\r\n.website-feed-summary-card {\r\n  display: grid;\r\n  gap: 6px;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.website-feed-summary-card span,\r\n.website-feed-endpoint-meta span {\r\n  color: #567185;\r\n  font-size: 0.76rem;\r\n  font-weight: 700;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.website-feed-summary-card strong {\r\n  color: #10293b;\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 1.2rem;\r\n}\r\n\r\n.website-feed-stage-strip {\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-stage-pill {\r\n  align-items: start;\r\n  border-left-width: 4px;\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: auto minmax(0, 1fr);\r\n  padding: 10px 12px;\r\n}\r\n\r\n.website-feed-stage-pill.tone-stable {\r\n  border-left-color: #44c188;\r\n}\r\n\r\n.website-feed-stage-pill.tone-accent {\r\n  border-left-color: #ff7448;\r\n}\r\n\r\n.website-feed-stage-pill.tone-attention {\r\n  border-left-color: #d7a225;\r\n}\r\n\r\n.website-feed-stage-pill.tone-neutral {\r\n  border-left-color: #8195a4;\r\n}\r\n\r\n.website-feed-stage-pill-index {\r\n  align-items: center;\r\n  background: #e7f1f5;\r\n  border: 1px solid #c9dbe5;\r\n  border-radius: 10px;\r\n  color: #173446;\r\n  display: inline-flex;\r\n  font-weight: 800;\r\n  height: 30px;\r\n  justify-content: center;\r\n  width: 30px;\r\n}\r\n\r\n.website-feed-stage-pill strong,\r\n.website-feed-endpoint strong,\r\n.website-feed-map-card strong,\r\n.website-feed-selected-connector strong,\r\n.website-feed-generated-endpoint strong,\r\n.website-feed-contract-card strong {\r\n  color: #10293b;\r\n}\r\n\r\n.website-feed-stage-pill p,\r\n.website-feed-summary-card p {\r\n  font-size: 0.78rem;\r\n  line-height: 1.35;\r\n}\r\n\r\n.website-feed-stage-pill .legacy-chip {\r\n  grid-column: 2;\r\n  justify-self: start;\r\n}\r\n\r\n.website-feed-setup {\r\n  gap: 14px;\r\n}\r\n\r\n.website-feed-sidebar-step-strip {\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-sidebar-step {\r\n  background: #f8fbfd;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 10px;\r\n  display: grid;\r\n  gap: 4px;\r\n  padding: 10px;\r\n}\r\n\r\n.website-feed-sidebar-step.is-active {\r\n  border-color: #7bb1c8;\r\n  box-shadow: inset 0 0 0 1px rgba(31, 138, 167, 0.14);\r\n}\r\n\r\n.website-feed-sidebar-step.is-complete {\r\n  background: #eef7f3;\r\n  border-color: #b9ded0;\r\n}\r\n\r\n.website-feed-sidebar-step span,\r\n.website-feed-sidebar-tab span,\r\n.website-feed-contract-summary-item span {\r\n  color: #567185;\r\n  font-size: 0.72rem;\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.website-feed-sidebar-step strong,\r\n.website-feed-sidebar-tab strong,\r\n.website-feed-contract-summary-item strong,\r\n.website-feed-panel-copy p,\r\n.website-feed-generated-endpoint-header strong {\r\n  color: #10293b;\r\n}\r\n\r\n.website-feed-sidebar-step p,\r\n.website-feed-contract-summary-item p,\r\n.website-feed-panel-copy p {\r\n  font-size: 0.78rem;\r\n  line-height: 1.35;\r\n}\r\n\r\n.website-feed-preview-panel {\r\n  background: linear-gradient(180deg, #fcfeff 0%, #edf5f8 100%);\r\n  border-color: #cfdee8;\r\n  grid-template-rows: auto auto minmax(0, 1fr) auto auto;\r\n  height: 100%;\r\n}\r\n\r\n.website-feed-preview-header {\r\n  align-items: start;\r\n  display: grid;\r\n  gap: 14px;\r\n  grid-template-columns: minmax(0, 1fr) auto;\r\n}\r\n\r\n.website-feed-preview-header h3 {\r\n  margin: 0;\r\n}\r\n\r\n.website-feed-preview-actions {\r\n  align-items: flex-start;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n  justify-content: flex-end;\r\n}\r\n\r\n.website-feed-preview-actions .legacy-desktop-board-button {\r\n  text-decoration: none;\r\n}\r\n\r\n.website-feed-preview-toolbar {\r\n  align-items: center;\r\n  background: #dce8ee;\r\n  border: 1px solid #c9d8e1;\r\n  border-radius: 12px 12px 0 0;\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-template-columns: auto minmax(0, 1fr) auto;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.website-feed-browser-dots {\r\n  display: flex;\r\n  gap: 6px;\r\n}\r\n\r\n.website-feed-browser-dots span {\r\n  background: #ffffff;\r\n  border: 1px solid rgba(16, 41, 59, 0.12);\r\n  border-radius: 999px;\r\n  display: block;\r\n  height: 10px;\r\n  width: 10px;\r\n}\r\n\r\n.website-feed-preview-address {\r\n  background: rgba(255, 255, 255, 0.84);\r\n  border: 1px solid rgba(16, 41, 59, 0.1);\r\n  border-radius: 999px;\r\n  color: #234b60;\r\n  font-size: 0.8rem;\r\n  font-weight: 700;\r\n  min-width: 0;\r\n  overflow: hidden;\r\n  padding: 8px 12px;\r\n  text-overflow: ellipsis;\r\n  white-space: nowrap;\r\n}\r\n\r\n.website-feed-browser-frame {\r\n  --website-preview-scale: 0.88;\r\n  background: #ffffff;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 0 0 14px 14px;\r\n  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.8);\r\n  height: 100%;\r\n  min-height: 880px;\r\n  overflow: hidden;\r\n  position: relative;\r\n}\r\n\r\n.website-feed-browser-iframe {\r\n  background: linear-gradient(180deg, #ffffff 0%, #f4f8fb 100%);\r\n  border: 0;\r\n  display: block;\r\n  height: calc(100% / var(--website-preview-scale));\r\n  margin: 0 auto;\r\n  min-height: calc(880px / var(--website-preview-scale));\r\n  transform: scale(var(--website-preview-scale));\r\n  transform-origin: top center;\r\n  width: calc(100% / var(--website-preview-scale));\r\n}\r\n\r\n.website-feed-browser-state-overlay {\r\n  align-content: center;\r\n  background: rgba(248, 251, 253, 0.92);\r\n  display: grid;\r\n  gap: 8px;\r\n  inset: 0;\r\n  justify-items: center;\r\n  padding: 24px;\r\n  position: absolute;\r\n  text-align: center;\r\n}\r\n\r\n.website-feed-browser-state-overlay strong {\r\n  color: #10293b;\r\n  font-size: 1rem;\r\n}\r\n\r\n.website-feed-browser-state-overlay p {\r\n  color: #567185;\r\n  max-width: 520px;\r\n}\r\n\r\n.website-feed-browser-state-overlay.is-blocked {\r\n  background: rgba(250, 244, 240, 0.94);\r\n}\r\n\r\n.website-feed-browser-snapshot-shell {\r\n  background: linear-gradient(180deg, #fcfefd 0%, #f3f8fb 100%);\r\n  display: grid;\r\n  grid-template-rows: minmax(0, 1fr) auto;\r\n  height: 100%;\r\n  min-height: 880px;\r\n}\r\n\r\n.website-feed-browser-snapshot-image {\r\n
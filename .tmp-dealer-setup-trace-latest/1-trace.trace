st {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 8px;\r\n  min-height: 0;\r\n  overflow: auto;\r\n  padding-right: 2px;\r\n}\r\n\r\n.legacy-service-notification-card {\r\n  align-items: flex-start;\r\n  background: #f7fafc;\r\n  border: 1px solid #d0dbe2;\r\n  border-left: 0;\r\n  border-radius: 999px;\r\n  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);\r\n  color: #10293b;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 2px;\r\n  padding: 10px 14px;\r\n  text-align: left;\r\n  transition: background 140ms ease, border-color 140ms ease, transform 140ms ease;\r\n  width: 100%;\r\n}\r\n\r\n.legacy-service-notification-card:hover:not(:disabled),\r\n.legacy-service-notification-card:focus-visible {\r\n  background: #ffffff;\r\n  border-color: #9eb2bf;\r\n  outline: none;\r\n  transform: translateY(-1px);\r\n}\r\n\r\n.legacy-service-notification-card.is-unread {\r\n  background: #fffaf0;\r\n}\r\n\r\n.legacy-service-notification-card.is-viewing,\r\n.legacy-service-notification-card:disabled {\r\n  cursor: default;\r\n  opacity: 0.72;\r\n}\r\n\r\n.legacy-service-notification-card.tone-stable {\r\n  border-color: #c6e7d3;\r\n}\r\n\r\n.legacy-service-notification-card.tone-accent {\r\n  border-color: #ffd0bf;\r\n}\r\n\r\n.legacy-service-notification-card.tone-attention {\r\n  border-color: #efd9a3;\r\n}\r\n\r\n.legacy-service-notification-card.tone-neutral {\r\n  border-color: #c3d1da;\r\n}\r\n\r\n.legacy-service-notification-card strong {\r\n  color: #10293b;\r\n  font-size: 0.76rem;\r\n}\r\n\r\n.legacy-service-notification-card .legacy-command-meta {\r\n  color: #5b7384;\r\n  font-size: 0.68rem;\r\n}\r\n\r\n.legacy-service-notification-meta {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 6px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.legacy-service-notification-pill {\r\n  border: 1px solid #c3d1da;\r\n  border-radius: 999px;\r\n  display: inline-flex;\r\n  font-size: 0.62rem;\r\n  font-weight: 800;\r\n  letter-spacing: 0.0
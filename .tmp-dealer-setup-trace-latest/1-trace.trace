: 0;\r\n}\r\n\r\n.sandbox-page-header p {\r\n  color: #4f5b66;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.95rem;\r\n  line-height: 1.45;\r\n  margin: 8px 0 0;\r\n}\r\n\r\n.sandbox-page-title-row {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\n\r\n.sandbox-page-help-link,\r\n.sandbox-page-inline-link,\r\n.sandbox-link-button {\r\n  background: none;\r\n  border: 0;\r\n  color: #2f73b7;\r\n  cursor: pointer;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  padding: 0;\r\n}\r\n\r\n.sandbox-page-help-link {\r\n  font-size: 0.82rem;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sandbox-page-inline-link {\r\n  display: inline;\r\n  font-size: 0.9rem;\r\n  margin-left: 4px;\r\n}\r\n\r\n.sandbox-page-alert {\r\n  align-items: center;\r\n  background: #eef2f7;\r\n  border: 1px solid #d6dde6;\r\n  display: grid;\r\n  gap: 12px;\r\n  grid-template-columns: auto 1fr;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.sandbox-page-alert p {\r\n  color: #4f5b66;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.9rem;\r\n  margin: 0;\r\n}\r\n\r\n.sandbox-page-alert-icon {\r\n  align-items: center;\r\n  background: #5f7390;\r\n  border-radius: 999px;\r\n  color: #fff;\r\n  display: inline-flex;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.85rem;\r\n  font-weight: 700;\r\n  height: 22px;\r\n  justify-content: center;\r\n  width: 22px;\r\n}\r\n\r\n.sandbox-license-panel,\r\n.sandbox-table-shell {\r\n  background: #ffffff;\r\n  border: 1px solid #bec7d2;\r\n}\r\n\r\n.sandbox-section-title {\r\n  background: linear-gradient(180deg, #eef2f7 0%, #dce3ed 100%);\r\n  border-bottom: 1px solid #bec7d2;\r\n  color: #28323c;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.92rem;\r\n  font-weight: 700;\r\n  padding: 7px 12px;\r\n}\r\n\r\n.sandbox-license-grid {\r\n  display: grid;\r\n  gap: 16px;\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n  padding: 14px 18px 10px;\r\n}\r\n\r\n.sandbox-license-card {\r\n  display: grid;\r\n  gap: 4px;\r\n}\r\n\r\n.sandbox-license-card strong,\r\n.sandbox-license-usage,\r\n.sandbox-license-availability,\r\n.sandbox-tab-strip button,\r\n.sandbox-table,\r\n.sandbox-new-button {\r\n  font-family: Arial, Helvetica, sans-serif;\r\n}\r\n\r\n.sandbox-license-card strong {\r\n  color: #2f3640;\r\n  font-size: 0.95rem;\r\n}\r\n\r\n.sandbox-license-usage {\r\n  font-size: 0.94rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.sandbox-license-usage.tone-stable {\r\n  color: #2f8a2f;\r\n}\r\n\r\n.sandbox-license-usage.tone-alert,\r\n.sandbox-license-usage.tone-attention {\r\n  color: #cf2f24;\r\n}\r\n\r\n.sandbox-license-availability {\r\n  color: #4f5b66;\r\n  font-size: 0.82rem;\r\n}\r\n\r\n.sandbox-tab-strip {\r\n  align-items: end;\r\n  background: #f7f8fa;\r\n  border-bottom: 1px solid #bec7d2;\r\n  display: flex;\r\n  gap: 2px;\r\n  padding: 8px 8px 0;\r\n}\r\n\r\n.sandbox-tab-strip button {\r\n  background: linear-gradient(180deg, #f8fafc 0%, #e5eaf1 100%);\r\n  border: 1px solid #b8c2cd;\r\n  border-bottom: 0;\r\n  color: #39424d;\r\n  font-size: 0.86rem;\r\n  padding: 6px 12px;\r\n}\r\n\r\n.sandbox-tab-strip button.is-active {\r\n  background: #ffffff;\r\n  position: relative;\r\n  top: 1px;\r\n}\r\n\r\n.sandbox-table-toolbar {\r\n  display: flex;\r\n  justify-content: center;\r\n  padding: 12px 12px 8px;\r\n}\r\n\r\n.sandbox-new-button {\r\n  background: linear-gradient(180deg, #ffffff 0%, #eef3f8 100%);\r\n  border: 1px solid #b7c3cf;\r\n  border-radius: 4px;\r\n  color: #39424d;\r\n  font-size: 0.85rem;\r\n  padding: 5px 10px;\r\n}\r\n\r\n.sandbox-table-wrap {\r\n  overflow: auto;\r\n  padding: 0 10px 10px;\r\n}\r\n\r\n.sandbox-table {\r\n  border-collapse: collapse;\r\n  color: #3f4750;\r\n  font-size: 0.8rem;\r\n  min-width: 1280px;\r\n  width: 100%;\r\n}\r\n\r\n.sandbox-table th,\r\n.sandbox-table td {\r\n  border: 1px solid #d6dde6;\r\n  padding: 6px 8px;\r\n  text-align: left;\r\n  vertical-align: top;\r\n}\r\n\r\n.sandbox-table
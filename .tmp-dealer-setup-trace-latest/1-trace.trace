height: 14px;\r\n  justify-content: center;\r\n  line-height: 1;\r\n  min-width: 14px;\r\n  padding: 0 3px;\r\n}\r\n\r\n.crm-center-salesforce-toolbar button.tone-sms .crm-center-salesforce-toolbar-icon,\r\n.crm-center-salesforce-toolbar button.tone-email .crm-center-salesforce-toolbar-icon,\r\n.crm-center-salesforce-toolbar button.tone-call .crm-center-salesforce-toolbar-icon,\r\n.crm-center-salesforce-toolbar button.tone-quote .crm-center-salesforce-toolbar-icon {\r\n  background: #13a7b8;\r\n}\r\n\r\n.crm-center-salesforce-toolbar button.tone-task .crm-center-salesforce-toolbar-icon,\r\n.crm-center-salesforce-toolbar button.tone-review .crm-center-salesforce-toolbar-icon,\r\n.crm-center-salesforce-toolbar button.tone-payment .crm-center-salesforce-toolbar-icon {\r\n  background: #6fbe5c;\r\n}\r\n\r\n.crm-center-salesforce-filter-summary {\r\n  color: #6c808e;\r\n  font-size: 0.67rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.crm-center-salesforce-filter-actions {\r\n  display: inline-flex;\r\n  gap: 10px;\r\n}\r\n\r\n.crm-center-salesforce-filter-actions button {\r\n  background: transparent;\r\n  border: 0;\r\n  color: #3c6793;\r\n  font-size: 0.67rem;\r\n  font-weight: 700;\r\n  padding: 0;\r\n}\r\n\r\n.crm-center-salesforce-feed {\r\n  background: #fff;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n  min-height: 0;\r\n  overflow: auto;\r\n  padding: 10px 12px 12px;\r\n}\r\n\r\n.crm-center-salesforce-group {\r\n  display: grid;\r\n  gap: 0;\r\n}\r\n\r\n.crm-center-salesforce-group-header {\r\n  align-items: center;\r\n  background: #f3f5f7;\r\n  border: 1px solid #eceff2;\r\n  border-radius: 3px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 6px 8px;\r\n}\r\n\r\n.crm-center-salesforce-group-header strong {\r\n  color: #173446;\r\n  font-size: 0.68rem;\r\n}\r\n\r\n.crm-center-salesforce-group-header span {\r\n  color: #6b808e;\r\n  font-size: 0.64rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.crm-center-salesforce-group-body {\r\n  min-height: 0;\r\n  padding: 8px 0 10px;\r\n}\r\n\r\n.crm-center-salesforce-list {\r\n  display: grid;\r\n  gap: 0;\r\n  position: relative;\r\n}\r\n\r\n.crm-center-task-card,\r\n.crm-center-activity-row,\r\n.crm-center-salesforce-entry {\r\n  align-items: start;\r\n}\r\n\r\n.crm-center-salesforce-list::before {\r\n  background: #d8dde2;\r\n  bottom: 8px;\r\n  content: \"\";\r\n  left: 8px;\r\n  position: absolute;\r\n  top: 8px;\r\n  width: 1px;\r\n}\r\n\r\n.crm-center-salesforce-entry {\r\n  background: transparent;\r\n  border: 0;\r\n  border-radius: 0;\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-template-columns: auto minmax(0, 1fr) auto;\r\n  padding: 8px 0;\r\n}\r\n\r\n.crm-center-salesforce-entry-marker {\r\n  align-items: start;\r\n  display: flex;\r\n  justify-content: center;\r\n  padding-top: 1px;\r\n  position: relative;\r\n  width: 18px;\r\n  z-index: 1;\r\n}\r\n\r\n.crm-center-avatar {\r\n  align-items: center;\r\n  background: linear-gradient(180deg, #dceafe 0%, #bfd4f5 100%);\r\n  border-radius: 12px;\r\n  color: #184777;\r\n  display: inline-flex;\r\n  font-weight: 700;\r\n  height: 46px;\r\n  justify-content: center;\r\n  width: 46px;\r\n}\r\n\r\n.crm-center-side-metrics {\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n}\r\n\r\n.crm-center-side-metrics span,\r\n.crm-center-side-card dt {\r\n  color: #6d808e;\r\n  font-size: 0.74rem;\r\n  letter-spacing: 0.03em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.crm-center-insight-list {\r\n  color: #385264;\r\n  margin: 0;\r\n  padding-left: 18px;\r\n}\r\n\r\n.crm-center-insight-list li + li {\r\n  margin-top: 8px;\r\n}\r\n\r\n.crm-center-activity-kind,\r\n.crm-center-salesforce-entry-icon {\r\n  align-items: center;\r\n  border-radius: 4px;\r\n  color: #1f4f74;\r\n  display: inline-flex;\r\n  font-size: 0.55rem;\r\n  font-weight: 700;\r\n  justify-content: center;\r\n  min-height: 16px;\r\n  min-width: 16px;\r\n  padding: 0 3px;\r\n}\r\n\r\n.crm-center-activity-kind.tone-sms,\r\n.crm-center-activity-kind.tone-email,\r\n.crm-center-activity-kind.tone-call,\r\n.crm-center-activity-kind.tone-quote,\r\n.crm-center-salesforce-entry-icon.tone-sms,\r\n.crm-center-salesforce-entry-icon.tone-email,\r\n.crm-center-salesforce-entry-icon.tone-call,\r\n.crm-center-salesforce-entry-icon.tone-quote {\r\n  background: #e4eef9;\r\n}\r\n\r\n.crm-center-activity-kind.tone-task,\r\n.crm-center-activity-kind.tone-payment,\r\n.crm-center-activity-kind.tone-review,\r\n.crm-center-salesforce-entry-icon.tone-task,\r\n.crm-center-salesforce-entry-icon.tone-payment,\r\n.crm-center-salesforce-entry-icon.tone-review {\r\n  background: #fff1d9;\r\n}\r\n\r\n.crm-center-activity-row {\r\n  grid-template-columns: auto minmax(0, 1fr) auto;\r\n  padding: 12px;\r\n}\r\n\r\n.crm-center-salesforce-entry-copy {\r\n  display: grid;\r\n  gap: 2px;\r\n}\r\n\r\n.crm-center-salesforce-entry-copy p,\r\n.crm-center-salesforce-entry-copy span {\r\n  margin: 0;\r\n}\r\n\r\n.crm-center-salesforce-entry-copy strong {\r\n  color: #1f5a93;\r\n  font-size: 0.72rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.crm-center-salesforce-entry-copy p {\r\n  color: #173446;\r\n  font-size: 0.68rem;\r\n  line-height: 1.35;\r\n}\r\n\r\n.crm-center-salesforce-entry-copy span {\r\n  color: #6b808e;\r\n  font-size: 0.64rem;\r\n}\r\n\r\n.crm-center-salesforce-entry-meta {\r\n  display: grid;\r\n  gap: 4px;\r\n  justify-items: end;\r\n  text-align: right;\r\n}\r\n\r\n.crm-center-salesforce-entry-meta span {\r\n  color: #5d7484;\r\n  font-size: 0.64rem;\r\n  white-space: nowrap;\r\n}\r\n\r\n.crm-center-salesforce-entry-meta em {\r\n  color: #173446;\r\n  font-size: 0.62rem;\r\n  font-style: normal;\r\n}\r\n\r\n.crm-center-activity-meta {\r\n  display: grid;\r\n  gap: 8px;\r\n  justify-items: end;\r\n}\r\n\r\n.crm-center-salesforce-empty {\r\n  align-items: center;\r\n  background: #fff;\r\n  color: #607889;\r\n  display: grid;\r\n  gap: 4px;\r\n  justify-items: center;\r\n  min-height: 68px;\r\n  padding: 10px;\r\n  text-align: center;\r\n}\r\n\r\n.crm-center-salesforce-empty strong {\r\n  color: #4f6575;\r\n  font-size: 0.7rem;\r\n}\r\n\r\n.crm-center-salesforce-empty p {\r\n  color: #607889;\r\n  font-size: 0.64rem;\r\n  margin: 0;\r\n}\r\n\r\n.crm-center-salesforce-show-all {\r\n  align-self: center;\r\n  background: linear-gradient(180deg, #3768a7 0%, #2a5487 100%);\r\n  border: 1px solid #2a5487;\r\n  border-radius: 3px;\r\n  color: #fff;\r\n  font-size: 0.66rem;\r\n  font-weight: 700;\r\n  margin: 10px 0 12px;\r\n  min-height: 20px;\r\n  padding: 0 12px;\r\n}\r\n\r\n.crm-center-empty {\r\n  align-items: center;\r\n  background: #fff;\r\n  border: 1px dashed #d0dce4;\r\n  border-radius: 12px;\r\n  display: flex;\r\n  justify-content: center;\r\n  min-height: 96px;\r\n  padding: 16px;\r\n  text-align: center;\r\n}\r\n\r\n@media (max-width: 1420px) {\r\n  .crm-center-content-grid {\r\n    grid-template-columns: minmax(260px, 0.9fr) minmax(0, 1.2fr);\r\n  }\r\n\r\n  .crm-center-side-panel {\r\n    grid-column: 1 / -1;\r\n    grid-template-columns: repeat(3, minmax(0, 1fr));\r\n  }\r\n\r\n  .crm-center-salesforce-tabs {\r\n    gap: 12px;\r\n  }\r\n}\r\n\r\n@media (max-width: 1080px) {\r\n  .crm-center-stage,\r\n  .crm-center-content-grid,\r\n  .crm-center-contact-grid,\r\n  .crm-center-payment-grid,\r\n  .crm-center-side-panel {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .crm-center-panel-header,\r\n  .crm-center-workspace-header,\r\n  .crm-center-detail-header {\r\n    align-items: start;\r\n    flex-direction: column;\r\n  }\r\n\r\n  .crm-center-quick-create-form {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .crm-center-side-edit-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .crm-center-panel-header input {\r\n    min-width: 0;\r\n    width: 100%;\r\n  }\r\n\r\n  .crm-center-salesforce-tabs {\r\n    gap: 10px;\r\n    overflow-x: auto;\r\n  }\r\n\r\n  .crm-center-salesforce-entry {\r\n    grid-template-columns: auto minmax(0, 1fr);\r\n  }\r\n\r\n  .crm-center-salesforce-entry-meta {\r\n    justify-items: start;\r\n    text-align: left;\r\n  }\r\n}\r\n\r\n.landing-download-button:hover {\r\n  background: rgba(255, 116, 72, 0.18);\r\n  border-color: rgba(255, 116, 72, 0.32);\r\n}\r\n\r\n.landing-web-access {\r\n  align-items: center;\r\n  background:\r\n    linear-gradient(135deg, rgba(255, 116, 72, 0.14), rgba(10, 31, 47, 0.82)),\r\n    var(--panel);\r\n  border-radius: 28px;\r\n  display: flex;\r\n  gap: 24px;\r\n  justify-content: space-between;\r\n  padding: clamp(24px, 4vw, 40px);\r\n}\r\n\r\n.landing-web-access > div {\r\n  display: grid;\r\n  gap: 10px;\r\n  max-width: 760px;\r\n}\r\n\r\n.landing-web-access h2 {\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: clamp(2rem, 4vw, 3rem);\r\n  line-height: 1;\r\n  margin: 0;\r\n}\r\n\r\n.landing-web-access p {\r\n  color: var(--muted);\r\n  line-height: 1.7;\r\n  margin: 0;\r\n}\r\n\r\n.landing-web-login-button {\r\n  align-items: center;\r\n  display: inline-flex;\r\n  flex: 0 0 auto;\r\n  justify-content: center;\r\n  min-width: 180px;\r\n  text-decoration: none;\r\n}\r\n\r\n.login-page-screen {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: center;\r\n  min-height: 100vh;\r\n  overflow: hidden;\r\n  padding: 32px;\r\n  position: relative;\r\n  z-index: 1;\r\n}\r\n\r\n.login-page-backdrop {\r\n  background:\r\n    radial-gradient(circle at top left, rgba(255, 116, 72, 0.24), transparent 32%),\r\n    radial-gradient(circle at bottom right, rgba(94, 160, 197, 0.28), transparent 28%),\r\n    linear-gradient(135deg, rgba(3, 19, 31, 0.72), rgba(8, 34, 56, 0.86)),\r\n    rgba(5, 24, 39, 0.7);\r\n  filter: blur(10px);\r\n  inset: -18px;\r\n  position: absolute;\r\n  transform: scale(1.04);\r\n}\r\n\r\n.login-page-card {\r\n  -webkit-backdrop-filter: blur(24px);\r\n  backdrop-filter: blur(24px);\r\n  background: rgba(248, 250, 252, 0.92);\r\n  border: 1px solid rgba(255, 255, 255, 0.56);\r\n  border-radius: 28px;\r\n  box-shadow: 0 34px 90px rgba(0, 0, 0, 0.42);\r\n  color: #153047;\r\n  display: grid;\r\n  gap: 24px;\r\n  max-width: 520px;\r\n  padding: clamp(28px, 4vw, 44px);\r\n  position: relative;\r\n  width: min(100%, 520px);\r\n  z-index: 1;\r\n}\r\n\r\n.login-page-header {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.login-page-header h1 {\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: clamp(2.2rem, 5vw, 3.1rem);\r\n  line-height: 1;\r\n  margin: 0;\r\n}\r\n\r\n.login-page-header p,\r\n.login-page-note {\r\n  color: #60758a;\r\n  line-height: 1.55;\r\n  margin: 0;\r\n}\r\n\r\n.login-page-form {\r\n  display: grid;\r\n  gap: 18px;\r\n}\r\n\r\n.login-page-form label,\r\n.login-page-note {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.login-page-form label span {\r\n  color: #284158;\r\n  font-size: 0.88rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.login-page-form input {\r\n  background: rgba(255, 255, 255, 0.96);\r\n  border: 1px solid rgba(21, 48, 71, 0.22);\r\n  border-radius: 14px;\r\n  color: #153047;\r\n  min-height: 54px;\r\n  outline: none;\r\n  padding: 0 16px;\r\n}\r\n\r\n.login-page-form input:focus {\r\n  border-color: var(--accent);\r\n  box-shadow: 0 0 0 4px rgba(255, 116, 72, 0.14);\r\n}\r\n\r\n.login-page-submit {\r\n  width: 100%;\r\n}\r\n\r\n.brand-badge,\r\n.section-eyebrow {\r\n  color: var(--accent-soft);\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 0.78rem;\r\n  letter-spacing: 0.12em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.login-screen,\r\n.dashboard-screen {\r\n  min-height: 100vh;\r\n  padding: 32px;\r\n  position: relative;\r\n  z-index: 1;\r\n}\r\n\r\n.login-screen {\r\n  align-items: center;\r\n  display: grid;\r\n  gap: 32px;\r\n  grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.85fr);\r\n}\r\n\r\n.login-copy-panel,\r\n.compact-panel,\r\n.login-card,\r\n.modal-panel {\r\n  -webkit-backdrop-filter: blur(18px);\r\n  backdrop-filter: blur(18px);\r\n  background: var(--panel);\r\n  border: 1px solid var(--line);\r\n  box-shadow: var(--shadow);\r\n}\r\n\r\n.login-copy-panel {\r\n  border-radius: 32px;\r\n  display: grid;\r\n  gap: 20px;\r\n  padding: 40px;\r\n}\r\n\r\n.login-copy-panel h1 {\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: clamp(2.4rem, 5vw, 4.4rem);\r\n  line-height: 0.96;\r\n  margin: 0;\r\n  max-width: 12ch;\r\n}\r\n\r\n.login-copy-panel p {\r\n  color: var(--muted);\r\n  font-size: 1rem;\r\n  line-height: 1.7;\r\n  margin: 0;\r\n  max-width: 56ch;\r\n}\r\n\r\n.highlight-list {\r\n  display: grid;\r\n  gap: 14px;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.highlight-card {\r\n  background: rgba(255, 255, 255, 0.03);\r\n  border: 1px solid rgba(255, 255, 255, 0.06);\r\n  border-radius: 22px;\r\n  display: grid;\r\n  gap: 10px;\r\n  padding: 18px;\r\n}\r\n\r\n.highlight-card strong,\r\n.login-card h2,\r\n.dashboard-header h1,\r\n.hero-panel h2,\r\n.section-panel h3 {\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n}\r\n\r\n.highlight-card span,\r\n.card-footer-copy,\r\n.hero-panel p,\r\n.feed-row span,\r\n.activity-row p,\r\n.module-card p,\r\n.stat-card p,\r\n.tab-menu-item,\r\n.modal-copy {\r\n  color: var(--muted);\r\n}\r\n\r\n.login-card-shell {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n}\r\n\r\n.login-card {\r\n  border-radius: 28px;\r\n  display: grid;\r\n  gap: 28px;\r\n  padding: 34px;\r\n  width: min(100%, 460px);\r\n}\r\n\r\n.card-topline {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.card-topline h2,\r\n.hero-panel h2,\r\n.section-panel h3 {\r\n  font-size: 2rem;\r\n  margin: 0;\r\n}\r\n\r\n.login-form {\r\n  display: grid;\r\n  gap: 18px;\r\n}\r\n\r\n.login-form label {\r\n  display: grid;\r\n  gap: 10px;\r\n}\r\n\r\n.login-form span,\r\n.stat-card span,\r\n.hero-meta-grid span,\r\n.module-footer span,\r\n.store-card span,\r\n.feed-row strong,\r\n.feed-row span,\r\n.operator-chip span,\r\n.activity-row strong {\r\n  font-size: 0.9rem;\r\n}\r\n\r\n.login-form input {\r\n  background: rgba(248, 250, 252, 0.96);\r\n  border: 1px solid rgba(255, 255, 255, 0.14);\r\n  border-radius: 16px;\r\n  color: #153047;\r\n  min-height: 54px;\r\n  outline: none;\r\n  padding: 0 16px;\r\n}\r\n\r\n.login-form input:focus {\r\n  border-color: var(--accent);\r\n  box-shadow: 0 0 0 4px rgba(255, 116, 72, 0.12);\r\n}\r\n\r\n.primary-button,\r\n.secondary-button,\r\n.icon-button,\r\n.tab-button,\r\n.tab-menu-item,\r\n.store-card {\r\n  border: 0;\r\n}\r\n\r\n.primary-button,\r\n.secondary-button,\r\n.icon-button {\r\n  border-radius: 16px;\r\n  min-height: 50px;\r\n  padding: 0 18px;\r\n}\r\n\r\n.primary-button {\r\n  background: linear-gradient(135deg, var(--accent) 0%, #f38a42 100%);\r\n  color: #102638;\r\n  font-weight: 700;\r\n}\r\n\r\n.primary-button:disabled {\r\n  cursor: wait;\r\n  opacity: 0.75;\r\n}\r\n\r\n.secondary-button,\r\n.icon-button {\r\n  background: rgba(255, 255, 255, 0.06);\r\n  color: var(--text);\r\n}\r\n\r\n.card-footer-copy {\r\n  display: grid;\r\n  gap: 6px;\r\n  font-size: 0.88rem;\r\n}\r\n\r\n.form-error {\r\n  background: rgba(255, 116, 72, 0.12);\r\n  border: 1px solid rgba(255, 116, 72, 0.26);\r\n  border-radius: 16px;\r\n  color: #ffd9ca;\r\n  margin: 0;\r\n  padding: 12px 14px;\r\n}\r\n\r\n.dashboard-header {\r\n  display: grid;\r\n  gap: 24px;\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.dashboard-header-top {\r\n  align-items: start;\r\n  display: flex;\r\n  gap: 20px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.dashboard-header h1 {\r\n  font-size: clamp(2rem, 3vw, 3rem);\r\n  margin: 10px 0 12px;\r\n}\r\n\r\n.dashboard-header p,\r\n.hero-panel p,\r\n.stat-card p,\r\n.module-card p,\r\n.activity-row p,\r\n.feed-row span,\r\n.modal-copy {\r\n  line-height: 1.6;\r\n  margin: 0;\r\n}\r\n\r\n.dashboard-actions {\r\n  align-items: center;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 12px;\r\n  justify-content: flex-end;\r\n}\r\n\r\n.operator-chip {\r\n  align-items: center;\r\n  background: rgba(255, 255, 255, 0.05);\r\n  border: 1px solid var(--line);\r\n  border-radius: 18px;\r\n  display: flex;\r\n  gap: 12px;\r\n  padding: 10px 14px;\r\n}\r\n\r\n.operator-chip strong,\r\n.feed-row strong,\r\n.activity-row strong,\r\n.module-card strong,\r\n.store-card strong {\r\n  display: block;\r\n}\r\n\r\n.avatar-badge {\r\n  align-items: center;\r\n  background: linear-gradient(135deg, rgba(255, 116, 72, 0.2), rgba(255, 180, 142, 0.24));\r\n  border-radius: 999px;\r\n  display: inline-flex;\r\n  height: 42px;\r\n  justify-content: center;\r\n  width: 42px;\r\n}\r\n\r\n.top-tabs {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 12px;\r\n  position: relative;\r\n}\r\n\r\n.tab-wrap {\r\n  position: relative;\r\n}\r\n\r\n.tab-button {\r\n  background: rgba(255, 255, 255, 0.05);\r\n  border-radius: 999px;\r\n  color: var(--text);\r\n  min-height: 42px;\r\n  padding: 0 18px;\r\n}\r\n\r\n.tab-button.open {\r\n  background: rgba(255, 116, 72, 0.16);\r\n  color: var(--accent-soft);\r\n}\r\n\r\n.tab-menu {\r\n  background: var(--panel-strong);\r\n  border: 1px solid var(--line);\r\n  border-radius: 20px;\r\n  box-shadow: var(--shadow);\r\n  display: grid;\r\n  gap: 8px;\r\n  min-width: 220px;\r\n  padding: 12px;\r\n  position: absolute;\r\n  top: calc(100% + 10px);\r\n  z-index: 2;\r\n}\r\n\r\n.tab-menu-entry {\r\n  position: relative;\r\n}\r\n\r\n.tab-menu-item {\r\n  background: rgba(255, 255, 255, 0.04);\r\n  border-radius: 14px;\r\n  color: var(--text);\r\n  min-height: 42px;\r\n  padding: 0 14px;\r\n  text-align: left;\r\n}\r\n\r\n.tab-menu-item-submenu {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  width: 100%;\r\n}\r\n\r\n.tab-menu-chevron {\r\n  font-size: 0.86rem;\r\n  opacity: 0.62;\r\n}\r\n\r\n.tab-submenu {\r\n  background: var(--panel-strong);\r\n  border: 1px solid var(--line);\r\n  border-radius: 20px;\r\n  box-shadow: var(--shadow);\r\n  display: none;\r\n  gap: 8px;\r\n  left: calc(100% + 10px);\r\n  min-width: 220px;\r\n  padding: 12px;\r\n  position: absolute;\r\n  top: -12px;\r\n  z-index: 3;\r\n}\r\n\r\n.tab-menu-submenu-shell:hover > .tab-submenu,\r\n.tab-menu-submenu-shell:focus-within > .tab-submenu {\r\n  display: grid;\r\n}\r\n\r\n.dashboard-main {\r\n  display: grid;\r\n  gap: 20px;\r\n}\r\n\r\n.banner-error {\r\n  margin-bottom: 0;\r\n}\r\n\r\n.compact-panel {\r\n  border-radius: 28px;\r\n  padding: 24px;\r\n}\r\n\r\n.hero-panel {\r\n  align-items: end;\r\n  display: grid;\r\n  gap: 20px;\r\n  grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);\r\n}\r\n\r\n.hero-meta-grid {\r\n  display: grid;\r\n  gap: 14px;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.hero-meta-grid div,\r\n.stat-card,\r\n.module-card,\r\n.feed-row,\r\n.activity-row,\r\n.store-card {\r\n  background: rgba(255, 255, 255, 0.04);\r\n  border: 1px solid rgba(255, 255, 255, 0.06);\r\n  border-radius: 20px;\r\n}\r\n\r\n.hero-meta-grid div {\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 16px;\r\n}\r\n\r\n.hero-meta-grid strong,\r\n.stat-card strong {\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 1.35rem;\r\n}\r\n\r\n.stats-strip {\r\n  display: grid;\r\n  gap: 16px;\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n}\r\n\r\n.stat-card {\r\n  display: grid;\r\n  gap: 14px;\r\n}\r\n\r\n.board-layout {\r\n  display: grid;\r\n  gap: 20px;\r\n  grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.85fr);\r\n}\r\n\r\n.board-column {\r\n  display: grid;\r\n  gap: 20px;\r\n}\r\n\r\n.section-panel {\r\n  display: grid;\r\n  gap: 18px;\r\n}\r\n\r\n.panel-heading {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.module-grid,\r\n.feed-list,\r\n.activity-list,\r\n.store-grid {\r\n  display: grid;\r\n  gap: 14px;\r\n}\r\n\r\n.module-grid {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.module-card,\r\n.activity-row,\r\n.store-card {\r\n  display: grid;\r\n  gap: 14px;\r\n  padding: 18px;\r\n}\r\n\r\n.module-card-top,\r\n.module-footer,\r\n.feed-row {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 10px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.module-category,\r\n.store-code {\r\n  color: var(--accent-soft);\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  letter-spacing: 0.08em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.status-pill {\r\n  border-radius: 999px;\r\n  display: inline-flex;\r\n  font-size: 0.78rem;\r\n  padding: 7px 12px;\r\n}\r\n\r\n.tone-online,\r\n.tone-publishing,\r\n.tone-ready,\r\n.tone-streaming,\r\n.tone-stable {\r\n  background: rgba(68, 193, 136, 0.14);\r\n  color: #9be7bf;\r\n}\r\n\r\n.tone-mapping,\r\n.tone-building,\r\n.tone-attention {\r\n  background: rgba(242, 178, 79, 0.15);\r\n  color: #ffd28a;\r\n}\r\n\r\n.tone-accent {\r\n  background: rgba(255, 116, 72, 0.14);\r\n  color: var(--accent-soft);\r\n}\r\n\r\n.feed-row {\r\n  padding: 16px 18px;\r\n}\r\n\r\n.feed-row div {\r\n  display: grid;\r\n  gap: 6px;\r\n}\r\n\r\n.activity-row {\r\n  gap: 8px;\r\n}\r\n\r\n.modal-backdrop {\r\n  align-items: center;\r\n  -webkit-backdrop-filter: blur(10px);\r\n  backdrop-filter: blur(10px);\r\n  background: rgba(3, 11, 18, 0.6);\r\n  display: flex;\r\n  inset: 0;\r\n  justify-content: center;\r\n  padding: 24px;\r\n  position: fixed;\r\n  z-index: 10;\r\n}\r\n\r\n.modal-panel {\r\n  border-radius: 28px;\r\n  display: grid;\r\n  gap: 18px;\r\n  max-width: 720px;\r\n  padding: 26px;\r\n  width: min(100%, 720px);\r\n}\r\n\r\n.modal-header {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 16px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.modal-header h2 {\r\n  margin: 4px 0 0;\r\n}\r\n\r\n.store-grid {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.store-card {\r\n  color: var(--text);\r\n  min-height: 140px;\r\n  text-align: left;\r\n}\r\n\r\n.store-card.active,\r\n.store-card:hover {\r\n  border-color: rgba(255, 180, 142, 0.5);\r\n  transform: translateY(-1px);\r\n}\r\n\r\n@media (max-width: 1080px) {\r\n  .landing-hero,\r\n  .login-screen,\r\n  .hero-panel,\r\n  .board-layout {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .login-card-shell {\r\n    justify-content: stretch;\r\n  }\r\n\r\n  .login-card {\r\n    width: 100%;\r\n  }\r\n\r\n  .stats-strip {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n\r\n  .landing-download-grid {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n}\r\n\r\n@media (max-width: 760px) {\r\n  .landing-screen,\r\n  .login-page-screen,\r\n  .login-screen,\r\n  .dashboard-screen {\r\n    padding: 20px;\r\n  }\r\n\r\n  .landing-download-grid,\r\n  .highlight-list,\r\n  .module-grid,\r\n  .store-grid,\r\n  .stats-strip,\r\n  .hero-meta-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .dashboard-header-top,\r\n  .dashboard-actions,\r\n  .landing-web-access,\r\n  .feed-row,\r\n  .module-card-top,\r\n  .module-footer,\r\n  .modal-header {\r\n    align-items: stretch;\r\n    flex-direction: column;\r\n  }\r\n\r\n  .landing-web-login-button {\r\n    width: 100%;\r\n  }\r\n\r\n  .tab-menu {\r\n    left: 0;\r\n    right: auto;\r\n    width: min(260px, calc(100vw - 64px));\r\n  }\r\n\r\n  .tab-submenu {\r\n    left: 0;\r\n    top: calc(100% + 8px);\r\n    width: min(260px, calc(100vw - 64px));\r\n  }\r\n}\r\n\r\n.legacy-dashboard {\r\n  background: #d7e0e3;\r\n  color: #10293b;\r\n  padding: 0;\r\n}\r\n\r\n.legacy-dashboard .banner-error {\r\n  margin: 12px 16px 0;\r\n}\r\n\r\n.legacy-app-frame {\r\n  border-bottom: 1px solid #4a6677;\r\n}\r\n\r\n.legacy-app-frame.is-drop-target {\r\n  box-shadow: inset 0 0 0 2px rgba(122, 208, 235, 0.82);\r\n}\r\n\r\n.legacy-app-frame.is-desktop-app-frame {\r\n  background: linear-gradient(180deg, #f7fbfd 0%, #edf4f8 100%);\r\n  border-bottom-color: #d4e0e8;\r\n  box-shadow: 0 14px 32px rgba(19, 53, 74, 0.08);\r\n}\r\n\r\n.legacy-title-strip {\r\n  align-items: center;\r\n  background: #dce9ec;\r\n  color: #173446;\r\n  display: flex;\r\n  font-size: 0.78rem;\r\n  justify-content: space-between;\r\n  min-height: 36px;\r\n  padding: 0 12px;\r\n}\r\n\r\n.legacy-title-strip.is-desktop-title-strip {\r\n  background: linear-gradient(180deg, #fbfdff 0%, #ecf4f8 100%);\r\n  border-bottom: 1px solid #dce7ee;\r\n  color: #4e6b7f;\r\n  font-size: 0.74rem;\r\n  font-weight: 600;\r\n  letter-spacing: 0.04em;\r\n  min-height: 42px;\r\n  padding: 0 16px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.legacy-menu-row {\r\n  align-items: center;\r\n  background: #ece9df;\r\n  border-bottom: 1px solid #6a7174;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  min-height: 28px;\r\n  padding: 0 8px;\r\n  position: relative;\r\n  z-index: 5;\r\n}\r\n\r\n.legacy-menu-row.is-desktop-menu-row {\r\n  background: linear-gradient(180deg, #f9fbfd 0%, #eef4f8 100%);\r\n  border-bottom-color: #dbe6ed;\r\n  min-height: 42px;\r\n  padding: 0 12px;\r\n}\r\n\r\n.legacy-menu-row .top-tabs {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 0;\r\n}\r\n\r\n.legacy-menu-row .tab-wrap {\r\n  position: relative;\r\n}\r\n\r\n.legacy-login-menu-links {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 0;\r\n}\r\n\r\n.legacy-static-menu-item {\r\n  align-items: center;\r\n  color: #10293b;\r\n  display: inline-flex;\r\n  font-size: 0.82rem;\r\n  min-height: 28px;\r\n  padding: 0 9px;\r\n}\r\n\r\n.legacy-menu-row .tab-button {\r\n  background: transparent;\r\n  border-radius: 0;\r\n  color: #10293b;\r\n  font-size: 0.82rem;\r\n  font-weight: 500;\r\n  min-height: 28px;\r\n  padding: 0 9px;\r\n}\r\n\r\n.legacy-menu-row.is-desktop-menu-row .tab-button {\r\n  border-radius: 10px;\r\n  color: #38586b;\r\n  font-size: 0.78rem;\r\n  font-weight: 600;\r\n  min-height: 32px;\r\n  padding: 0 12px;\r\n}\r\n\r\n.legacy-menu-row .tab-button.open,\r\n.legacy-menu-row .tab-button:hover {\r\n  background: #cfd8db;\r\n  color: #10293b;\r\n}\r\n\r\n.legacy-menu-row.is-desktop-menu-row .tab-button.open,\r\n.legacy-menu-row.is-desktop-menu-row .tab-button:hover {\r\n  background: linear-gradient(180deg, #ffffff 0%, #e8f1f6 100%);\r\n  color: #14384b;\r\n}\r\n\r\n.legacy-menu-row .tab-menu {\r\n  background: #d7d0c4;\r\n  border: 1px solid #6a6a6a;\r\n  border-radius: 0;\r\n  box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.18);\r\n  gap: 0;\r\n  min-width: 220px;\r\n  padding: 2px 0;\r\n  top: 100%;\r\n}\r\n\r\n.legacy-menu-row.is-desktop-menu-row .tab-menu {\r\n  background: #fbfdff;\r\n  border-color: #d7e2ea;\r\n  border-radius: 14px;\r\n  box-shadow: 0 18px 40px rgba(19, 53, 74, 0.14);\r\n  margin-top: 6px;\r\n  overflow: visible;\r\n}\r\n\r\n.legacy-menu-row .tab-menu-item {\r\n  align-items: center;\r\n  background: transparent;\r\n  border-radius: 0;\r\n  color: #10293b;\r\n  display: flex;\r\n  font-size: 0.82rem;\r\n  justify-content: flex-start;\r\n  min-height: 26px;\r\n  padding: 0 10px;\r\n}\r\n\r\n.legacy-menu-row .tab-menu-item:hover {\r\n  background: #1c516f;\r\n  color: #fff;\r\n}\r\n\r\n.legacy-menu-row.is-desktop-menu-row .tab-menu-item:hover {\r\n  background: #edf4f8;\r\n  color: #12384b;\r\n}\r\n\r\n.legacy-menu-row .tab-submenu {\r\n  background: #d7d0c4;\r\n  border: 1px solid #6a6a6a;\r\n  border-radius: 0;\r\n  box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.18);\r\n  gap: 0;\r\n  left: calc(100% - 2px);\r\n  padding: 2px 0;\r\n  top: -3px;\r\n}\r\n\r\n.legacy-menu-row.is-desktop-menu-row .tab-submenu {\r\n  background: #fbfdff;\r\n  border-color: #d7e2ea;\r\n  border-radius: 14px;\r\n  box-shadow: 0 18px 40px rgba(19, 53, 74, 0.14);\r\n}\r\n\r\n.legacy-header-tools {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 8px;\r\n}\r\n\r\n.legacy-header-tools.is-desktop-header-tools {\r\n  gap: 10px;\r\n}\r\n\r\n.legacy-global-search-shell {\r\n  position: relative;\r\n}\r\n\r\n.legacy-global-search {\r\n  background: #fff;\r\n  border: 1px solid #a8b5bc;\r\n  border-radius: 2px;\r\n  color: #163348;\r\n  height: 22px;\r\n  min-width: 210px;\r\n  padding: 0 8px;\r\n}\r\n\r\n.legacy-global-search.is-desktop-global-search {\r\n  background: linear-gradient(180deg, #ffffff 0%, #f3f8fb 100%);\r\n  border-color: #d3dfe7;\r\n  border-radius: 12px;\r\n  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);\r\n  height: 34px;\r\n  min-width: 280px;\r\n  padding: 0 12px;\r\n}\r\n\r\n.legacy-search-results {\r\n  background: #fbfcfd;\r\n  border: 1px solid #9daab3;\r\n  box-shadow: 0 14px 32px rgba(4, 19, 31, 0.18);\r\n  display: grid;\r\n  left: 0;\r\n  margin-top: 4px;\r\n  max-height: 320px;\r\n  overflow: auto;\r\n  position: absolute;\r\n  top: 100%;\r\n  width: min(420px, 80vw);\r\n  z-index: 5;\r\n}\r\n\r\n.legacy-search-result,\r\n.legacy-search-result-empty {\r\n  border-bottom: 1px solid #d5dde2;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.legacy-search-result {\r\n  background: transparent;\r\n  color: #143345;\r\n  display: grid;\r\n  gap: 3px;\r\n  text-align: left;\r\n}\r\n\r\n.legacy-search-result:hover,\r\n.legacy-search-result:focus-visible {\r\n  background: #edf4f8;\r\n}\r\n\r\n.legacy-search-result strong,\r\n.legacy-search-result-empty {\r\n  font-size: 0.82rem;\r\n}\r\n\r\n.legacy-search-result span {\r\n  color: #567185;\r\n  font-size: 0.75rem;\r\n}\r\n\r\n.legacy-search-result-empty {\r\n  color: #567185;\r\n}\r\n\r\n.legacy-header-button {\r\n  background: #f6f7f7;\r\n  border: 1px solid #8898a0;\r\n  border-radius: 4px;\r\n  color: #173446;\r\n  height: 24px;\r\n  padding: 0 10px;\r\n}\r\n\r\n.legacy-header-button.is-desktop-header-button {\r\n  background: linear-gradient(180deg, #ffffff 0%, #edf4f8 100%);\r\n  border-color: #d3dfe7;\r\n  border-radius: 12px;\r\n  box-shadow: 0 8px 16px rgba(19, 53, 74, 0.05);\r\n  font-weight: 600;\r\n  height: 34px;\r\n  padding: 0 14px;\r\n}\r\n\r\n.legacy-launch-strip {\r\n  background: linear-gradient(180deg, #0b3757 0%, #0b2840 100%);\r\n  display: grid;\r\n  gap: 6px;\r\n  grid-template-columns: repeat(10, minmax(0, 1fr));\r\n  padding: 5px 6px 7px;\r\n}\r\n\r\n.legacy-launch-strip.is-drop-target {\r\n  box-shadow: inset 0 0 0 2px rgba(122, 208, 235, 0.9);\r\n}\r\n\r\n.legacy-launch-button-shell {\r\n  min-width: 0;\r\n  position: relative;\r\n}\r\n\r\n.legacy-launch-button-shell.is-dragging {\r\n  opacity: 0.42;\r\n}\r\n\r\n.legacy-launch-button-shell.is-drop-before::before,\r\n.legacy-launch-button-shell.is-drop-after::after {\r\n  background: #7ad0eb;\r\n  border-radius: 999px;\r\n  box-shadow: 0 0 0 1px rgba(9, 42, 62, 0.24);\r\n  content: \"\";\r\n  position: absolute;\r\n  top: 6px;\r\n  bottom: 6px;\r\n  width: 4px;\r\n  z-index: 3;\r\n}\r\n\r\n.legacy-launch-button-shell.is-drop-before::before {\r\n  left: -4px;\r\n}\r\n\r\n.legacy-launch-button-shell.is-drop-after::after {\r\n  right: -4px;\r\n}\r\n\r\n.legacy-launch-button-shell .legacy-launch-button {\r\n  width: 100%;\r\n}\r\n\r\n.legacy-launch-button-shell.is-context-open .legacy-launch-button {\r\n  border-color: #9fc2d7;\r\n  box-shadow: 0 10px 20px rgba(4, 24, 39, 0.16);\r\n}\r\n\r\n.legacy-launch-context-button {\r\n  align-items: center;\r\n  background: #f3fafc;\r\n  border: 1px solid #b8d1de;\r\n  border-radius: 999px;\r\n  color: #18445a;\r\n  cursor: pointer;\r\n  display: inline-flex;\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 0.62rem;\r\n  font-weight: 700;\r\n  height: 18px;\r\n  justify-content: center;\r\n  padding: 0;\r\n  position: absolute;\r\n  right: 8px;\r\n  top: 8px;\r\n  width: 18px;\r\n}\r\n\r\n.legacy-launch-context-button:hover {\r\n  background: #ffffff;\r\n  border-color: #d04b4b;\r\n  color: #8a2323;\r\n}\r\n\r\n.legacy-launch-strip.is-desktop-launch-strip {\r\n  background: linear-gradient(180deg, #edf4f8 0%, #dde9f0 100%);\r\n  border-top: 1px solid rgba(255, 255, 255, 0.72);\r\n  grid-template-columns: repeat(10, minmax(0, 1fr));\r\n  padding: 10px 12px 12px;\r\n}\r\n\r\n.legacy-launch-strip.is-desktop-launch-strip .legacy-launch-button {\r\n  background: linear-gradient(180deg, #ffffff 0%, #edf4f8 100%);\r\n  border-color: #d3dfe7;\r\n  box-shadow: 0 10px 18px rgba(19, 53, 74, 0.06);\r\n  color: #14374a;\r\n}\r\n\r\n.legacy-launch-strip.is-desktop-launch-strip .legacy-launch-button span {\r\n  background: rgba(31, 138, 167, 0.08);\r\n  color: #1b566f;\r\n}\r\n\r\n.legacy-launch-strip.is-desktop-launch-strip .legacy-launch-button.is-active {\r\n  background: linear-gradient(180deg, #fdfefe 0%, #dfeef4 100%);\r\n  border-color: #8cb9cd;\r\n}\r\n\r\n.legacy-launch-button {\r\n  align-items: center;\r\n  background: linear-gradient(180deg, #0d466c 0%, #0a2942 100%);\r\n  border: 1px solid #678aa1;\r\n  border-radius: 12px;\r\n  color: #eef7fb;\r\n  display: flex;\r\n  gap: 8px;\r\n  min-height: 38px;\r\n  padding: 0 10px;\r\n  text-align: left;\r\n  transition: border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;\r\n}\r\n\r\n.legacy-launch-button span {\r\n  align-items: center;\r\n  background: rgba(210, 234, 246, 0.12);\r\n  border-radius: 999px;\r\n  display: inline-flex;\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  height: 24px;\r\n  justify-content: center;\r\n  width: 24px;\r\n}\r\n\r\n.legacy-launch-button strong {\r\n  font-size: 0.8rem;\r\n  line-height: 1;\r\n}\r\n\r\n.legacy-launch-button:hover {\r\n  border-color: #9fc2d7;\r\n  box-shadow: 0 10px 20px rgba(4, 24, 39, 0.16);\r\n  transform: translateY(-1px);\r\n}\r\n\r\n.legacy-launch-button.is-active {\r\n  background: linear-gradient(180deg, #fdfefe 0%, #e7f0f5 100%);\r\n  border-color: #b7d2e0;\r\n  box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.9), 0 10px 20px rgba(4, 24, 39, 0.14);\r\n  color: #12354a;\r\n}\r\n\r\n.legacy-launch-button.is-active span {\r\n  background: rgba(18, 63, 90, 0.08);\r\n  color: #12354a;\r\n}\r\n\r\n.legacy-launch-button:disabled {\r\n  cursor: default;\r\n  opacity: 0.8;\r\n}\r\n\r\n.legacy-login-screen {\r\n  background: #d7e0e3;\r\n  min-height: 100vh;\r\n}\r\n\r\n.legacy-login-body {\r\n  display: grid;\r\n  grid-template-columns: 280px minmax(0, 1fr);\r\n  min-height: calc(100vh - 109px);\r\n}\r\n\r\n.legacy-login-sidebar {\r\n  background: #0c3553;\r\n  color: #edf4f8;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.legacy-login-sidebar .legacy-window-link {\r\n  cursor: default;\r\n}\r\n\r\n.legacy-login-sidebar-footer {\r\n  display: grid;\r\n  gap: 16px;\r\n  padding: 22px 18px;\r\n}\r\n\r\n.legacy-login-sidebar-footer h1 {\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 2rem;\r\n  line-height: 1;\r\n  margin: 0;\r\n}\r\n\r\n.legacy-login-sidebar-footer p {\r\n  color: #a9bfce;\r\n  line-height: 1.6;\r\n  margin: 0;\r\n}\r\n\r\n.legacy-login-highlight-list {\r\n  display: grid;\r\n  gap: 10px;\r\n}\r\n\r\n.legacy-login-highlight {\r\n  background: rgba(255, 255, 255, 0.06);\r\n  border: 1px solid rgba(255, 255, 255, 0.08);\r\n  border-radius: 14px;\r\n  display: grid;\r\n  gap: 6px;\r\n  padding: 12px;\r\n}\r\n\r\n.legacy-login-highlight strong {\r\n  color: #fff;\r\n}\r\n\r\n.legacy-login-highlight span {\r\n  color: #b5c7d4;\r\n  font-size: 0.84rem;\r\n  line-height: 1.5;\r\n}\r\n\r\n.legacy-login-workarea {\r\n  background: #eef0f1;\r\n  display: grid;\r\n  grid-template-rows: auto 1fr;\r\n}\r\n\r\n.legacy-login-stage {\r\n  align-items: center;\r\n  display: grid;\r\n  min-height: 100%;\r\n  padding: 24px;\r\n}\r\n\r\n.legacy-login-panel {\r\n  background: #f7f8f8;\r\n  border: 1px solid #99a7b0;\r\n  box-shadow: 0 20px 48px rgba(0, 0, 0, 0.18);\r\n  display: grid;\r\n  gap: 24px;\r\n  margin: 0 auto;\r\n  max-width: 520px;\r\n  padding: 28px;\r\n  width: 100%;\r\n}\r\n\r\n.legacy-login-panel-header {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.legacy-login-panel-header h2 {\r\n  color: #10293b;\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 2rem;\r\n  margin: 0;\r\n}\r\n\r\n.legacy-login-panel-header p {\r\n  color: #4d6575;\r\n  margin: 0;\r\n}\r\n\r\n.legacy-login-form {\r\n  display: grid;\r\n  gap: 16px;\r\n}\r\n\r\n.legacy-login-form label {\r\n  display: grid;\r\n  gap: 6px;\r\n}\r\n\r\n.legacy-login-form span {\r\n  color: #335065;\r\n  font-size: 0.84rem;\r\n  font-weight: 600;\r\n}\r\n\r\n.legacy-login-form input {\r\n  background: #fff;\r\n  border: 1px solid #a7b4bb;\r\n  border-radius: 2px;\r\n  color: #153047;\r\n  min-height: 36px;\r\n  outline: none;\r\n  padding: 0 10px;\r\n}\r\n\r\n.legacy-login-form input:focus {\r\n  border-color: #ff7448;\r\n  box-shadow: 0 0 0 3px rgba(255, 116, 72, 0.12);\r\n}\r\n\r\n.legacy-login-submit {\r\n  background: linear-gradient(180deg, #0d466c 0%, #0a2942 100%);\r\n  border: 1px solid #65859b;\r\n  color: #f1f7fb;\r\n  min-height: 40px;\r\n}\r\n\r\n.legacy-login-submit:disabled {\r\n  cursor: wait;\r\n  opacity: 0.8;\r\n}\r\n\r\n.legacy-login-note-bar {\r\n  color: #567185;\r\n  display: grid;\r\n  gap: 6px;\r\n  font-size: 0.82rem;\r\n}\r\n\r\n.legacy-workspace-shell {\r\n  display: grid;\r\n  grid-template-columns: 220px minmax(0, 1fr);\r\n  height: calc(100vh - 109px);\r\n  min-height: calc(100vh - 109px);\r\n  overflow: hidden;\r\n}\r\n\r\n.legacy-workspace-shell.is-desktop-shell {\r\n  grid-template-columns: 220px minmax(0, 1fr);\r\n}\r\n\r\n.legacy-workspace-shell.is-sandbox-shell {\r\n  grid-template-columns: minmax(0, 1fr);\r\n  height: calc(100vh - 78px);\r\n  min-height: calc(100vh - 78px);\r\n}\r\n\r\n.legacy-workspace-shell.is-service-shell {\r\n  height: calc(100vh - 116px);\r\n  min-height: calc(100vh - 116px);\r\n}\r\n\r\n.legacy-open-windows {\r\n  background: linear-gradient(180deg, #0d3958 0%, #0b3049 38%, #08253a 100%);\r\n  border-right: 1px solid rgba(255, 255, 255, 0.08);\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n  min-height: 0;\r\n  overflow: auto;\r\n  padding: 12px 10px 14px;\r\n}\r\n\r\n.legacy-open-windows.is-desktop-open-windows {\r\n  background: linear-gradient(180deg, #0d3958 0%, #0b3049 38%, #08253a 100%);\r\n  border-right-color: rgba(255, 255, 255, 0.08);\r\n}\r\n\r\n.legacy-open-title {\r\n  align-items: center;\r\n  background: linear-gradient(180deg, #afc2ce 0%, #7e9aae 100%);\r\n  color: #0a2940;\r\n  display: flex;\r\n  font-size: 0.8rem;\r\n  font-weight: 700;\r\n  justify-content: center;\r\n  min-height: 28px;\r\n}\r\n\r\n.legacy-open-header {\r\n  background: linear-gradient(180deg, rgba(255, 255, 255, 0.16) 0%, rgba(214, 231, 240, 0.08) 100%);\r\n  border: 1px solid rgba(196, 217, 228, 0.22);\r\n  border-radius: 14px;\r\n  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12), 0 12px 24px rgba(3, 16, 26, 0.18);\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 12px;\r\n  position: relative;\r\n}\r\n\r\n.legacy-open-title-row {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 10px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.legacy-open-header-actions {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 8px;\r\n}\r\n\r\n.legacy-open-windows .legacy-open-title {\r\n  background: none;\r\n  color: #f4fafc;\r\n  font-size: 0.76rem;\r\n  justify-content: flex-start;\r\n  letter-spacing: 0.08em;\r\n  min-height: 0;\r\n  padding: 0;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.legacy-open-windows.is-desktop-open-windows .legacy-open-title {\r\n  background: none;\r\n  border-bottom: 0;\r\n  min-height: 0;\r\n}\r\n\r\n.legacy-open-help-shell {\r\n  position: static;\r\n}\r\n\r\n.legacy-open-icon-button {\r\n  align-items: center;\r\n  background: rgba(255, 255, 255, 0.12);\r\n  border: 1px solid rgba(255, 255, 255, 0.16);\r\n  border-radius: 999px;\r\n  color: #eef6fa;\r\n  display: inline-flex;\r\n  font-size: 0.72rem;\r\n  font-weight: 700;\r\n  height: 26px;\r\n  justify-content: center;\r\n  min-width: 26px;\r\n  padding: 0;\r\n  width: 26px;\r\n}\r\n\r\n.legacy-open-icon-button:hover,\r\n.legacy-open-icon-button:focus-visible {\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border-color: rgba(255, 255, 255, 0.28);\r\n}\r\n\r\n.legacy-open-help-tooltip {\r\n  background: #f7fbfd;\r\n  border: 1px solid #c4d7e4;\r\n  border-radius: 12px;\r\n  box-shadow: 0 18px 32px rgba(6, 18, 29, 0.2);\r\n  color: #16374c;\r\n  font-size: 0.72rem;\r\n  line-height: 1.45;\r\n  opacity: 0;\r\n  padding: 10px 12px;\r\n  pointer-events: none;\r\n  position: absolute;\r\n  left: 12px;\r\n  right: 12px;\r\n  top: calc(100% + 8px);\r\n  transform: translateY(-4px);\r\n  transition: opacity 140ms ease, transform 140ms ease;\r\n  width: auto;\r\n  z-index: 4;\r\n}\r\n\r\n.legacy-open-help-shell:hover .legacy-open-help-tooltip,\r\n.legacy-open-help-shell:focus-within .legacy-open-help-tooltip {\r\n  opacity: 1;\r\n  transform: translateY(0);\r\n}\r\n\r\n.legacy-open-clear-button {\r\n  background: rgba(255, 255, 255, 0.94);\r\n  border: 1px solid rgba(194, 214, 226, 0.9);\r\n  border-radius: 999px;\r\n  color: #12364b;\r\n  font-size: 0.68rem;\r\n  font-weight: 700;\r\n  min-height: 28px;\r\n  padding: 0 10px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.legacy-open-clear-button:hover:not(:disabled),\r\n.legacy-open-clear-button:focus-visible:not(:disabled) {\r\n  background: #ffffff;\r\n  border-color: #8db7c9;\r\n}\r\n\r\n.legacy-open-clear-button:disabled {\r\n  cursor: not-allowed;\r\n  opacity: 0.45;\r\n}\r\n\r\n.legacy-open-window-list {\r\n  align-content: start;\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.legacy-open-window-canvas {\r\n  background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(214, 231, 240, 0.02) 100%);\r\n  border: 1px dashed rgba(189, 214, 226, 0.28);\r\n  border-radius: 14px;\r\n  min-height: 92px;\r\n}\r\n\r\n.legacy-open-windows.is-sandbox-open-windows {\r\n  gap: 0;\r\n}\r\n\r\n.legacy-window-link {\r\n  background: #8ea7b8;\r\n  border: 0;\r\n  border-left: 4px solid #ff6f3c;\r\n  border-top: 1px solid rgba(255, 255, 255, 0.12);\r\n  color: #08263a;\r\n  font-size: 0.84rem;\r\n  min-height: 30px;\r\n  padding: 0 10px;\r\n  text-align: left;\r\n}\r\n\r\n.legacy-open-windows .legacy-window-link {\r\n  align-items: center;\r\n  background: linear-gradient(180deg, rgba(250, 253, 255, 0.98) 0%, rgba(225, 236, 243, 0.98) 100%);\r\n  border: 1px solid rgba(176, 198, 211, 0.92);\r\n  border-left: 0;\r\n  border-radius: 12px;\r\n  box-shadow: 0 8px 16px rgba(4, 20, 32, 0.12);\r\n  color: #12364b;\r\n  display: flex;\r\n  font-weight: 600;\r\n  justify-content: flex-start;\r\n  min-height: 44px;\r\n  padding: 0 14px;\r\n  position: relative;\r\n  transition: background 140ms ease, border-color 140ms ease, box-shadow 140ms ease, transform 140ms ease;\r\n  width: 100%;\r\n}\r\n\r\n.legacy-open-windows .legacy-window-link:active {\r\n  cursor: grabbing;\r\n}\r\n\r\n.legacy-window-link-copy {\r\n  min-width: 0;\r\n}\r\n\r\n.legacy-window-link-grip {\r\n  color: #6f8ea4;\r\n  flex: 0 0 auto;\r\n  font-size: 0.92rem;\r\n  letter-spacing: -0.18em;\r\n  margin-right: 10px;\r\n}\r\n\r\n.legacy-open-windows.is-desktop-open-windows .legacy-window-link {\r\n  background: linear-gradient(180deg, rgba(250, 253, 255, 0.98) 0%, rgba(225, 236, 243, 0.98) 100%);\r\n  border-color: rgba(176, 198, 211, 0.92);\r\n  color: #12364b;\r\n}\r\n\r\n.legacy-open-windows .legacy-window-link:hover {\r\n  background: linear-gradient(180deg, #ffffff 0%, #edf6fa 100%);\r\n  border-color: #8db7c9;\r\n  box-shadow: 0 12px 22px rgba(4, 20, 32, 0.16);\r\n  transform: translateX(2px);\r\n}\r\n\r\n.legacy-open-windows.is-desktop-open-windows .legacy-window-link:hover {\r\n  background: linear-gradient(180deg, #ffffff 0%, #edf6fa 100%);\r\n}\r\n\r\n.legacy-window-link.active {\r\n  background: #f4f5f5;\r\n  font-weight: 700;\r\n}\r\n\r\n.legacy-open-windows .legacy-window-link.active {\r\n  background: linear-gradient(180deg, #174767 0%, #103650 100%);\r\n  border-color: #6db8d6;\r\n  box-shadow: 0 12px 22px rgba(6, 18, 29, 0.22), inset 0 0 0 1px rgba(255, 255, 255, 0.08);\r\n  color: #f5fbff;\r\n}\r\n\r\n.legacy-open-windows.is-desktop-open-windows .legacy-window-link.active {\r\n  background: linear-gradient(180deg, #174767 0%, #103650 100%);\r\n  border-color: #6db8d6;\r\n  color: #f5fbff;\r\n}\r\n\r\n.legacy-open-windows .legacy-window-link.active .legacy
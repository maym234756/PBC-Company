n\r\n.management-activities-detail-grid strong {\r\n  color: #10293b;\r\n  font-size: 0.84rem;\r\n}\r\n\r\n.management-activities-status-chip {\r\n  border: 1px solid #73838e;\r\n  border-radius: 999px;\r\n  font-size: 0.7rem;\r\n  font-weight: 700;\r\n  letter-spacing: 0.04em;\r\n  padding: 4px 8px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.management-activities-status-chip.is-successful {\r\n  background: #e5f4ea;\r\n  color: #2e6f48;\r\n}\r\n\r\n.management-activities-status-chip.is-erroneous {\r\n  background: #fde7e5;\r\n  color: #8d3f34;\r\n}\r\n\r\n.management-activities-status-chip.is-pending {\r\n  background: #fff5dc;\r\n  color: #8c6420;\r\n}\r\n\r\n.management-activities-status-chip.is-in-process {\r\n  background: #e3eef8;\r\n  color: #345a7a;\r\n}\r\n\r\n.management-activities-grid-wrap {\r\n  border: 1px solid #8b9aa4;\r\n  max-height: 620px;\r\n  overflow: auto;\r\n}\r\n\r\n.management-activities-grid {\r\n  background: #f9fafb;\r\n  border-collapse: collapse;\r\n  min-width: 100%;\r\n}\r\n\r\n.management-activities-grid th,\r\n.management-activities-grid td {\r\n  border: 1px solid #b7c2c9;\r\n  font-size: 0.76rem;\r\n  padding: 4px 8px;\r\n  text-align: left;\r\n}\r\n\r\n.management-activities-grid th {\r\n  background: linear-gradient(180deg, #1d5470 0%, #12394f 100%);\r\n  color: #f3f8fb;\r\n  position: sticky;\r\n  top: 0;\r\n}\r\n\r\n.management-activities-grid tbody tr {\r\n  background: #f7f9fb;\r\n}\r\n\r\n.management-activities-grid tbody tr:nth-child(even) {\r\n  background: #eef3f7;\r\n}\r\n\r\n.management-activities-grid tbody tr.is-selected {\r\n  background: #d7e8f3;\r\n}\r\n\r\n.management-activities-grid tbody tr.is-aged-issue {\r\n  box-shadow: inset 3px 0 0 #cb715a;\r\n}\r\n\r\n.management-activities-status-stack {\r\n  display: grid;\r\n  gap: 2px;\r\n}\r\n\r\n.management-activities-status-text {\r\n  font-weight: 700;\r\n}\r\n\r\n.management-activities-status-text.is-successful {\r\n  color: #2e6f48;\r\n}\r\n\r\n.management-activities-status-text.is-erroneous {\r\n  color: #8d3f34;\r\n}\r\n\r\n.management-activities-status-text.is-pending {\r\n  color: #8c6420;\r\n}\r\n\r\n.management-activities-status-text.is-in-process {\r\n  color: #345a7a;\r\n}\r\n\r\n.management-activities-inline-reason {\r\n  color: #5d7384;\r\n  font-size: 0.69rem;\r\n  line-height: 1.3;\r\n}\r\n\r\n.management-activities-age-cell.is-aged {\r\n  color: #8d3f34;\r\n  font-weight: 700;\r\n}\r\n\r\n.management-activities-document-link {\r\n  background: none;\r\n  border: 0;\r\n  color: #3d5ddb;\r\n  font-size: 0.76rem;\r\n  padding: 0;\r\n  text-decoration: underline;\r\n}\r\n\r\n.management-activities-empty-state {\r\n  color: #5a7385;\r\n  padding: 24px 12px;\r\n  text-align: center;\r\n}\r\n\r\n@media (max-width: 1100px) {\r\n  .management-activities-kpi-strip {\r\n    grid-template-columns: repeat(3, minmax(0, 1fr));\r\n  }\r\n\r\n  .management-activities-document-grid,\r\n  .management-activities-detail-grid {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n}\r\n\r\n@media (max-width: 820px) {\r\n  .management-activities-toolbar,\r\n  .management-activities-search-row,\r\n  .management-activities-view-row {\r\n    align-items: stretch;\r\n    flex-direction: column;\r\n  }\r\n\r\n  .management-activities-filter-toggle {\r\n    width: 100%;\r\n  }\r\n\r\n  .management-activities-search-field {\r\n    align-items: stretch;\r\n    flex-direction: column;\r\n  }\r\n\r\n  .management-activities-search-field input {\r\n    width: 100%;\r\n  }\r\n\r\n  .management-activities-kpi-strip,\r\n  .management-activities-document-grid,\r\n  .management-activities-detail-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n}\r\n\r\n/* ─── Sales Deal Workbench ──────────────────────────────────────────────────── */\r\n\r\n.legacy-workspace-stack.is-sales-deal-layout {\r\n  height: 100%;\r\n  min-height: 0;\r\n}\r\n\r\n.legacy-workspace-stack.is-sales-deal-layout > * {\r\n  min-height: 0;\r\n  min-width: 0;\r\n}\r\n\r\n.legacy-data-window-sales-detail {\r\n  display: flex;\r\n  flex-direction: column;\r\n  height: 100%;\r\n  min-height: 0;\r\n  overflow: hidden;\r\n}\r\n\r\n.sales-deal-workbench {\r\n  background: #f4f4f4;\r\n  display: flex;\r\n  flex-direction: column;\r\n  flex: 1 1 0;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  font-size: 0.72rem;\r\n  height: 100%;\r\n  min-height: 0;\r\n  overflow-y: auto;\r\n}\r\n\r\n/* Tab bar */\r\n\r\n.sales-deal-tabs {\r\n  align-items: flex-end;\r\n  background: #d9d9d9;\r\n  border-bottom: 2px solid #aaa;\r\n  display: flex;\r\n  flex-shrink: 0;\r\n  flex-wrap: wrap;\r\n  gap: 2px;\r\n  padding: 4px 6px 0;\r\n}\r\n\r\n.sales-deal-tab {\r\n  background: #c5c5c5;\r\n  border: 1px solid #aaa;\r\n  border-bottom: none;\r\n  border-radius: 3px 3px 0 0;\r\n  color: #222;\r\n  cursor: pointer;\r\n  font-family: inherit;\r\n  font-size: 0.7rem;\r\n  padding: 3px 8px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sales-deal-tab:hover {\r\n  background: #d8d8d8;\r\n}\r\n\r\n.sales-deal-tab.active {\r\n  background: #fff;\r\n  font-weight: bold;\r\n  position: relative;\r\n  z-index: 1;\r\n}\r\n\r\n/* General tab layout */\r\n\r\n.sales-deal-general {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 6px;\r\n  padding: 8px;\r\n}\r\n\r\n.sales-deal-header-grid {\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: 1fr 1fr 1fr;\r\n}\r\n\r\n.sales-deal-section {\r\n  background: #fff;\r\n  border: 1px solid #ccc;\r\n  padding: 6px 8px;\r\n}\r\n\r\n.sales-deal-section-title {\r\n  background: #e8edf2;\r\n  border-bottom: 1px solid #ccc;\r\n  font-size: 0.68rem;\r\n  font-weight: bold;\r\n  letter-spacing: 0.03em;\r\n  margin: -6px -8px 6px;\r\n  padding: 2px 8px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-field-row {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 4px;\r\n  margin-bottom: 3px;\r\n}\r\n\r\n.sales-deal-label {\r\n  color: #555;\r\n  flex-shrink: 0;\r\n  font-size: 0.68rem;\r\n  min-width: 80px;\r\n  text-align: right;\r\n}\r\n\r\n.sales-deal-input {\r\n  background: #fffde7;\r\n  border: 1px solid #bbb;\r\n  color: #111;\r\n  flex: 1;\r\n  font-family: inherit;\r\n  font-size: 0.71rem;\r\n  height: 18px;\r\n  min-width: 0;\r\n  padding: 1px 4px;\r\n}\r\n\r\n.sales-deal-input.is-short {\r\n  flex: 0 0 100px;\r\n  min-width: 0;\r\n  width: 100px;\r\n}\r\n\r\n.sales-deal-stage-badge {\r\n  background: #1a5276;\r\n  border-radius: 2px;\r\n  color: #fff;\r\n  font-size: 0.66rem;\r\n  font-weight: bold;\r\n  letter-spacing: 0.04em;\r\n  padding: 2px 8px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-pct {\r\n  color: #333;\r\n  flex-shrink: 0;\r\n  font-size: 0.68rem;\r\n}\r\n\r\n/* Unit toolbar */\r\n\r\n.sales-deal-unit-toolbar {\r\n  align-items: center;\r\n  background: #e2e8ef;\r\n  border: 1px solid #ccc;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 4px;\r\n  padding: 4px 6px;\r\n}\r\n\r\n.sales-deal-unit-toolbar-label {\r\n  font-weight: bold;\r\n  margin-right: 2px;\r\n}\r\n\r\n.sales-deal-toolbar-btn {\r\n  background: #d9e4f0;\r\n  border: 1px solid #99b;\r\n  border-radius: 2px;\r\n  color: #1a3a5c;\r\n  cursor: pointer;\r\n  font-family: inherit;\r\n  font-size: 0.68rem;\r\n  padding: 2px 8px;\r\n}\r\n\r\n.sales-deal-toolbar-btn:hover {\r\n  background: #c5d7ea;\r\n}\r\n\r\n/* Unit table */\r\n\r\n.sales-deal-unit-table-wrap {\r\n  background: #fff;\r\n  border: 1px solid #ccc;\r\n  overflow-x: auto;\r\n}\r\n\r\n.sales-deal-unit-table {\r\n  border-collapse: collapse;\r\n  font-size: 0.7rem;\r\n  min-width: 100%;\r\n  width: 100%;\r\n}\r\n\r\n.sales-deal-unit-table th {\r\n  background: #dce6f0;\r\n  border: 1px solid #ccc;\r\n  font-size: 0.66rem;\r\n  font-weight: bold;\r\n  padding: 3px 6px;\r\n  text-align: left;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sales-deal-unit-table td {\r\n  border: 1px solid #e0e0e0;\r\n  padding: 3px 6px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sales-deal-unit-table td.align-right,\r\n.sales-deal-unit-table th.align-right {\r\n  text-align: right;\r\n}\r\n\r\n.sales-deal-unit-table tbody tr:nth-child(odd) {\r\n  background: #f8fbff;\r\n}\r\n\r\n.sales-deal-unit-empty {\r\n  color: #999;\r\n  font-style: italic;\r\n  text-align: center !important;\r\n}\r\n\r\n/* Pricing grid */\r\n\r\n.sales-deal-pricing-grid {\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: 1fr 1fr 1fr;\r\n}\r\n\r\n.sales-deal-pricing-section {\r\n  background: #fff;\r\n  border: 1px solid #ccc;\r\n  padding: 6px 8px;\r\n}\r\n\r\n.sales-deal-pricing-title {\r\n  background: #e8edf2;\r\n  border-bottom: 1px solid #ccc;\r\n  font-size: 0.68rem;\r\n  font-weight: bold;\r\n  letter-spacing: 0.03em;\r\n  margin: -6px -8px 4px;\r\n  padding: 2px 8px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-pricing-row {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 1px 0;\r\n}\r\n\r\n.sales-deal-pricing-row span:first-child {\r\n  color: #555;\r\n}\r\n\r\n.sales-deal-pricing-row span:last-child {\r\n  font-variant-numeric: tabular-nums;\r\n  text-align: right;\r\n}\r\n\r\n.sales-deal-pricing-row.is-subtotal {\r\n  border-top: 1px solid #ddd;\r\n  font-weight: bold;\r\n  margin-top: 2px;\r\n  padding-top: 3px;\r\n}\r\n\r\n.sales-deal-pricing-row.is-total {\r\n  background: #eaf0f8;\r\n  border-radius: 2px;\r\n  border-top: 2px solid #99b4cc;\r\n  font-weight: bold;\r\n  margin-top: 3px;\r\n  padding: 3px 4px;\r\n}\r\n\r\n/* Placeholder tab */\r\n\r\n.sales-deal-tab-placeholder {\r\n  align-items: center;\r\n  color: #888;\r\n  display: flex;\r\n  font-style: italic;\r\n  justify-content: center;\r\n  min-height: 200px;\r\n  padding: 32px;\r\n}\r\n\r\n.sales-deal-deposits {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n}\r\n\r\n.sales-deal-deposits-hero {\r\n  background: linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);\r\n  border: 1px solid #c2cfdd;\r\n  border-radius: 4px;\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);\r\n  padding: 10px 12px;\r\n}\r\n\r\n.sales-deal-deposits-hero-copy p {\r\n  color: #4f5d6a;\r\n  font-size: 0.76rem;\r\n  margin: 4px 0 0;\r\n}\r\n\r\n.sales-deal-deposits-title-row {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.sales-deal-deposits-kicker {\r\n  color: #6b7d8e;\r\n  font-size: 0.62rem;\r\n  font-weight: bold;\r\n  letter-spacing: 0.08em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-deposits-title-row h4 {\r\n  color: #1f2f44;\r\n  font-size: 1rem;\r\n  margin: 2px 0 0;\r\n}\r\n\r\n.sales-deal-deposits-status {\r\n  border-radius: 999px;\r\n  font-size: 0.66rem;\r\n  font-weight: bold;\r\n  letter-spacing: 0.08em;\r\n  padding: 3px 10px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-deposits-status.is-pending {\r\n  background: #fff3dc;\r\n  border: 1px solid #dfbb72;\r\n  color: #8e5c07;\r\n}\r\n\r\n.sales-deal-deposits-status.is-posted {\r\n  background: #e4f7eb;\r\n  border: 1px solid #87c09a;\r\n  color: #235f38;\r\n}\r\n\r\n.sales-deal-deposits-summary-grid {\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n}\r\n\r\n.sales-deal-deposits-loading {\r\n  color: #5f5b52;\r\n  font-size: 12px;\r\n  margin: 0;\r\n}\r\n\r\n.sales-deal-deposits-summary-card {\r\n  background: #fff;\r\n  border: 1px solid #c9d5e3;\r\n  border-radius: 3px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 2px;\r\n  min-height: 58px;\r\n  padding: 7px 9px;\r\n}\r\n\r\n.sales-deal-deposits-summary-card span {\r\n  color: #67798a;\r\n  font-size: 0.66rem;\r\n  font-weight: bold;\r\n  letter-spacing: 0.04em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-deposits-summary-card strong {\r\n  color: #1d3048;\r\n  font-size: 0.96rem;\r\n  font-variant-numeric: tabular-nums;\r\n}\r\n\r\n.sales-deal-deposits-layout {\r\n  display: grid;\r\n  gap: 12px;\r\n  grid-template-columns: minmax(0, 1.6fr) minmax(300px, 1fr);\r\n}\r\n\r\n.sales-deal-deposits-ledger,\r\n.sales-deal-deposits-card {\r\n  background: #fff;\r\n  border: 1px solid #c9d3df;\r\n  border-radius: 3px;\r\n}\r\n\r\n.sales-deal-deposits-panel-header {\r\n  align-items: center;\r\n  background: #e8edf2;\r\n  border-bottom: 1px solid #ccd5de;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 6px 8px;\r\n}\r\n\r\n.sales-deal-deposits-panel-header h4 {\r\n  color: #233548;\r\n  font-size: 0.78rem;\r\n  margin: 0;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-deposits-panel-header span {\r\n  color: #5f7387;\r\n  font-size: 0.68rem;\r\n}\r\n\r\n.sales-deal-deposits-table-wrap {\r\n  overflow-x: auto;\r\n}\r\n\r\n.sales-deal-deposits-table {\r\n  border-collapse: collapse;\r\n  min-width: 640px;\r\n  width: 100%;\r\n}\r\n\r\n.sales-deal-deposits-table th,\r\n.sales-deal-deposits-table td {\r\n  border-bottom: 1px solid #dbe4ee;\r\n  font-size: 0.76rem;\r\n  padding: 7px 8px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.sales-deal-deposits-table th {\r\n  background: #f8fbfe;\r\n  color: #41566d;\r\n  font-size: 0.68rem;\r\n  text-align: left;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.sales-deal-deposits-row {\r\n  cursor: pointer;\r\n}\r\n\r\n.sales-deal-deposits-row.is-selected td {\r\n  background: #d9e9f7;\r\n}\r\n\r\n.sales-deal-deposits-ledger-actions {\r\n  border-top: 1px solid #d9e2ec;\r\n  display: flex;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.sales-deal-deposits-rail {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.sales-deal-deposits-form-grid {\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.sales-deal-deposits-form-grid label {\r\n  color: #4f6479;\r\n  display: grid;\r\n  font-size: 0.7rem;\r\n  font-weight: 600;\r\n  gap: 4px;\r\n}\r\n\r\n.sales-deal-deposits-actions {\r\n  border-top: 1px solid #d9e2ec;\r\n  display: flex;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.sales-deal-deposits-activity-list {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.sales-deal-deposits-activity-item {\r\n  border: 1px solid #d9e2ec;\r\n  border-radius: 3px;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 3px;\r\n  padding: 7px;\r\n}\r\n\r\n.sales-deal-deposits-activity-copy strong {\r\n  color: #22364d;\r\n  font-size: 0.75rem;\r\n}\r\n\r\n.sales-deal-deposits-activity-copy p {\r\n  color: #5a6d80;\r\n  font-size: 0.72rem;\r\n  margin: 2px 0 0;\r\n}\r\n\r\n.sales-deal-deposits-activity-item > span {\r\n  color: #72869b;\r\n  font-size: 0.66rem;\r\n}\r\n\r\n.sales-deposit-modal-backdrop {\r\n  align-items: center;\r\n  background: rgba(5, 16, 30, 0.5);\r\n  display: flex;\r\n  inset: 0;\r\n  justify-content: center;\r\n  padding: 20px;\r\n  position: fixed;\r\n  z-index: 40;\r\n}\r\n\r\n.sales-deposit-modal,\r\n.sales-deposit-reprint-modal {\r\n  background: #d7d7d7;\r\n  border: 2px solid #7b8795;\r\n  box-shadow: 0 22px 50px rgba(3, 12, 26, 0.55);\r\n  display: flex;\r\n  flex-direction: column;\r\n  max-height: calc(100vh - 48px);\r\n  overflow: auto;\r\n  width: min(920px, 100%);\r\n}\r\n\r\n.sales-deposit-modal-titlebar {\r\n  align-items: center;\r\n  background: #ff6d3b;\r\n  border-bottom: 1px solid #5f6772;\r\n  color: #fff;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 4px 8px;\r\n}\r\n\r\n.sales-deposit-modal-titlebar h4 {\r\n  font-size: 1.85rem;\r\n  letter-spacing: 0.01em;\r\n  margin: 0;\r\n}\r\n\r\n.sales-deposit-modal-close {\r\n  align-items: center;\r\n  background: #f0452d;\r\n  border: 2px solid #4a2f2f;\r\n  color: #180d0d;\r\n  display: inline-flex;\r\n  font-weight: 800;\r\n  height: 24px;\r\n  justify-content: center;\r\n  text-transform: uppercase;\r\n  width: 24px;\r\n}\r\n\r\n.sales-deposit-modal-section {\r\n  border: 2px solid #909aa6;\r\n  margin: 10px;\r\n  padding: 8px;\r\n}\r\n\r\n.sales-deposit-modal-section-title {\r\n  color: #1b2f45;\r\n  font-size: 1.1rem;\r\n  font-weight: 700;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.sales-deposit-modal-deal-row {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.sales-deposit-modal-deal-row strong,\r\n.sales-deposit-modal-deal-row span {\r\n  color: #1d2f44;\r\n  font-size: 1rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.sales-deposit-modal-grid {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.sales-deposit-modal-grid label,\r\n.sales-deposit-modal-inline-action {\r\n  align-items: center;\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: 180px minmax(0, 1fr);\r\n}\r\n\r\n.sales-deposit-modal-grid label > span,\r\n.sales-deposit-modal-inline-action > span {\r\n  color: #23364a;\r\n  font-size: 0.9rem;\r\n  font-weight: 600;\r\n  text-align: right;\r\n}\r\n\r\n.sales-deposit-modal-input,\r\n.sales-deposit-modal-notes {\r\n  background: #f4f4f4;\r\n  border: 2px solid #9aabba;\r\n  color: #1f3148;\r\n  font-size: 0.95rem;\r\n  min-height: 36px;\r\n  padding: 2px 8px;\r\n}\r\n\r\n.sales-deposit-modal-input.is-amount {\r\n  background: #f2d3db;\r\n  font-weight: 700;\r\n  text-align: right;\r\n}\r\n\r\n.sales-deposit-modal-notes {\r\n  min-height: 180px;\r\n  resize: vertical;\r\n  width: 100%;\r\n}\r\n\r\n.sales-deposit-modal-actions {\r\n  background: linear-gradient(180deg, #1e5f83 0%, #0e3451 100%);\r\n  border-top: 1px solid #19384d;\r\n  display: flex;\r\n  gap: 10px;\r\n  justify-content: flex-end;\r\n  padding: 10px;\r\n}\r\n\r\n.sales-deposit-modal-primary,\r\n.sales-deposit-modal-secondary {\r\n  background: #e0e0e0;\r\n  border: 2px solid #637180;\r\n  color: #1d2f45;\r\n  font-size: 0.95rem;\r\n  font-weight: 700;\r\n  min-width: 110px;\r\n  padding: 4px 12px;\r\n}\r\n\r\n.sales-deposit-modal-error {\r\n  color: #932f3b;\r\n  font-size: 0.85rem;\r\n  font-weight: 700;\r\n  margin: 0 10px 10px;\r\n}\r\n\r\n.sales-deposit-reprint-modal {\r\n  width: min(980px, 100%);\r\n}\r\n\r\n.sales-deposit-reprint-toolbar {\r\n  align-items: center;\r\n  background: #d0dae5;\r\n  border-bottom: 1px solid #94a2b1;\r\n  color: #23364c;\r\n  display: flex;\r\n  font-size: 0.85rem;\r\n  justify-content: space-between;\r\n  padding: 6px 10px;\r\n}\r\n\r\n.sales-deposit-reprint-page {\r\n  background: #f7f7f7;\r\n  border: 1px solid #97a4b3;\r\n  color: #1f3247;\r\n  margin: 12px;\r\n  min-height: 430px;\r\n  padding: 16px;\r\n}\r\n\r\n.sales-deposit-reprint-page h5 {\r\n  font-size: 1.35rem;\r\n  margin: 0 0 10px;\r\n  text-align: center;\r\n}\r\n\r\n.sales-deposit-reprint-meta-grid {\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n}\r\n\r\n.sales-deposit-reprint-meta-grid span {\r\n  color: #5b6f84;\r\n  display: block;\r\n  font-size: 0.75rem;\r\n  margin-bottom: 2px;\r\n}\r\n\r\n.sales-deposit-reprint-meta-grid strong {\r\n  font-size: 0.92rem;\r\n}\r\n\r\n.sales-deposit-reprint-notes {\r\n  border-top: 1px solid #bbc6d1;\r\n  margin-top: 14px;\r\n  padding-top: 10px;\r\n}\r\n\r\n.sales-deposit-reprint-notes > span {\r\n  color: #445a70;\r\n  display: block;\r\n  font-size: 0.76rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.sales-deposit-reprint-notes > p {\r\n  color: #1f3348;\r\n  font-size: 0.88rem;\r\n  margin: 4px 0 10px;\r\n}\r\n\r\n/* Feature 1: Invoice tab */\r\n\r\n.legacy-invoice-layout { display: grid; gap: 16px; }\r\n\r\n.legacy-invoice-header { display: grid; gap: 8px; }\r\n\r\n.legacy-invoice-header-meta { align-items: center; display: flex; flex-wrap: wrap; gap: 12px; font-size: 0.85rem; }\r\n\r\n.legacy-invoice-actions { display: flex; flex-wrap: wrap; gap: 8px; }\r\n\r\n.legacy-invoice-job-block { border: 1px solid #dce7ed; border-radius: 8px; overflow: hidden; }\r\n\r\n.legacy-invoice-job-header { align-items: center; background: #eef5f9; display: flex; gap: 10px; justify-content: space-between; padding: 8px 12px; }\r\n\r\n.legacy-invoice-sub-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-invoice-sub-table th { background: #f5f9fb; color: #567185; font-size: 0.72rem; font-weight: 700; padding: 5px 8px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-invoice-sub-table td { border-top: 1px solid #edf1f4; padding: 5px 8px; }\r\n\r\n.legacy-invoice-sub-table .is-right { text-align: right; }\r\n\r\n.legacy-invoice-sub-total { background: #f5f9fb; font-size: 0.82rem; font-weight: 700; padding: 6px 12px; text-align: right; }\r\n\r\n.legacy-invoice-totals-grid { display: grid; gap: 4px; max-width: 340px; margin-left: auto; }\r\n\r\n.legacy-invoice-totals-row { align-items: center; display: flex; gap: 8px; justify-content: space-between; font-size: 0.85rem; padding: 3px 0; }\r\n\r\n.legacy-invoice-totals-row.is-total { border-top: 2px solid #dce7ed; font-size: 1rem; font-weight: 700; padding-top: 8px; margin-top: 4px; }\r\n\r\n.legacy-invoice-totals-row.is-due { color: #d43a2a; font-size: 1.05rem; font-weight: 800; }\r\n\r\n.legacy-invoice-misc-row { align-items: center; display: flex; gap: 8px; justify-content: space-between; padding: 4px 0; font-size: 0.85rem; }\r\n\r\n.legacy-invoice-deposit-row { align-items: center; display: flex; gap: 12px; padding: 5px 0; font-size: 0.82rem; border-top: 1px solid #edf1f4; }\r\n\r\n/* Feature 2: Parts PO Receiving */\r\n\r\n.legacy-parts-receive-panel { background: #fff; border: 1px solid #dce7ed; border-radius: 10px; display: grid; gap: 12px; padding: 16px; }\r\n\r\n.legacy-parts-receive-header { align-items: center; display: flex; gap: 10px; justify-content: space-between; }\r\n\r\n.legacy-parts-receive-table { border-collapse: collapse; width: 100%; font-size: 0.82rem; }\r\n\r\n.legacy-parts-receive-table th { background: #eef5f9; color: #567185; font-size: 0.72rem; font-weight: 700; padding: 6px 8px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-parts-receive-table td { border-top: 1px solid #edf1f4; padding: 5px 8px; vertical-align: middle; }\r\n\r\n.legacy-parts-receive-table input[type=\"number\"] { border: 1px solid #c8d8e1; border-radius: 5px; font-size: 0.82rem; padding: 3px 6px; width: 64px; }\r\n\r\n.legacy-parts-receive-actions { display: flex; gap: 8px; justify-content: flex-end; }\r\n\r\n/* Feature 3: Sales F&I Deal Stages */\r\n\r\n.legacy-deal-stage-bar { display: flex; gap: 0; margin-bottom: 12px; }\r\n\r\n.legacy-deal-stage { align-items: center; background: #eef5f9; border-right: 2px solid #fff; display: flex; flex: 1; flex-direction: column; gap: 2px; padding: 8px 6px; font-size: 0.72rem; text-align: center; }\r\n\r\n.legacy-deal-stage:first-child { border-radius: 8px 0 0 8px; }\r\n\r\n.legacy-deal-stage:last-child { border-radius: 0 8px 8px 0; border-right: none; }\r\n\r\n.legacy-deal-stage.is-active { background: #173446; color: #fff; font-weight: 700; }\r\n\r\n.legacy-deal-stage.is-complete { background: #2a7f62; color: #fff; }\r\n\r\n.legacy-deal-stage-dot { border-radius: 50%; height: 8px; width: 8px; background: currentColor; opacity: 0.5; margin: 0 auto 2px; }\r\n\r\n.legacy-deal-stage.is-active .legacy-deal-stage-dot, .legacy-deal-stage.is-complete .legacy-deal-stage-dot { opacity: 1; }\r\n\r\n.legacy-fi-panel { display: grid; gap: 12px; }\r\n\r\n.legacy-fi-grid { display: grid; gap: 10px; grid-template-columns: 1fr 1fr; }\r\n\r\n.legacy-fi-field { display: grid; gap: 4px; }\r\n\r\n.legacy-fi-field label { color: #567185; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; }\r\n\r\n.legacy-fi-field input, .legacy-fi-field select { border: 1px solid #c8d8e1; border-radius: 6px; font-size: 0.85rem; padding: 6px 8px; width: 100%; }\r\n\r\n.legacy-fi-payment-result { background: #eef7f3; border: 1px solid #b9ded0; border-radius: 8px; padding: 12px; text-align: center; }\r\n\r\n.legacy-fi-payment-result strong { display: block; font-size: 1.4rem; color: #173446; }\r\n\r\n.legacy-fi-payment-result span { font-size: 0.78rem; color: #567185; }\r\n\r\n/* Feature 4: Technician Workload View */\r\n\r\n.legacy-workload-board { display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); padding: 16px; }\r\n\r\n.legacy-workload-card { background: #fff; border: 1px solid #dce7ed; border-radius: 10px; display: grid; gap: 8px; padding: 12px; }\r\n\r\n.legacy-workload-card-header { align-items: center; display: flex; gap: 8px; justify-content: space-between; }\r\n\r\n.legacy-workload-bar-track { background: #eef5f9; border-radius: 4px; height: 6px; overflow: hidden; }\r\n\r\n.legacy-workload-bar-fill { background: #2a7f62; border-radius: 4px; height: 100%; transition: width 0.3s; }\r\n\r\n.legacy-workload-bar-fill.is-busy { background: #e6a817; }\r\n\r\n.legacy-workload-bar-fill.is-overloaded { background: #d43a2a; }\r\n\r\n.legacy-workload-meta { display: flex; gap: 8px; font-size: 0.75rem; color: #567185; }\r\n\r\n.technician-workload-page {\r\n  align-content: start;\r\n  background: #d5d7da;\r\n  border: 1px solid #7f8d99;\r\n  box-shadow: inset 0 1px 0 rgba(255,255,255,0.55);\r\n  display: grid;\r\n  min-height: 100%;\r\n}\r\n\r\n.technician-workload-shell {\r\n  align-content: start;\r\n  background: #d1d4d8;\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.technician-workload-panel,\r\n.technician-workload-preview-shell {\r\n  background: #e1e2e5;\r\n  border: 1px solid #8f98a1;\r\n  box-shadow: inset 0 1px 0 rgba(255,255,255,0.55);\r\n}\r\n\r\n.technician-workload-panel-heading strong {\r\n  color: #203440;\r\n  display: block;\r\n  font-size: 0.8rem;\r\n  line-height: 1.2;\r\n}\r\n\r\n.technician-workload-panel-heading span,\r\n.technician-workload-report-header span {\r\n  color: #5b6974;\r\n  display: block;\r\n  font-size: 0.67rem;\r\n}\r\n\r\n.technician-workload-top-grid {\r\n  align-items: start;\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: minmax(320px, 0.9fr) minmax(500px, 1.1fr);\r\n}\r\n\r\n.technician-workload-panel {\r\n  min-height: 0;\r\n  padding: 8px;\r\n}\r\n\r\n.technician-workload-panel-heading {\r\n  align-items: start;\r\n  display: flex;\r\n  gap: 8px;\r\n  justify-content: space-between;\r\n  margin-bottom: 6px;\r\n}\r\n\r\n.technician-workload-radio-row,\r\n.technician-workload-technician-toolbar {\r\n  align-items: center;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px 12px;\r\n}\r\n\r\n.technician-workload-filter-grid {\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.technician-workload-field {\r\n  display: grid;\r\n  gap: 2px;\r\n}\r\n\r\n.technician-workload-date-field {\r\n  position: relative;\r\n}\r\n\r\n.technician-workload-choice-block {\r\n  display: grid;\r\n  gap: 4px;\r\n}\r\n\r\n.technician-workload-choice-block > span,\r\n.technician-workload-field span,\r\n.technician-workload-preview-toolbar span {\r\n  color: #30424f;\r\n  font-size: 0.68rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.technician-workload-field input,\r\n.technician-workload-preview-toolbar select {\r\n  background: #fff;\r\n  border: 1px solid #9099a0;\r\n  color: #22323d;\r\n  font-size: 0.73rem;\r\n  min-height: 22px;\r\n  padding: 2px 5px;\r\n}\r\n\r\n.technician-workload-hidden-date-input {\r\n  height: 1px;\r\n  left: 0;\r\n  opacity: 0;\r\n  pointer-events: none;\r\n  position: absolute;\r\n  top: 0;\r\n  width: 1px;\r\n}\r\n\r\n.technician-workload-date-trigger {\r\n  align-items: center;\r\n  appearance: none;\r\n  background: linear-gradient(180deg, #ffffff 0%, #e2e7eb 100%);\r\n  border: 1px solid #9099a0;\r\n  color: #22323d;\r\n  cursor: pointer;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  min-height: 24px;\r\n  padding: 3px 6px;\r\n  text-align: left;\r\n}\r\n\r\n.technician-workload-date-trigger strong {\r\n  font-size: 0.73rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.technician-workload-date-trigger span {\r\n  color: #5d6d78;\r\n  font-size: 0.64rem;\r\n  font-weight: 700;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.technician-workload-date-trigger:focus-visible {\r\n  outline: 1px solid #2c6f95;\r\n  outline-offset: 1px;\r\n}\r\n\r\n.technician-workload-radio-row label,\r\n.technician-workload-technician-toolbar label {\r\n  align-items: center;\r\n  color: #22323d;\r\n  display: inline-flex;\r\n  font-size: 0.72rem;\r\n  gap: 4px;\r\n}\r\n\r\n.technician-workload-panel-footer {\r\n  border-top: 1px solid #c6cdd4;\r\n  color: #5d6872;\r\n  font-size: 0.68rem;\r\n  margin-top: 8px;\r\n  padding-top: 6px;\r\n}\r\n\r\n.technician-workload-load-state {\r\n  background: #eef3f6;\r\n  border: 1px solid #c8d1d8;\r\n  color: #445864;\r\n  font-size: 0.68rem;\r\n  margin-top: 6px;\r\n  padding: 5px 6px;\r\n}\r\n\r\n.technician-workload-load-state.is-error {\r\n  background: #fff1ec;\r\n  border-color: #dba18f;\r\n  color: #8a3b24;\r\n}\r\n\r\n.technician-workload-technician-panel {\r\n  display: grid;\r\n  gap: 6px;\r\n}\r\n\r\n.technician-workload-technician-toolbar {\r\n  justify-content: flex-end;\r\n}\r\n\r\n.technician-workload-technician-table {\r\n  background: #fff;\r\n  border-collapse: collapse;\r\n  font-size: 0.7rem;\r\n  width: 100%;\r\n}\r\n\r\n.technician-workload-technician-table th,\r\n.technician-workload-technician-table td {\r\n  border: 1px solid #a5afb8;\r\n  padding: 3px 4px;\r\n}\r\n\r\n.technician-workload-technician-table th {\r\n  background: linear-gradient(180deg, #0d3750 0%, #1d4f6d 100%);\r\n  color: #fff;\r\n  font-size: 0.66rem;\r\n  text-align: left;\r\n}\r\n\r\n.technician-workload-technician-table th:nth-child(1),\r\n.technician-workload-technician-table td:nth-child(1),\r\n.technician-workload-technician-table th:nth-child(3),\r\n.technician-workload-technician-table td:nth-child(3),\r\n.technician-workload-technician-table th:nth-child(4),\r\n.technician-workload-technician-table td:nth-child(4),\r\n.technician-workload-technician-table th:nth-child(5),\r\n.technician-workload-technician-table td:nth-child(5) {\r\n  text-align: center;\r\n}\r\n\r\n.technician-workload-status-dot {\r\n  background: #667785;\r\n  border-radius: 999px;\r\n  display: inline-block;\r\n  height: 8px;\r\n  width: 8px;\r\n}\r\n\r\n.technician-workload-status-dot.is-active {\r\n  background: #0f2e43;\r\n}\r\n\r\n.technician-workload-preview-shell {\r\n  align-self: start;\r\n  display: grid;\r\n  grid-template-rows: auto 1fr;\r\n  min-height: 300px;\r\n}\r\n\r\n.technician-workload-preview-toolbar {\r\n  align-items: center;\r\n  background: #efefef;\r\n  border-bottom: 1px solid #a3abb2;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 5px;\r\n  padding: 4px 5px;\r\n}\r\n\r\n.technician-workload-preview-badge {\r\n  background: linear-gradient(180deg, #fefefe 0%, #dce2e6 100%);\r\n  border: 1px solid #93a0aa;\r\n  color: #234053;\r\n  font-size: 0.64rem;\r\n  font-weight: 800;\r\n  letter-spacing: 0.04em;\r\n  padding: 3px 8px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.technician-workload-preview-toolbar label {\r\n  align-items: center;\r\n  display: inline-flex;\r\n  gap: 5px;\r\n}\r\n\r\n.technician-workload-printer-select {\r\n  min-width: 220px;\r\n}\r\n\r\n.technician-workload-printer-select select {\r\n  min-width: 180px;\r\n}\r\n\r\n.technician-workload-toolbar-icons {\r\n  display: inline-flex;\r\n  gap: 4px;\r\n}\r\n\r\n.technician-workload-toolbar-icons button,\r\n.technician-workload-print-button,\r\n.technician-workload-generate-button {\r\n  background: linear-gradient(180deg, #fafafa 0%, #d9dde1 100%);\r\n  border: 1px solid #8e99a1;\r\n  color: #22323d;\r\n  cursor: pointer;\r\n  font-size: 0.68rem;\r\n  min-height: 22px;\r\n  padding: 2px 7px;\r\n}\r\n\r\n.technician-workload-print-button {\r\n  font-weight: 700;\r\n}\r\n\r\n.technician-workload-generate-button {\r\n  margin-left: auto;\r\n}\r\n\r\n.technician-workload-preview-canvas {\r\n  background: #f5f5f5;\r\n  min-height: 240px;\r\n  padding: 6px;\r\n}\r\n\r\n.technician-workload-report-sheet {\r\n  background: #fff;\r\n  border: 1px solid #b1b7bc;\r\n  box-shadow: inset 0 1px 0 rgba(255,255,255,0.7);\r\n  display: grid;\r\n  gap: 6px;\r\n  min-height: 0;\r\n  padding: 8px 10px;\r\n}\r\n\r\n.technician-workload-report-kicker {\r\n  color: #60717c;\r\n  display: flex;\r\n  font-size: 0.62rem;\r\n  font-weight: 800;\r\n  gap: 10px;\r\n  letter-spacing: 0.05em;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.technician-workload-report-header {\r\n  align-items: flex-start;\r\n  border-bottom: 1px solid #d6dde2;\r\n  color: #566672;\r\n  display: flex;\r\n  font-size: 0.68rem;\r\n  gap: 8px;\r\n  justify-content: space-between;\r\n  padding-bottom: 6px;\r\n}\r\n\r\n.technician-workload-report-header strong {\r\n  color: #152a39;\r\n  display: block;\r\n  font-size: 0.88rem;\r\n  margin-bottom: 2px;\r\n}\r\n\r\n.technician-workload-report-eyebrow {\r\n  color: #486171;\r\n  font-size: 0.63rem;\r\n  font-weight: 800;\r\n  letter-spacing: 0.04em;\r\n  margin-bottom: 1px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.technician-workload-report-header span {\r\n  display: block;\r\n}\r\n\r\n.technician-workload-report-issued {\r\n  display: grid;\r\n  gap: 1px;\r\n  justify-items: end;\r\n  text-align: right;\r\n}\r\n\r\n.technician-workload-report-issued strong {\r\n  color: #1a3342;\r\n  font-size: 0.76rem;\r\n  margin: 0;\r\n}\r\n\r\n.technician-workload-report-meta-strip {\r\n  background: #f2f5f7;\r\n  border: 1px solid #d6dde2;\r\n  color: #496070;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  font-size: 0.64rem;\r\n  font-weight: 700;\r\n  gap: 6px 14px;\r\n  padding: 4px 6px;\r\n}\r\n\r\n.technician-workload-summary-strip {\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n}\r\n\r\n.technician-workload-summary-strip div {\r\n  background: #f1f4f6;\r\n  border: 1px solid #d6dde2;\r\n  display: grid;\r\n  gap: 2px;\r\n  padding: 6px 7px;\r\n}\r\n\r\n.technician-workload-summary-strip span {\r\n  color: #566672;\r\n  font-size: 0.67rem;\r\n}\r\n\r\n.technician-workload-summary-strip strong {\r\n  color: #152a39;\r\n  font-size: 1rem;\r\n}\r\n\r\n.technician-workload-report-table {\r\n  border-collapse: collapse;\r\n  font-size: 0.7rem;\r\n  width: 100%;\r\n}\r\n\r\n.technician-workload-report-table th,\r\n.technician-workload-report-table td {\r\n  border: 1px solid #cfd6db;\r\n  padding: 3px 4px;\r\n  vertical-align: middle;\r\n}\r\n\r\n.technician-workload-empty-row {\r\n  color: #60707d;\r\n  font-size: 0.68rem;\r\n  font-style: italic;\r\n  padding: 10px 8px;\r\n  text-align: center;\r\n}\r\n\r\n.technician-workload-empty-row.is-report {\r\n  padding: 12px 8px;\r\n}\r\n\r\n.technician-workload-report-table th {\r\n  background: #eef3f6;\r\n  color: #355063;\r\n  font-size: 0.65rem;\r\n  text-align: left;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.technician-workload-report-table th:nth-child(2),\r\n.technician-workload-report-table td:nth-child(2),\r\n.technician-workload-report-table th:nth-child(3),\r\n.technician-workload-report-table td:nth-child(3),\r\n.technician-workload-report-table th:nth-child(4),\r\n.technician-workload-report-table td:nth-child(4),\r\n.technician-workload-report-table th:nth-child(6),\r\n.technician-workload-report-table td:nth-child(6) {\r\n  text-align: center;\r\n}\r\n\r\n.technician-workload-detail-stack {\r\n  display: grid;\r\n  gap: 10px;\r\n}\r\n\r\n.technician-workload-detail-empty,\r\n.technician-workload-detail-no-sessions {\r\n  background: #f3f6f8;\r\n  border: 1px solid #d6dde2;\r\n  color: #5d6f7c;\r\n  font-size: 0.68rem;\r\n  padding: 8px;\r\n}\r\n\r\n.technician-workload-detail-section {\r\n  border: 1px solid #d6dde2;\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.technician-workload-detail-header {\r\n  align-items: start;\r\n  display: flex;\r\n  gap: 8px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.technician-workload-detail-header strong,\r\n.technician-workload-detail-job-row strong,\r\n.technician-workload-detail-session-group-header strong {\r\n  color: #173040;\r\n  display: block;\r\n}\r\n\r\n.technician-workload-detail-header span,\r\n.technician-workload-detail-job-row span,\r\n.technician-workload-detail-session-group-header span,\r\n.technician-workload-detail-summary span {\r\n  color: #5b6f7b;\r\n  display: block;\r\n  font-size: 0.66rem;\r\n}\r\n\r\n.technician-workload-detail-summary {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 10px;\r\n  justify-content: flex-end;\r\n  text-align: right;\r\n}\r\n\r\n.technician-workload-detail-job-table,\r\n.technician-workload-detail-session-table {\r\n  border-collapse: collapse;\r\n  font-size: 0.69rem;\r\n  width: 100%;\r\n}\r\n\r\n.technician-workload-detail-job-table th,\r\n.technician-workload-detail-job-table td,\r\n.technician-workload-detail-session-table th,\r\n.technician-workload-detail-session-table td {\r\n  border: 1px solid #d0d7dc;\r\n  padding: 4px 5px;\r\n  vertical-align: top;\r\n}\r\n\r\n.technician-workload-detail-job-table th,\r\n.technician-workload-detail-session-table th {\r\n  background: #eef3f6;\r\n  color: #375266;\r\n  font-size: 0.64rem;\r\n  text-align: left;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.technician-workload-detail-job-table td:nth-child(4),\r\n.technician-workload-detail-job-table td:nth-child(5),\r\n.technician-workload-detail-job-table td:nth-child(6),\r\n.technician-workload-detail-job-table td:nth-child(7),\r\n.technician-workload-detail-session-table td:nth-child(3),\r\n.technician-workload-detail-session-table td:nth-child(4),\r\n.technician-workload-detail-session-table td:nth-child(5) {\r\n  text-align: center;\r\n}\r\n\r\n.technician-workload-detail-session-stack {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.technician-workload-detail-session-group {\r\n  display: grid;\r\n  gap: 5px;\r\n}\r\n\r\n.technician-workload-detail-session-group-header {\r\n  align-items: baseline;\r\n  display: flex;\r\n  gap: 8px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.technician-workload-report-utilization-cell {\r\n  align-items: center;\r\n  display: grid;\r\n  gap: 4px;\r\n}\r\n\r\n.technician-workload-report-utilization-cell span {\r\n  color: #415563;\r\n  font-size: 0.69rem;\r\n}\r\n\r\n.technician-workload-report-bar-track {\r\n  background: #e7edf1;\r\n  border: 1px solid #d4dbe0;\r\n  height: 8px;\r\n  overflow: hidden;\r\n}\r\n\r\n.technician-workload-report-bar-fill {\r\n  background: #2c6f95;\r\n  height: 100%;\r\n}\r\n\r\n.technician-workload-report-bar-fill.is-busy {\r\n  background: #c98b16;\r\n}\r\n\r\n.technician-workload-report-bar-fill.is-overloaded {\r\n  background: #ba4723;\r\n}\r\n\r\n.technician-workload-report-footer {\r\n  border-top: 1px solid #d6dde2;\r\n  color: #5c6c77;\r\n  display: flex;\r\n  font-size: 0.66rem;\r\n  gap: 12px;\r\n  justify-content: flex-end;\r\n  padding-top: 5px;\r\n}\r\n\r\n@media (max-width: 1100px) {\r\n  .technician-workload-top-grid {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .technician-workload-report-header {\r\n    display: grid;\r\n    justify-content: flex-start;\r\n  }\r\n\r\n  .technician-workload-summary-strip {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n\r\n  .technician-workload-report-issued {\r\n    justify-items: start;\r\n    text-align: left;\r\n  }\r\n}\r\n\r\n@media (max-width: 720px) {\r\n  .technician-workload-shell {\r\n    padding: 6px;\r\n  }\r\n\r\n  .technician-workload-filter-grid,\r\n  .technician-workload-summary-strip {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .technician-workload-preview-toolbar {\r\n    align-items: stretch;\r\n    flex-direction: column;\r\n  }\r\n\r\n  .technician-workload-technician-toolbar,\r\n  .technician-workload-report-footer {\r\n    align-items: flex-start;\r\n    flex-direction: column;\r\n  }\r\n\r\n  .technician-workload-report-meta-strip {\r\n    flex-direction: column;\r\n    gap: 4px;\r\n  }\r\n\r\n  .technician-workload-detail-header,\r\n  .technician-workload-detail-summary,\r\n  .technician-workload-detail-session-group-header {\r\n    display: grid;\r\n    justify-content: flex-start;\r\n    text-align: left;\r\n  }\r\n\r\n  .technician-workload-generate-button {\r\n    margin-left: 0;\r\n  }\r\n\r\n  .technician-workload-printer-select,\r\n  .technician-workload-printer-select select {\r\n    min-width: 0;\r\n    width: 100%;\r\n  }\r\n}\r\n\r\n@media print {\r\n  @page {\r\n    margin: 0.45in;\r\n    size: landscape;\r\n  }\r\n\r\n  .technician-workload-page,\r\n  .technician-workload-shell,\r\n  .technician-workload-preview-shell,\r\n  .technician-workload-preview-canvas,\r\n  .technician-workload-report-sheet {\r\n    background: #fff;\r\n    border: none;\r\n    box-shadow: none;\r\n  }\r\n\r\n  .technician-workload-shell {\r\n    padding: 0;\r\n  }\r\n\r\n  .technician-workload-top-grid,\r\n  .technician-workload-preview-toolbar {\r\n    display: none;\r\n  }\r\n\r\n  .technician-workload-preview-canvas,\r\n  .technician-workload-report-sheet {\r\n    padding: 0;\r\n  }\r\n\r\n  .technician-workload-report-table th,\r\n  .technician-workload-report-table td {\r\n    font-size: 9pt;\r\n    padding: 4px 6px;\r\n  }\r\n\r\n  .technician-workload-detail-section {\r\n    break-inside: avoid;\r\n    page-break-inside: avoid;\r\n    padding: 0;\r\n  }\r\n\r\n  .technician-workload-detail-job-table th,\r\n  .technician-workload-detail-job-table td,\r\n  .technician-workload-detail-session-table th,\r\n  .technician-workload-detail-session-table td {\r\n    font-size: 8.5pt;\r\n  }\r\n}\r\n\r\n/* Feature 5: Unit History */\r\n\r\n.legacy-unit-history { border: 1px solid #dce7ed; border-radius: 8px; overflow: hidden; margin-top: 12px; }\r\n\r\n.legacy-unit-history-header { align-items: center; background: #eef5f9; display: flex; gap: 8px; justify-content: space-between; padding: 8px 12px; font-size: 0.8rem; font-weight: 700; }\r\n\r\n.legacy-unit-history-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-unit-history-table th { background: #f5f9fb; color: #567185; font-size: 0.72rem; font-weight: 700; padding: 5px 8px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-unit-history-table td { border-top: 1px solid #edf1f4; padding: 5px 8px; }\r\n\r\n.legacy-unit-history-table .is-view-btn { background: none; border: none; color: #2a6f9e; cursor: pointer; font-size: 0.78rem; text-decoration: underline; }\r\n\r\n/* Feature 7: Schema Mapping */\r\n\r\n.legacy-schema-mapping { display: grid; gap: 12px; }\r\n\r\n.legacy-schema-mapping-table { border-collapse: collapse; font-size: 0.82rem; width: 100%; }\r\n\r\n.legacy-schema-mapping-table th { background: #eef5f9; color: #567185; font-size: 0.72rem; font-weight: 700; padding: 6px 10px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-schema-mapping-table td { border-top: 1px solid #edf1f4; padding: 6px 10px; vertical-align: middle; }\r\n\r\n.legacy-schema-mapping-arrow { color: #8faab8; font-weight: 700; text-align: center; }\r\n\r\n.legacy-schema-mapping-table select { border: 1px solid #c8d8e1; border-radius: 5px; font-size: 0.8rem; padding: 3px 6px; }\r\n\r\n.legacy-schema-mapping-table input[type=\"text\"] { border: 1px solid #c8d8e1; border-radius: 5px; font-size: 0.8rem; padding: 3px 6px; width: 140px; }\r\n\r\n/* Sprint Features CSS */\r\n\r\n/* Feature 1: RO Status Gating */\r\n\r\n.legacy-invoice-gate-warning { background: #fff8e1; border: 1px solid #f59e0b; border-radius: 6px; margin-bottom: 10px; padding: 10px 14px; }\r\n\r\n.legacy-invoice-gate-warning-title { align-items: center; color: #b45309; display: flex; font-weight: 600; gap: 6px; margin-bottom: 6px; }\r\n\r\n.legacy-invoice-gate-job-row { align-items: center; border-top: 1px solid #fde68a; display: flex; gap: 10px; justify-content: space-between; padding: 4px 0; }\r\n\r\n.legacy-invoice-gate-job-row span { color: #78350f; font-size: 0.85rem; }\r\n\r\n/* Feature 2: eSignature Workflow */\r\n\r\n.legacy-esig-layout { display: flex; flex-direction: column; gap: 12px; }\r\n\r\n.legacy-esig-auth-card { background: #f8fafc; border: 1px solid #d4e1e9; border-radius: 8px; padding: 12px 14px; }\r\n\r\n.legacy-esig-auth-header { align-items: center; display: flex; gap: 10px; margin-bottom: 6px; }\r\n\r\n.legacy-esig-auth-meta { color: #567185; display: flex; flex-wrap: wrap; font-size: 0.8rem; gap: 12px; margin-bottom: 8px; }\r\n\r\n.legacy-esig-doc-table { border-collapse: collapse; font-size: 0.82rem; width: 100%; }\r\n\r\n.legacy-esig-doc-table th { background: #eef5f9; color: #567185; font-size: 0.72rem; font-weight: 700; padding: 6px 10px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-esig-doc-table td { border-top: 1px solid #edf1f4; padding: 6px 10px; vertical-align: middle; }\r\n\r\n.legacy-esig-request-form { background: #f8fafc; border: 1px solid #d4e1e9; border-radius: 8px; display: flex; flex-direction: column; gap: 10px; padding: 14px; }\r\n\r\n.legacy-esig-request-form label { display: flex; flex-direction: column; font-size: 0.82rem; gap: 4px; }\r\n\r\n.legacy-esig-request-form select, .legacy-esig-request-form input, .legacy-esig-request-form textarea { border: 1px solid #c8d8e1; border-radius: 5px; font-size: 0.85rem; padding: 5px 8px; }\r\n\r\n.legacy-esig-request-form textarea { min-height: 60px; resize: vertical; }\r\n\r\n.legacy-esig-request-actions { display: flex; gap: 8px; }\r\n\r\n/* Feature 3: Sales Deal Stage Gating */\r\n\r\n.legacy-deal-stage-block { background: #fff3cd; border: 1px solid #ffc107; border-radius: 5px; color: #856404; font-size: 0.84rem; margin: 4px 0 8px; padding: 7px 12px; }\r\n\r\n/* Feature 4: Notifications Bell */\r\n\r\n.legacy-notif-bell-wrap { position: relative; }\r\n\r\n.legacy-notif-bell { background: none; border: none; cursor: pointer; font-size: 1.2rem; padding: 4px 8px; position: relative; }\r\n\r\n.legacy-notif-badge { background: #e53e3e; border-radius: 8px; color: #fff; font-size: 0.65rem; font-weight: 700; min-width: 16px; padding: 1px 4px; position: absolute; right: 2px; text-align: center; top: 2px; }\r\n\r\n.legacy-notif-panel { background: #fff; border: 1px solid #d4e1e9; border-radius: 8px; box-shadow: 0 4px 16px rgba(0,0,0,.12); min-width: 300px; position: absolute; right: 0; top: 36px; z-index: 200; }\r\n\r\n.legacy-notif-panel-header { align-items: center; border-bottom: 1px solid #edf1f4; display: flex; justify-content: space-between; padding: 10px 14px; }\r\n\r\n.legacy-notif-panel-header button { background: none; border: none; color: #2a6f9e; cursor: pointer; font-size: 0.8rem; }\r\n\r\n.legacy-notif-item { background: none; border: none; border-bottom: 1px solid #f0f4f7; cursor: pointer; display: flex; gap: 10px; justify-content: space-between; padding: 10px 14px; text-align: left; width: 100%; }\r\n\r\n.legacy-notif-item:hover { background: #f8fafc; }\r\n\r\n.legacy-notif-item.is-read { opacity: 0.5; }\r\n\r\n.legacy-notif-item-body { display: flex; flex-direction: column; gap: 2px; }\r\n\r\n.legacy-notif-item-body strong { font-size: 0.84rem; }\r\n\r\n.legacy-notif-item-body span { color: #567185; font-size: 0.78rem; }\r\n\r\n.legacy-notif-item-time { color: #8faab8; font-size: 0.75rem; white-space: nowrap; }\r\n\r\n.legacy-notif-empty { color: #8faab8; font-size: 0.82rem; padding: 14px; text-align: center; }\r\n\r\n/* Feature 5: Parts Reorder Alerts */\r\n\r\n.legacy-parts-reorder-banner { align-items: center; background: #fff8e1; border: 1px solid #f59e0b; border-radius: 6px; display: flex; justify-content: space-between; margin: 8px 12px; padding: 8px 14px; }\r\n\r\n.legacy-parts-reorder-banner-text { color: #b45309; font-size: 0.84rem; font-weight: 600; }\r\n\r\n.legacy-parts-reorder-banner-actions { display: flex; gap: 8px; }\r\n\r\n/* Feature 6: Communications Tab */\r\n\r\n.legacy-comms-layout { display: flex; flex-direction: column; gap: 12px; }\r\n\r\n.legacy-comms-compose { background: #f8fafc; border: 1px solid #d4e1e9; border-radius: 8px; display: flex; flex-direction: column; gap: 10px; padding: 14px; }\r\n\r\n.legacy-comms-compose label { display: flex; flex-direction: column; font-size: 0.82rem; gap: 4px; }\r\n\r\n.legacy-comms-compose input, .legacy-comms-compose select, .legacy-comms-compose textarea { border: 1px solid #c8d8e1; border-radius: 5px; font-size: 0.85rem; padding: 5px 8px; }\r\n\r\n.legacy-comms-compose textarea { min-height: 60px; resize: vertical; }\r\n\r\n.legacy-comms-compose-actions { display: flex; gap: 8px; }\r\n\r\n.legacy-comms-thread { display: flex; flex-direction: column; gap: 8px; }\r\n\r\n.legacy-comms-message { border-radius: 8px; max-width: 85%; padding: 10px 14px; }\r\n\r\n.legacy-comms-message.is-out { align-self: flex-end; background: #e8f4fd; }\r\n\r\n.legacy-comms-message.is-in { align-self: flex-start; background: #f0f4f7; }\r\n\r\n.legacy-comms-message-meta { align-items: center; display: flex; font-size: 0.75rem; gap: 8px; margin-bottom: 4px; opacity: 0.7; }\r\n\r\n.legacy-comms-message-body { font-size: 0.85rem; }\r\n\r\n/* Feature 8: Cross-Store Reporting */\r\n\r\n.legacy-cross-store-summary { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 12px; }\r\n\r\n.legacy-cross-store-card { background: #f8fafc; border: 1px solid #d4e1e9; border-radius: 8px; display: flex; flex-direction: column; gap: 3px; min-width: 140px; padding: 12px 16px; }\r\n\r\n.legacy-cross-store-card span { color: #567185; font-size: 0.78rem; }\r\n\r\n.legacy-cross-store-card strong { color: #1a3a4a; font-size: 1.1rem; }\r\n\r\n.legacy-cross-store-card.is-total { background: #eef5f9; border-color: #b0ccd9; }\r\n\r\n/* ─── Feature 1: Payment Panel ─────────────────────────────────────── */\r\n\r\n.legacy-payment-panel { background: #f5f9fb; border: 1px solid #dce7ed; border-radius: 8px; display: grid; gap: 10px; margin-top: 12px; padding: 14px; }\r\n\r\n.legacy-payment-panel-header { align-items: center; display: flex; font-weight: 700; font-size: 0.85rem; gap: 8px; justify-content: space-between; }\r\n\r\n.legacy-payment-row { align-items: center; display: flex; gap: 10px; }\r\n\r\n.legacy-payment-row label { color: #567185; font-size: 0.78rem; font-weight: 600; min-width: 80px; }\r\n\r\n.legacy-payment-row input { border: 1px solid #c8d8e1; border-radius: 6px; font-size: 0.85rem; padding: 5px 8px; width: 160px; }\r\n\r\n.legacy-payment-actions { display: flex; gap: 8px; justify-content: flex-end; }\r\n\r\n/* ─── Feature 2: PO Create Panel ────────────────────────────────────── */\r\n\r\n.legacy-po-create-panel { background: #f5f9fb; border: 1px solid #dce7ed; border-radius: 10px; display: grid; gap: 12px; padding: 16px; }\r\n\r\n.legacy-po-create-header { align-items: center; display: flex; font-weight: 700; gap: 8px; justify-content: space-between; }\r\n\r\n.legacy-po-create-fields { display: grid; gap: 8px; grid-template-columns: 1fr 1fr; }\r\n\r\n.legacy-po-create-field { display: grid; gap: 3px; font-size: 0.8rem; font-weight: 600; }\r\n\r\n.legacy-po-create-field input, .legacy-po-create-field textarea { border: 1px solid #c8d8e1; border-radius: 6px; font-size: 0.85rem; padding: 5px 8px; width: 100%; }\r\n\r\n.legacy-po-create-field textarea { min-height: 50px; resize: vertical; }\r\n\r\n.legacy-po-lines-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-po-lines-table th { background: #eef5f9; color: #567185; font-size: 0.72rem; font-weight: 700; padding: 5px 8px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-po-lines-table td { border-top: 1px solid #edf1f4; padding: 4px 6px; }\r\n\r\n.legacy-po-lines-table input { border: 1px solid #c8d8e1; border-radius: 4px; font-size: 0.8rem; padding: 3px 5px; width: 100%; }\r\n\r\n.legacy-po-total-row { font-size: 0.85rem; font-weight: 700; padding: 6px 0; text-align: right; }\r\n\r\n.legacy-po-actions { display: flex; gap: 8px; justify-content: flex-end; }\r\n\r\n/* ─── Feature 3: Warranty Stepper ───────────────────────────────────── */\r\n\r\n.legacy-warranty-stepper { display: flex; gap: 0; margin-bottom: 14px; }\r\n\r\n.legacy-warranty-step { align-items: center; background: #eef5f9; border-right: 2px solid #fff; display: flex; flex: 1; flex-direction: column; font-size: 0.7rem; gap: 2px; padding: 7px 6px; text-align: center; }\r\n\r\n.legacy-warranty-step:first-child { border-radius: 7px 0 0 7px; }\r\n\r\n.legacy-warranty-step:last-child { border-radius: 0 7px 7px 0; border-right: none; }\r\n\r\n.legacy-warranty-step.is-complete { background: #2a7f62; color: #fff; }\r\n\r\n.legacy-warranty-step.is-active { background: #173446; color: #fff; font-weight: 700; }\r\n\r\n.legacy-warranty-step-dot { border-radius: 50%; height: 6px; margin: 0 auto 2px; opacity: 0.4; width: 6px; background: currentColor; }\r\n\r\n.legacy-warranty-step.is-active .legacy-warranty-step-dot, .legacy-warranty-step.is-complete .legacy-warranty-step-dot { opacity: 1; }\r\n\r\n/* ─── Feature 4: Global Search ──────────────────────────────────────── */\r\n\r\n.legacy-global-search-wrap { position: relative; }\r\n\r\n.legacy-global-search-input { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 20px; color: inherit; font-size: 0.82rem; outline: none; padding: 5px 14px; width: 220px; }\r\n\r\n.legacy-global-search-input::placeholder { color: rgba(255,255,255,0.4); }\r\n\r\n.legacy-global-search-input:focus { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.3); }\r\n\r\n.legacy-global-search-results { background: #0f2535; border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; box-shadow: 0 8px 32px rgba(0,0,0,0.4); display: grid; gap: 0; left: 0; min-width: 280px; position: absolute; top: calc(100% + 6px); z-index: 300; }\r\n\r\n.legacy-global-search-group { padding: 8px 0; }\r\n\r\n.legacy-global-search-group-label { color: rgba(255,255,255,0.4); display: block; font-size: 0.68rem; font-weight: 700; padding: 2px 12px 4px; text-transform: uppercase; }\r\n\r\n.legacy-global-search-item { align-items: baseline; background: none; border: none; cursor: pointer; display: flex; gap: 8px; padding: 6px 12px; text-align: left; width: 100%; }\r\n\r\n.legacy-global-search-item:hover { background: rgba(255,255,255,0.07); }\r\n\r\n.legacy-global-search-item strong { color: #f3f6fa; font-size: 0.82rem; }\r\n\r\n.legacy-global-search-item span { color: rgba(255,255,255,0.5); font-size: 0.75rem; }\r\n\r\n/* ─── Feature 5: Customer Profile Panel ─────────────────────────────── */\r\n\r\n.legacy-customer-profile-overlay { background: rgba(0,0,0,0.3); bottom: 0; left: 0; position: fixed; right: 0; top: 0; z-index: 400; }\r\n\r\n.legacy-customer-profile-panel { background: #0f2535; border-left: 1px solid rgba(255,255,255,0.1); bottom: 0; box-shadow: -8px 0 40px rgba(0,0,0,0.4); display: grid; grid-template-rows: auto 1fr; overflow: hidden; position: fixed; right: 0; top: 0; width: 400px; z-index: 401; }\r\n\r\n.legacy-customer-profile-header { border-bottom: 1px solid rgba(255,255,255,0.1); display: grid; gap: 8px; padding: 16px; }\r\n\r\n.legacy-customer-profile-tabs { display: flex; gap: 0; }\r\n\r\n.legacy-customer-profile-tab { background: none; border: none; border-bottom: 2px solid transparent; color: rgba(255,255,255,0.5); cursor: pointer; font-size: 0.8rem; padding: 8px 14px; }\r\n\r\n.legacy-customer-profile-tab.is-active { border-bottom-color: #ff7448; color: #fff; font-weight: 600; }\r\n\r\n.legacy-customer-profile-body { overflow-y: auto; padding: 14px; }\r\n\r\n.legacy-customer-profile-meta { color: rgba(255,255,255,0.55); font-size: 0.8rem; display: grid; gap: 4px; }\r\n\r\n/* ─── Feature 6: Schedule Grid ──────────────────────────────────────── */\r\n\r\n.legacy-schedule-grid { display: grid; gap: 8px; grid-template-columns: repeat(5, 1fr); padding: 12px; }\r\n\r\n.legacy-schedule-day { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; display: grid; gap: 6px; min-height: 120px; padding: 8px; }\r\n\r\n.legacy-schedule-day-header { color: rgba(255,255,255,0.5); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; }\r\n\r\n.legacy-schedule-day-header.is-today { color: #ff7448; }\r\n\r\n.legacy-schedule-ro-chip { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1); border-radius: 5px; cursor: pointer; display: grid; gap: 2px; padding: 5px 7px; text-align: left; width: 100%; }\r\n\r\n.legacy-schedule-ro-chip:hover { background: rgba(255,255,255,0.12); }\r\n\r\n.legacy-schedule-ro-chip strong { color: #f3f6fa; font-size: 0.75rem; }\r\n\r\n.legacy-schedule-ro-chip span { color: rgba(255,255,255,0.5); font-size: 0.68rem; }\r\n\r\n/* ─── Feature 8: Dark Mode Toggle ───────────────────────────────────── */\r\n\r\n.legacy-theme-toggle { background: none; border: none; cursor: pointer; font-size: 1rem; opacity: 0.7; padding: 4px 6px; }\r\n\r\n.legacy-theme-toggle:hover { opacity: 1; }\r\n\r\n[data-theme=\"light\"] {\r\n  --bg: #f0f4f8;\r\n  --bg-soft: #e6ecf2;\r\n  --panel: rgba(255, 255, 255, 0.92);\r\n  --panel-strong: rgba(255, 255, 255, 0.98);\r\n  --line: rgba(0, 0, 0, 0.1);\r\n  --text: #0d1f2d;\r\n  --muted: #4a6070;\r\n  --accent: #e55a2b;\r\n  --accent-soft: #f08060;\r\n  --stable: #1f7a52;\r\n  --attention: #b07a10;\r\n  --shadow: 0 8px 40px rgba(0, 0, 0, 0.12);\r\n}\r\n\r\n[data-theme=\"light\"] body {\r\n  background: linear-gradient(135deg, #dce8f2 0%, #edf3f8 50%, #e0eaf5 100%) !important;\r\n}\r\n\r\n[data-theme=\"light\"] .legacy-info-card {\r\n  background: rgba(255,255,255,0.9);\r\n  border-color: rgba(0,0,0,0.1);\r\n}\r\n\r\n/* ─── Feature 7: Print CSS ──────────────────────────────────────────── */\r\n\r\n@media print {\r\n  .legacy-workspace-nav,\r\n  .legacy-toolbar-strip,\r\n  .legacy-notif-bell-wrap,\r\n  .legacy-global-search-wrap,\r\n  .legacy-service-workbench-tabs,\r\n  .legacy-service-button-strip,\r\n  .legacy-invoice-actions,\r\n  .legacy-invoice-gate-warning,\r\n  .legacy-data-window-header,\r\n  .legacy-service-pane-tabs,\r\n  .legacy-desktop-board,\r\n  .website-feed-page,\r\n  .legacy-app-sidebar,\r\n  .legacy-workspace-rail,\r\n  button:not(.print-visible) {\r\n    display: none !important;\r\n  }\r\n  body { background: #fff !important; color: #000 !important; }\r\n  .legacy-invoice-layout { padding: 24px !important; }\r\n  .legacy-invoice-job-block { border: 1px solid #ccc !important; page-break-inside: avoid; }\r\n  .legacy-invoice-sub-table th { background: #f0f0f0 !important; color: #333 !important; }\r\n  .legacy-invoice-totals-row { border-color: #ccc !important; }\r\n  .legacy-invoice-totals-row.is-due { color: #000 !important; }\r\n  .legacy-info-card { background: #fff !important; border: 1px solid #ccc !important; box-shadow: none !important; }\r\n  .legacy-chip { border: 1px solid #999 !important; }\r\n  .legacy-service-tab-screen { page-break-before: avoid; }\r\n  .legacy-invoice-print-area { color: #000 !important; }\r\n  .legacy-invoice-print-area .legacy-chip { border: 1px solid #999 !important; color: #333 !important; background: transparent !important; }\r\n  .legacy-closeout-wizard { display: none !important; }\r\n  .legacy-payment-panel { display: none !important; }\r\n}\r\n\r\n/* ─── Feature 9: Responsive Breakpoints ─────────────────────────────── */\r\n\r\n@media (max-width: 1024px) {\r\n  .legacy-data-window { padding: 8px !important; }\r\n  .legacy-service-pane-grid.is-split { grid-template-columns: 1fr !important; }\r\n  .legacy-service-key-grid { grid-template-columns: 1fr 1fr !important; }\r\n  .legacy-invoice-layout { padding: 10px !important; }\r\n  .legacy-fi-grid { grid-template-columns: 1fr !important; }\r\n  .website-sync-settings-layout { grid-template-columns: 1fr !important; }\r\n  .legacy-workload-board { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)) !important; }\r\n  .legacy-schedule-grid { grid-template-columns: repeat(3, 1fr) !important; }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .legacy-workspace-nav { display: none !important; }\r\n  .legacy-service-workbench-tabs { flex-wrap: wrap; gap: 4px !important; }\r\n  .legacy-service-workbench-tab { font-size: 0.72rem !important; padding: 4px 8px !important; }\r\n  .legacy-toolbar-strip { flex-wrap: wrap; gap: 6px !important; }\r\n  .legacy-invoice-header-meta { flex-wrap: wrap; gap: 6px !important; }\r\n  .legacy-deal-stage-bar { flex-wrap: wrap; gap: 4px !important; }\r\n  .legacy-deal-stage { min-width: 80px !important; }\r\n  .legacy-schedule-grid { grid-template-columns: 1fr 1fr !important; }\r\n  .legacy-cross-store-summary { flex-direction: column !important; }\r\n  .legacy-customer-profile-panel { width: 100% !important; }\r\n  .legacy-notif-panel { min-width: 260px !important; right: -20px !important; }\r\n  .legacy-global-search-input { width: 160px !important; }\r\n}\r\n\r\n@media (max-width: 480px) {\r\n  .legacy-schedule-grid { grid-template-columns: 1fr !important; }\r\n  .legacy-fi-grid { grid-template-columns: 1fr !important; }\r\n  .legacy-invoice-totals-grid { max-width: 100% !important; }\r\n  .legacy-global-search-input { width: 120px !important; }\r\n}\r\n\r\n/* ===== Sprint 5 CSS additions ===== */\r\n\r\n/* Feature 1: RO Closeout Wizard */\r\n\r\n.legacy-closeout-wizard { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; margin-top: 14px; padding: 14px; }\r\n\r\n.legacy-closeout-wizard-header { align-items: center; display: flex; font-size: 0.85rem; font-weight: 700; justify-content: space-between; margin-bottom: 12px; }\r\n\r\n.legacy-closeout-steps { display: flex; gap: 0; margin-bottom: 14px; }\r\n\r\n.legacy-closeout-step { align-items: center; background: rgba(255,255,255,0.04); border-right: 2px solid rgba(255,255,255,0.08); display: flex; flex: 1; flex-direction: column; font-size: 0.7rem; gap: 3px; padding: 7px 4px; text-align: center; }\r\n\r\n.legacy-closeout-step:last-child { border-right: none; }\r\n\r\n.legacy-closeout-step.is-active { background: #173446; color: #fff; font-weight: 700; }\r\n\r\n.legacy-closeout-step.is-done { background: #1a4a35; color: #7bcca0; }\r\n\r\n.legacy-closeout-step-num { background: rgba(255,255,255,0.12); border-radius: 50%; font-size: 0.72rem; font-weight: 700; height: 20px; line-height: 20px; text-align: center; width: 20px; }\r\n\r\n.legacy-closeout-body { font-size: 0.83rem; }\r\n\r\n.legacy-closeout-job-row { align-items: center; border-bottom: 1px solid rgba(255,255,255,0.06); display: flex; gap: 10px; justify-content: space-between; padding: 6px 0; }\r\n\r\n.legacy-closeout-totals { display: grid; gap: 4px; margin-bottom: 10px; }\r\n\r\n.legacy-closeout-totals > div { display: flex; justify-content: space-between; padding: 3px 0; font-size: 0.82rem; }\r\n\r\n.legacy-closeout-totals > div.is-total { border-top: 1px solid rgba(255,255,255,0.15); font-weight: 700; margin-top: 4px; padding-top: 6px; }\r\n\r\n.legacy-closeout-all-ok { color: #7bcca0; font-size: 0.83rem; margin-bottom: 10px; }\r\n\r\n.legacy-closeout-footer { display: flex; gap: 8px; justify-content: flex-end; margin-top: 10px; }\r\n\r\n/* Feature 2: Parts Receiving Reconciliation */\r\n\r\n.legacy-receive-discrepancy.is-match { color: #7bcca0; }\r\n\r\n.legacy-receive-discrepancy.is-short { color: #ff7448; }\r\n\r\n.legacy-receive-discrepancy.is-over { color: #f0a830; }\r\n\r\n.legacy-receive-fully-received { align-items: center; background: rgba(123,204,160,0.1); border: 1px solid #7bcca0; border-radius: 6px; color: #7bcca0; display: flex; font-size: 0.8rem; font-weight: 700; gap: 6px; margin-top: 8px; padding: 6px 10px; }\r\n\r\n/* Feature 4: Technician Time Clock */\r\n\r\n.legacy-ot-chip { background: rgba(240,168,48,0.15); border: 1px solid #f0a830; border-radius: 4px; color: #f0a830; font-size: 0.7rem; font-weight: 700; padding: 2px 5px; }\r\n\r\n/* Feature 5: Role Permissions */\r\n\r\n.legacy-role-selector { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 6px; color: inherit; cursor: pointer; font-size: 0.78rem; padding: 4px 8px; }\r\n\r\n.legacy-workbench-notice { background: rgba(123,204,160,0.12); border: 1px solid #7bcca0; border-radius: 6px; color: #7bcca0; font-size: 0.8rem; margin-bottom: 8px; padding: 6px 10px; }\r\n\r\n/* Feature 6: Report Center Workspace */\r\n\r\n.legacy-report-workspace { display: grid; gap: 0; grid-template-columns: 200px 1fr; height: 100%; }\r\n\r\n.legacy-report-nav { border-right: 1px solid rgba(255,255,255,0.08); display: grid; align-content: start; gap: 2px; padding: 12px 8px; }\r\n\r\n.legacy-report-nav-item { background: none; border: none; border-radius: 6px; color: rgba(255,255,255,0.6); cursor: pointer; font-size: 0.82rem; padding: 8px 12px; text-align: left; width: 100%; }\r\n\r\n.legacy-report-nav-item:hover { background: rgba(255,255,255,0.06); color: #fff; }\r\n\r\n.legacy-report-nav-item.is-active { background: rgba(255,255,255,0.1); color: #fff; font-weight: 600; }\r\n\r\n.legacy-report-content { overflow-y: auto; padding: 16px; }\r\n\r\n.legacy-report-section-title { font-size: 0.95rem; font-weight: 700; margin-bottom: 14px; }\r\n\r\n.legacy-report-bar-chart { align-items: flex-end; display: flex; gap: 8px; height: 120px; }\r\n\r\n.legacy-report-bar-col { align-items: center; display: flex; flex: 1; flex-direction: column; gap: 4px; height: 100%; justify-content: flex-end; }\r\n\r\n.legacy-report-bar { background: linear-gradient(to top, #e55a2b, #ff9668); border-radius: 3px 3px 0 0; min-height: 4px; width: 100%; }\r\n\r\n.legacy-report-bar-col span { color: rgba(255,255,255,0.5); font-size: 0.65rem; }\r\n\r\n.legacy-report-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-report-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); font-size: 0.72rem; font-weight: 700; padding: 6px 10px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-report-table td { border-top: 1px solid rgba(255,255,255,0.06); padding: 7px 10px; }\r\n\r\n.legacy-report-aging-chip.is-ok { color: #7bcca0; }\r\n\r\n.legacy-report-aging-chip.is-warn { color: #f0a830; }\r\n\r\n.legacy-report-aging-chip.is-crit { color: #ff7448; }\r\n\r\n/* Feature 3: Sales Deal Finalization */\r\n\r\n.legacy-deal-summary-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; display: grid; gap: 6px; grid-template-columns: 1fr 1fr; margin-top: 10px; padding: 12px; }\r\n\r\n.legacy-deal-summary-row { display: flex; flex-direction: column; font-size: 0.8rem; gap: 2px; }\r\n\r\n.legacy-deal-summary-row span { color: rgba(255,255,255,0.5); font-size: 0.72rem; }\r\n\r\n.legacy-deal-summary-row strong { font-size: 0.85rem; }\r\n\r\n.legacy-deal-fund-actions { display: flex; gap: 8px; margin-top: 10px; }\r\n\r\n/* ── Sprint 7: Report Center admin/workflow sections ── */\r\n\r\n.legacy-report-sidebar { border-right: 1px solid rgba(255,255,255,0.08); display: grid; align-content: start; gap: 3px; overflow-y: auto; padding: 10px 8px; }\r\n\r\n.legacy-report-sidebar-group { color: rgba(255,255,255,0.35); font-size: 0.66rem; font-weight: 800; letter-spacing: 0.08em; margin: 10px 8px 3px; text-transform: uppercase; }\r\n\r\n.legacy-report-sidebar-item { background: none; border: none; border-radius: 7px; color: rgba(255,255,255,0.68); cursor: pointer; display: grid; gap: 2px; padding: 7px 10px; text-align: left; width: 100%; }\r\n\r\n.legacy-report-sidebar-item:hover { background: rgba(255,255,255,0.06); color: #fff; }\r\n\r\n.legacy-report-sidebar-item.is-active { background: rgba(255,255,255,0.11); box-shadow: inset 3px 0 0 #e55a2b; color: #fff; font-weight: 700; }\r\n\r\n.legacy-report-sidebar-category { font-size: 0.76rem; }\r\n\r\n.legacy-report-main-header { font-size: 1rem; font-weight: 800; }\r\n\r\n.legacy-report-section-shell { display: grid; gap: 12px; height: 100%; overflow-y: auto; padding: 16px; }\r\n\r\n.legacy-report-section-header { margin-bottom: 0; }\r\n\r\n.legacy-report-section-header h3 { margin: 2px 0 0; }\r\n\r\n.legacy-report-section-shell select,\r\n.legacy-report-section-shell input[type=\"text\"],\r\n.legacy-report-section-shell input[type=\"search\"],\r\n.legacy-report-section-shell input[type=\"time\"] { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); border-radius: 6px; color: inherit; font-size: 0.82rem; min-height: 30px; padding: 4px 8px; }\r\n\r\n.legacy-approval-table-wrap,\r\n.legacy-document-table-wrap,\r\n.legacy-health-failed-jobs { overflow-x: auto; }\r\n\r\n.legacy-approval-table,\r\n.legacy-document-table,\r\n.legacy-health-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-approval-table th,\r\n.legacy-document-table th,\r\n.legacy-health-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 800; padding: 6px 8px; text-align: left; text-transform: uppercase; white-space: nowrap; }\r\n\r\n.legacy-approval-table td,\r\n.legacy-document-table td,\r\n.legacy-health-table td { border-top: 1px solid rgba(255,255,255,0.06); padding: 7px 8px; vertical-align: top; }\r\n\r\n.legacy-approval-table td:first-child { display: grid; gap: 2px; min-width: 180px; }\r\n\r\n.legacy-approval-table td:first-child span { color: rgba(255,255,255,0.48); font-size: 0.72rem; }\r\n\r\n.legacy-approval-actions,\r\n.legacy-document-actions,\r\n.legacy-health-actions { display: flex; flex-wrap: wrap; gap: 6px; }\r\n\r\n.legacy-approval-status-pending,\r\n.legacy-document-status-draft,\r\n.legacy-document-status-ready { background: rgba(240,168,48,0.14); border: 1px solid rgba(240,168,48,0.65); color: #f0a830; }\r\n\r\n.legacy-approval-status-approved,\r\n.legacy-document-status-sent,\r\n.legacy-document-status-signed,\r\n.legacy-health-status-operational { background: rgba(123,204,160,0.13); border: 1px solid rgba(123,204,160,0.7); color: #7bcca0; }\r\n\r\n.legacy-approval-status-rejected,\r\n.legacy-health-status-down { background: rgba(255,116,72,0.13); border: 1px solid rgba(255,116,72,0.72); color: #ff7448; }\r\n\r\n.legacy-document-status-archived { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.65); }\r\n\r\n.legacy-document-toolbar { align-items: center; display: grid; gap: 8px; grid-template-columns: 180px minmax(180px, 1fr) auto; }\r\n\r\n.legacy-document-toolbar span { color: rgba(255,255,255,0.45); font-size: 0.78rem; font-weight: 700; }\r\n\r\n.legacy-task-board-quick-add { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; display: grid; gap: 8px; grid-template-columns: minmax(160px, 1.4fr) repeat(4, minmax(100px, 1fr)) auto; padding: 10px; }\r\n\r\n.legacy-task-board-grid { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.legacy-task-board-column { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; display: grid; align-content: start; gap: 8px; min-height: 220px; padding: 10px; }\r\n\r\n.legacy-task-board-column-header { align-items: center; color: rgba(255,255,255,0.55); display: flex; font-size: 0.74rem; font-weight: 800; justify-content: space-between; text-transform: uppercase; }\r\n\r\n.legacy-task-board-card { background: rgba(255,255,255,0.055); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; display: grid; gap: 7px; padding: 10px; }\r\n\r\n.legacy-task-board-card-title { font-size: 0.86rem; font-weight: 800; }\r\n\r\n.legacy-task-board-card-meta { color: rgba(255,255,255,0.48); display: flex; flex-wrap: wrap; font-size: 0.72rem; gap: 7px; }\r\n\r\n.legacy-task-board-card-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 6px; }\r\n\r\n.legacy-task-board-priority-low,\r\n.legacy-task-board-priority-normal { background: rgba(74,144,196,0.13); border: 1px solid rgba(74,144,196,0.65); color: #88c6f0; }\r\n\r\n.legacy-task-board-priority-high { background: rgba(240,168,48,0.14); border: 1px solid rgba(240,168,48,0.65); color: #f0a830; }\r\n\r\n.legacy-task-board-priority-urgent { background: rgba(255,116,72,0.14); border: 1px solid rgba(255,116,72,0.72); color: #ff7448; }\r\n\r\n.legacy-exception-summary-grid { display: grid; gap: 8px; grid-template-columns: repeat(6, minmax(110px, 1fr)); }\r\n\r\n.legacy-exception-summary-tile,\r\n.legacy-data-tools-card,\r\n.legacy-preferences-card,\r\n.legacy-health-card { background: rgba(255,255,255,0.045); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 11px; }\r\n\r\n.legacy-exception-summary-tile span { color: rgba(255,255,255,0.45); display: block; font-size: 0.68rem; font-weight: 800; min-height: 30px; text-transform: uppercase; }\r\n\r\n.legacy-exception-summary-tile strong { font-size: 1.25rem; }\r\n\r\n.legacy-exception-group-stack { display: grid; gap: 10px; }\r\n\r\n.legacy-exception-group { border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: hidden; }\r\n\r\n.legacy-exception-group-header { align-items: center; background: rgba(255,255,255,0.055); display: flex; font-size: 0.78rem; font-weight: 800; justify-content: space-between; padding: 8px 10px; text-transform: uppercase; }\r\n\r\n.legacy-exception-row { align-items: center; border-top: 1px solid rgba(255,255,255,0.06); display: grid; gap: 8px; grid-template-columns: 1.2fr 1fr 100px 110px auto; padding: 7px 10px; }\r\n\r\n.legacy-exception-row.is-acknowledged { opacity: 0.55; }\r\n\r\n.legacy-exception-footer { color: rgba(255,255,255,0.45); font-size: 0.78rem; }\r\n\r\n.legacy-exception-severity-low { background: rgba(74,144,196,0.13); border: 1px solid rgba(74,144,196,0.65); color: #88c6f0; }\r\n\r\n.legacy-exception-severity-medium { background: rgba(240,168,48,0.14); border: 1px solid rgba(240,168,48,0.65); color: #f0a830; }\r\n\r\n.legacy-exception-severity-high,\r\n.legacy-exception-severity-critical,\r\n.legacy-health-status-degraded { background: rgba(255,116,72,0.13); border: 1px solid rgba(255,116,72,0.72); color: #ff7448; }\r\n\r\n.legacy-data-tools-grid { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.legacy-data-tools-card { display: grid; gap: 12px; }\r\n\r\n.legacy-data-tools-card strong { font-size: 0.92rem; }\r\n\r\n.legacy-data-tools-card p { color: rgba(255,255,255,0.5); font-size: 0.78rem; margin: 4px 0 0; }\r\n\r\n.legacy-data-tools-actions { display: flex; flex-wrap: wrap; gap: 7px; }\r\n\r\n.legacy-data-tools-file-button { align-items: center; background: #edf3f7; border: 1px solid #c3d1da; border-radius: 999px; color: #173446; cursor: pointer; display: inline-flex; font-size: 0.74rem; font-weight: 700; min-height: 28px; overflow: hidden; padding: 0 10px; position: relative; }\r\n\r\n.legacy-data-tools-file-button input { height: 1px; opacity: 0; position: absolute; width: 1px; }\r\n\r\n.legacy-preferences-grid { display: grid; gap: 12px; grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr); }\r\n\r\n.legacy-preferences-card { display: grid; gap: 10px; }\r\n\r\n.legacy-preferences-card h4 { font-size: 0.86rem; margin: 0; }\r\n\r\n.legacy-preferences-option-grid { display: grid; gap: 8px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.legacy-preferences-option-grid.is-compact { grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.legacy-preferences-check { align-items: center; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; display: flex; font-size: 0.8rem; gap: 8px; padding: 8px; }\r\n\r\n.legacy-preferences-quiet-row { display: grid; gap: 8px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.legacy-preferences-quiet-row label { display: grid; gap: 4px; }\r\n\r\n.legacy-preferences-quiet-row span { color: rgba(255,255,255,0.45); font-size: 0.72rem; font-weight: 800; text-transform: uppercase; }\r\n\r\n.legacy-health-toolbar { align-items: center; display: flex; flex-wrap: wrap; gap: 10px; }\r\n\r\n.legacy-health-toolbar span { color: rgba(255,255,255,0.55); font-size: 0.8rem; }\r\n\r\n.legacy-health-card-grid { display: grid; gap: 10px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.legacy-health-card { display: grid; gap: 7px; }\r\n\r\n.legacy-health-card-header { align-items: center; display: flex; gap: 8px; justify-content: space-between; }\r\n\r\n.legacy-health-latency { font-size: 1.05rem; font-weight: 800; }\r\n\r\n.legacy-health-card p { color: rgba(255,255,255,0.58); font-size: 0.78rem; margin: 0; }\r\n\r\n.legacy-health-card > span { color: rgba(255,255,255,0.42); font-size: 0.72rem; }\r\n\r\n.legacy-health-admin-grid { display: grid; gap: 12px; grid-template-columns: minmax(0, 1fr) 240px; }\r\n\r\n.legacy-health-subheader { font-size: 0.84rem; font-weight: 800; margin-bottom: 8px; }\r\n\r\n.legacy-health-env-grid { background: rgba(255,255,255,0.045); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; display: grid; gap: 8px; padding: 11px; }\r\n\r\n.legacy-health-env-grid div { display: grid; gap: 2px; }\r\n\r\n.legacy-health-env-grid span { color: rgba(255,255,255,0.45); font-size: 0.68rem; font-weight: 800; text-transform: uppercase; }\r\n\r\n.legacy-health-env-grid strong { font-size: 0.78rem; overflow-wrap: anywhere; }\r\n\r\n@media (max-width: 1100px) {\r\n  .legacy-report-workspace { grid-template-columns: 170px 1fr; }\r\n  .legacy-task-board-quick-add,\r\n  .legacy-document-toolbar,\r\n  .legacy-health-admin-grid { grid-template-columns: 1fr; }\r\n  .legacy-exception-summary-grid,\r\n  .legacy-data-tools-grid,\r\n  .legacy-health-card-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n  .legacy-exception-row { grid-template-columns: 1fr; }\r\n}\r\n\r\n@media (max-width: 760px) {\r\n  .legacy-report-workspace,\r\n  .legacy-task-board-grid,\r\n  .legacy-preferences-grid,\r\n  .legacy-exception-summary-grid,\r\n  .legacy-data-tools-grid,\r\n  .legacy-health-card-grid { grid-template-columns: 1fr; }\r\n  .legacy-report-sidebar { border-bottom: 1px solid rgba(255,255,255,0.08); border-right: none; max-height: 220px; }\r\n}\r\n\r\n/* Sprint 8 additions */\r\n\r\n/* Feature 2: Session indicator */\r\n\r\n.legacy-session-indicator {\r\n  background: rgba(255,116,72,0.12);\r\n  border: 1px solid rgba(255,116,72,0.3);\r\n  border-radius: 4px;\r\n  color: #ffb48e;\r\n  font-size: 0.72rem;\r\n  padding: 1px 7px;\r\n}\r\n\r\n/* Feature 3: Reorder PO panel */\r\n\r\n.legacy-reorder-po-panel {\r\n  background: #f1f7fa;\r\n  border: 1px solid #b8cdd8;\r\n  border-radius: 6px;\r\n  margin-top: 8px;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.legacy-reorder-po-header {\r\n  font-size: 0.82rem;\r\n  font-weight: 700;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.legacy-reorder-po-row {\r\n  border-top: 1px solid #d7e3eb;\r\n  display: flex;\r\n  font-size: 0.8rem;\r\n  gap: 12px;\r\n  padding: 5px 0;\r\n}\r\n\r\n/* Feature 4: Notification templates */\r\n\r\n.legacy-notif-template-grid {\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));\r\n  padding: 10px 0;\r\n}\r\n\r\n.legacy-notif-template-card {\r\n  background: rgba(255,255,255,0.06);\r\n  border: 1px solid rgba(255,255,255,0.12);\r\n  border-radius: 8px;\r\n  display: grid;\r\n  gap: 6px;\r\n  padding: 12px;\r\n}\r\n\r\n.legacy-notif-template-name {\r\n  font-size: 0.86rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.legacy-notif-template-channels {\r\n  color: rgba(255,255,255,0.5);\r\n  font-size: 0.74rem;\r\n}\r\n\r\n.legacy-notif-template-preview {\r\n  color: rgba(255,255,255,0.7);\r\n  font-size: 0.78rem;\r\n}\r\n\r\n.legacy-notif-template-edit {\r\n  display: grid;\r\n  gap: 6px;\r\n  margin-top: 6px;\r\n}\r\n\r\n.legacy-notif-template-field {\r\n  display: grid;\r\n  font-size: 0.78rem;\r\n  gap: 3px;\r\n}\r\n\r\n.legacy-notif-template-field input,\r\n.legacy-notif-template-field textarea {\r\n  background: rgba(255,255,255,0.09);\r\n  border: 1px solid rgba(255,255,255,0.16);\r\n  border-radius: 4px;\r\n  color: #f3f6fa;\r\n  font-size: 0.78rem;\r\n  padding: 5px 8px;\r\n  resize: vertical;\r\n}\r\n\r\n/* Feature 5: VIN/HIN decoder */\r\n\r\n.legacy-vin-decoder {\r\n  background: rgba(255,255,255,0.04);\r\n  border: 1px solid rgba(255,255,255,0.12);\r\n  border-radius: 6px;\r\n  display: grid;\r\n  gap: 8px;\r\n  margin-top: 8px;\r\n  padding: 10px 12px;\r\n}\r\n\r\n.legacy-vin-decoder-label {\r\n  font-size: 0.78rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.legacy-vin-decoder-input {\r\n  background: rgba(255,255,255,0.09);\r\n  border: 1px solid rgba(255,255,255,0.16);\r\n  border-radius: 4px;\r\n  color: #f3f6fa;\r\n  font-size: 0.82rem;\r\n  padding: 5px 10px;\r\n  width: 100%;\r\n}\r\n\r\n.legacy-vin-decoded-chips {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 6px;\r\n  font-size: 0.78rem;\r\n}\r\n\r\n.legacy-vin-decoded-chips span {\r\n  background: rgba(68,193,136,0.14);\r\n  border-radius: 4px;\r\n  color: #9be7bf;\r\n  padding: 2px 8px;\r\n}\r\n\r\n/* Feature 7: Tech view */\r\n\r\n.legacy-tech-view-grid {\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\r\n  padding: 8px 0;\r\n}\r\n\r\n.legacy-tech-view-card {\r\n  background: rgba(255,255,255,0.05);\r\n  border: 1px solid rgba(255,255,255,0.12);\r\n  border-radius: 8px;\r\n  cursor: pointer;\r\n  display: grid;\r\n  gap: 5px;\r\n  padding: 12px;\r\n}\r\n\r\n.legacy-tech-view-card.is-selected {\r\n  border-color: rgba(255,116,72,0.6);\r\n  box-shadow: 0 0 0 2px rgba(255,116,72,0.18);\r\n}\r\n\r\n.legacy-tech-view-card:hover {\r\n  background: rgba(255,255,255,0.09);\r\n}\r\n\r\n.legacy-tech-view-ro {\r\n  font-size: 0.86rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.legacy-tech-view-customer {\r\n  color: rgba(255,255,255,0.7);\r\n  font-size: 0.8rem;\r\n}\r\n\r\n.legacy-tech-view-meta {\r\n  color: rgba(255,255,255,0.5);\r\n  font-size: 0.74rem;\r\n}\r\n\r\n.legacy-tech-view-writer {\r\n  color: rgba(255,180,142,0.8);\r\n  font-size: 0.74rem;\r\n}\r\n\r\n/* Feature 8: Customer portal full-page */\r\n\r\n.legacy-portal-full-page {\r\n  background: #f4f8fb;\r\n  color: #10293b;\r\n  display: grid;\r\n  gap: 0;\r\n  min-height: 100vh;\r\n  position: relative;\r\n}\r\n\r\n.legacy-portal-full-header {\r\n  align-items: center;\r\n  background: #1c4b6e;\r\n  display: flex;\r\n  gap: 14px;\r\n  padding: 16px 24px;\r\n}\r\n\r\n.legacy-portal-full-logo {\r\n  color: #7ad0eb;\r\n  font-size: 1.4rem;\r\n}\r\n\r\n.legacy-portal-full-title {\r\n  color: #f3f6fa;\r\n  font-family: \"Space Grotesk\", sans-serif;\r\n  font-size: 1.1rem;\r\n  font-weight: 700;\r\n}\r\n\r\n.legacy-portal-full-body {\r\n  display: grid;\r\n  gap: 16px;\r\n  padding: 24px;\r\n}\r\n\r\n.legacy-portal-full-card {\r\n  background: #fff;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 10px;\r\n  display: grid;\r\n  gap: 10px;\r\n  padding: 18px 20px;\r\n}\r\n\r\n.legacy-portal-status-bar {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 0;\r\n}\r\n\r\n.legacy-portal-status-step {\r\n  align-items: center;\r\n  display: flex;\r\n  flex: 1;\r\n  flex-direction: column;\r\n  font-size: 0.76rem;\r\n  gap: 6px;\r\n  min-width: 80px;\r\n  opacity: 0.45;\r\n  text-align: center;\r\n}\r\n\r\n.legacy-portal-status-dot {\r\n  background: #b3c5cf;\r\n  border-radius: 999px;\r\n  height: 14px;\r\n  width: 14px;\r\n}\r\n\r\n.legacy-portal-status-step.is-done .legacy-portal-status-dot {\r\n  background: #44c188;\r\n}\r\n\r\n.legacy-portal-status-step.is-done {\r\n  opacity: 1;\r\n}\r\n\r\n/* Feature 9: Saved searches */\r\n\r\n.legacy-saved-searches-row {\r\n  align-items: center;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 6px;\r\n  padding: 4px 0 6px;\r\n}\r\n\r\n.legacy-saved-search-chip {\r\n  align-items: center;\r\n  background: rgba(255,255,255,0.08);\r\n  border: 1px solid rgba(255,255,255,0.16);\r\n  border-radius: 999px;\r\n  color: #f3f6fa;\r\n  display: inline-flex;\r\n  font-size: 0.76rem;\r\n  gap: 4px;\r\n  padding: 2px 10px 2px 10px;\r\n}\r\n\r\n.legacy-saved-search-chip:hover {\r\n  background: rgba(255,255,255,0.14);\r\n}\r\n\r\n.legacy-saved-search-remove {\r\n  background: transparent;\r\n  border: none;\r\n  color: rgba(255,255,255,0.4);\r\n  cursor: pointer;\r\n  font-size: 0.7rem;\r\n  padding: 0 2px;\r\n}\r\n\r\n.legacy-save-search-inline {\r\n  align-items: center;\r\n  display: inline-flex;\r\n  gap: 6px;\r\n}\r\n\r\n.legacy-save-search-inline input {\r\n  background: rgba(255,255,255,0.09);\r\n  border: 1px solid rgba(255,255,255,0.2);\r\n  border-radius: 4px;\r\n  color: #f3f6fa;\r\n  font-size: 0.8rem;\r\n  padding: 3px 8px;\r\n  width: 180px;\r\n}\r\n\r\n/* Sprint 9 additions */\r\n\r\n.legacy-boat-inventory-shell,\r\n.legacy-user-admin-shell,\r\n.legacy-crm-shell,\r\n.legacy-fi-products-library,\r\n.legacy-report-real-panel { color: inherit; height: 100%; overflow: auto; padding: 14px; }\r\n\r\n.legacy-boat-inventory-toolbar,\r\n.legacy-crm-toolbar { align-items: center; display: flex; gap: 8px; margin-bottom: 10px; }\r\n\r\n.legacy-boat-inventory-toolbar input,\r\n.legacy-boat-inventory-toolbar select,\r\n.legacy-boat-inventory-form input,\r\n.legacy-boat-inventory-form select,\r\n.legacy-boat-inventory-form textarea,\r\n.legacy-user-admin-form input,\r\n.legacy-user-admin-form select,\r\n.legacy-crm-form input,\r\n.legacy-crm-form select { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.14); border-radius: 7px; color: inherit; font-size: 0.82rem; padding: 6px 8px; }\r\n\r\n.legacy-boat-inventory-toolbar input { flex: 1; min-width: 220px; }\r\n\r\n.legacy-boat-inventory-summary { display: grid; gap: 8px; grid-template-columns: repeat(6, minmax(0, 1fr)); margin-bottom: 10px; }\r\n\r\n.legacy-boat-inventory-card { min-height: 66px; padding: 10px; }\r\n\r\n.legacy-boat-inventory-card span { color: rgba(255,255,255,0.55); font-size: 0.72rem; text-transform: uppercase; }\r\n\r\n.legacy-boat-inventory-card strong { display: block; font-size: 1.05rem; margin-top: 5px; }\r\n\r\n.legacy-boat-inventory-layout { display: grid; gap: 12px; grid-template-columns: minmax(0, 1fr) 310px; min-height: 320px; }\r\n\r\n.legacy-boat-inventory-table-wrap { border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: auto; }\r\n\r\n.legacy-boat-inventory-table { border-collapse: collapse; font-size: 0.78rem; width: 100%; }\r\n\r\n.legacy-boat-inventory-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.52); font-size: 0.68rem; letter-spacing: 0.05em; padding: 7px 9px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-boat-inventory-table td { border-top: 1px solid rgba(255,255,255,0.06); cursor: pointer; padding: 7px 9px; }\r\n\r\n.legacy-boat-inventory-table tr.is-selected td { background: rgba(229,90,43,0.12); }\r\n\r\n.legacy-boat-inventory-detail { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; }\r\n\r\n.legacy-boat-inventory-detail h3 { font-size: 1rem; margin: 8px 0 2px; }\r\n\r\n.legacy-boat-inventory-detail p { color: rgba(255,255,255,0.58); font-size: 0.78rem; margin: 0 0 8px; }\r\n\r\n.legacy-boat-inventory-photo-grid { display: grid; gap: 6px; grid-template-columns: repeat(2, 1fr); }\r\n\r\n.legacy-boat-inventory-photo-grid span { align-items: center; aspect-ratio: 1.8; background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)); border: 1px dashed rgba(255,255,255,0.16); border-radius: 8px; color: rgba(255,255,255,0.5); display: flex; font-size: 0.7rem; justify-content: center; }\r\n\r\n.legacy-boat-inventory-specs { display: grid; gap: 6px; grid-template-columns: repeat(2, 1fr); margin: 10px 0; }\r\n\r\n.legacy-boat-inventory-specs span { color: rgba(255,255,255,0.5); display: grid; font-size: 0.7rem; }\r\n\r\n.legacy-boat-inventory-specs strong { color: rgba(255,255,255,0.88); font-size: 0.82rem; }\r\n\r\n.legacy-boat-inventory-notes { background: rgba(255,255,255,0.04); border-radius: 8px; padding: 8px; }\r\n\r\n.legacy-boat-inventory-actions { display: flex; gap: 8px; }\r\n\r\n.legacy-boat-inventory-form { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; margin-top: 12px; padding: 12px; }\r\n\r\n.legacy-boat-inventory-shell.is-major-unit-layout {\r\n  background: #d9e1e5;\r\n  color: #0e2637;\r\n  display: flex;\r\n  flex-direction: column;\r\n  font-family: Arial, Helvetica, sans-serif;\r\n  gap: 0;\r\n  height: 100%;\r\n  overflow: hidden;\r\n  padding: 0;\r\n}\r\n\r\n.major-unit-icon-toolbar {\r\n  align-items: stretch;\r\n  background: linear-gradient(#eef6f8 0%, #86a9b8 26%, #0d3950 100%);\r\n  border-bottom: 1px solid #78909d;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  min-height: 48px;\r\n  padding: 2px 8px 3px;\r\n}\r\n\r\n.major-unit-toolbar-group {\r\n  align-items: flex-start;\r\n  display: flex;\r\n  gap: 14px;\r\n}\r\n\r\n.major-unit-toolbar-group.is-right {\r\n  gap: 10px;\r\n}\r\n\r\n.major-unit-toolbar-button {\r\n  align-items: center;\r\n  background: transparent;\r\n  border: 0;\r\n  color: #eaf5fa;\r\n  display: grid;\r\n  font-size: 0.58rem;\r\n  gap: 1px;\r\n  justify-items: center;\r\n  min-width: 52px;\r\n  padding: 0;\r\n  text-shadow: 0 1px 0 rgba(0,0,0,0.55);\r\n}\r\n\r\n.major-unit-toolbar-button:disabled {\r\n  cursor: default;\r\n  opacity: 0.55;\r\n}\r\n\r\n.major-unit-toolbar-icon {\r\n  align-items: center;\r\n  background: linear-gradient(135deg, #f7fbfc, #93aab4 55%, #314a58);\r\n  border: 1px solid rgba(31, 56, 69, 0.75);\r\n  border-radius: 5px;\r\n  box-shadow:\r\n    inset 0 1px 0 rgba(255,255,255,0.78),\r\n    0 1px 2px rgba(0,0,0,0.35);\r\n  color: #0e2637;\r\n  display: flex;\r\n  font-size: 1rem;\r\n  height: 28px;\r\n  justify-content: center;\r\n  line-height: 1;\r\n  min-width: 42px;\r\n}\r\n\r\n.major-unit-toolbar-button strong {\r\n  display: block;\r\n  font-size: 0.58rem;\r\n  font-weight: 700;\r\n  line-height: 0.9;\r\n  max-width: 66px;\r\n}\r\n\r\n.major-unit-search-strip {\r\n  align-items: center;\r\n  background: #f2f5f7;\r\n  border-bottom: 1px solid #a6b3bc;\r\n  display: flex;\r\n  gap: 5px;\r\n  min-height: 22px;\r\n  padding: 2px 4px;\r\n}\r\n\r\n.major-unit-search-field {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 4px;\r\n}\r\n\r\n.major-unit-search-field span,\r\n.major-unit-found-count {\r\n  color: #0e2637;\r\n  font-size: 0.72rem;\r\n}\r\n\r\n.major-unit-search-strip input,\r\n.major-unit-search-strip select {\r\n  background: #fff;\r\n  border: 1px solid #7d8e9b;\r\n  border-radius: 0;\r\n  color: #0e2637;\r\n  font-size: 0.72rem;\r\n  height: 18px;\r\n  min-width: 200px;\r\n  padding: 0 5px;\r\n}\r\n\r\n.major-unit-search-strip select {\r\n  min-width: 126px;\r\n}\r\n\r\n.major-unit-found-count {\r\n  margin-left: auto;\r\n  padding-right: 8px;\r\n}\r\n\r\n.major-unit-filter-strip {\r\n  align-items: center;\r\n  background: #f2f5f7;\r\n  border-bottom: 1px solid #9daab3;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 12px;\r\n  min-height: 20px;\r\n  padding: 1px 26px;\r\n}\r\n\r\n.major-unit-filter-option {\r\n  align-items: center;\r\n  color: #0e2637;\r\n  display: inline-flex;\r\n  font-size: 0.72rem;\r\n  gap: 3px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.major-unit-filter-option input {\r\n  accent-color: #0b4360;\r\n  height: 11px;\r\n  margin: 0;\r\n  width: 11px;\r\n}\r\n\r\n.legacy-boat-inventory-shell.is-major-unit-layout .legacy-workbench-notice {\r\n  background: #fff5cc;\r\n  border: 1px solid #c9a84b;\r\n  border-radius: 0;\r\n  color: #5d4b0d;\r\n  font-size: 0.68rem;\r\n  margin: 0;\r\n  padding: 3px 6px;\r\n}\r\n\r\n.major-unit-grid-wrap {\r\n  background: #eef2f5;\r\n  border-top: 1px solid #6c7f8d;\r\n  flex: 1;\r\n  min-height: 0;\r\n  overflow: auto;\r\n}\r\n\r\n.major-unit-grid {\r\n  border-collapse: collapse;\r\n  color: #071c2c;\r\n  font-size: 0.7rem;\r\n  line-height: 1.18;\r\n  min-width: 100%;\r\n  table-layout: fixed;\r\n  width: 100%;\r\n}\r\n\r\n.major-unit-grid th {\r\n  background: #06466a;\r\n  border-bottom: 1px solid #122c3c;\r\n  border-right: 1px solid #8a9baa;\r\n  color: #fff;\r\n  cursor: grab;\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  min-height: 28px;\r\n  padding: 1px 2px;\r\n  position: relative;\r\n  text-align: center;\r\n  vertical-align: top;\r\n  white-space: normal;\r\n  word-break: break-word;\r\n}\r\n\r\n.major-unit-grid th:active {\r\n  cursor: grabbing;\r\n}\r\n\r\n.major-unit-grid th.is-dragging {\r\n  opacity: 0.52;\r\n}\r\n\r\n.major-unit-grid th.is-drop-target {\r\n  box-shadow: inset 3px 0 0 #ffb48e;\r\n}\r\n\r\n.major-unit-column-header {\r\n  align-items: stretch;\r\n  display: grid;\r\n  gap: 2px;\r\n  justify-items: center;\r\n  min-height: 100%;\r\n  padding-right: 6px;\r\n}\r\n\r\n.major-unit-column-header > span {\r\n  display: block;\r\n  line-height: 1.05;\r\n}\r\n\r\n.major-unit-column-resize-handle {\r\n  bottom: 0;\r\n  cursor: col-resize;\r\n  position: absolute;\r\n  right: -3px;\r\n  top: 0;\r\n  width: 7px;\r\n  z-index: 2;\r\n}\r\n\r\n.major-unit-column-resize-handle::after {\r\n  background: rgba(255, 255, 255, 0.42);\r\n  bottom: 4px;\r\n  content: \"\";\r\n  position: absolute;\r\n  right: 3px;\r\n  top: 4px;\r\n  width: 1px;\r\n}\r\n\r\n.major-unit-column-resize-handle:hover::after {\r\n  background: #ffb48e;\r\n  width: 2px;\r\n}\r\n\r\n.major-unit-grid td {\r\n  background: #f4f7f9;\r\n  border-bottom: 1px solid #919ba5;\r\n  border-right: 1px solid #78838f;\r\n  cursor: pointer;\r\n  min-height: 17px;\r\n  overflow-wrap: anywhere;\r\n  padding: 2px 3px;\r\n  vertical-align: top;\r\n  white-space: normal;\r\n  word-break: break-word;\r\n}\r\n\r\n.major-unit-grid tbody tr:nth-child(even) td {\r\n  background: #e8edf2;\r\n}\r\n\r\n.major-unit-grid tbody tr.is-selected td {\r\n  background: #a8c2d5;\r\n}\r\n\r\n.major-unit-grid tbody tr.is-empty td {\r\n  cursor: default;\r\n}\r\n\r\n.major-unit-editor-panel {\r\n  background: #eef3f6;\r\n  border-top: 2px solid #0b4360;\r\n  box-shadow: 0 
 #dbeaf3;\r\n  border-color: #7d98ab;\r\n  box-shadow: inset 0 0 0 1px rgba(11,67,96,0.16);\r\n}\r\n\r\n.chart-accounts-summary-card span {\r\n  color: #526978;\r\n  font-size: 0.62rem;\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.chart-accounts-summary-card strong {\r\n  color: #0e2637;\r\n  font-size: 0.96rem;\r\n}\r\n\r\n.chart-accounts-filter-strip {\r\n  align-items: center;\r\n  background: #f2f5f7;\r\n  border-bottom: 1px solid #9daab3;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n  min-height: 26px;\r\n  padding: 3px 6px;\r\n}\r\n\r\n.chart-accounts-filter-strip label {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 5px;\r\n}\r\n\r\n.chart-accounts-filter-strip span,\r\n.chart-accounts-found {\r\n  color: #0e2637;\r\n  font-size: 0.72rem;\r\n}\r\n\r\n.chart-accounts-filter-strip input,\r\n.chart-accounts-filter-strip select {\r\n  background: #fff;\r\n  border: 1px solid #7d8e9b;\r\n  border-radius: 0;\r\n  color: #0e2637;\r\n  font-size: 0.72rem;\r\n  height: 19px;\r\n  padding: 0 5px;\r\n}\r\n\r\n.chart-accounts-filter-strip input {\r\n  min-width: 260px;\r\n}\r\n\r\n.chart-accounts-found {\r\n  margin-left: auto;\r\n  padding-right: 8px;\r\n}\r\n\r\n.chart-accounts-body {\r\n  display: grid;\r\n  flex: 1;\r\n  grid-template-columns: minmax(0, 1fr);\r\n  min-height: 0;\r\n}\r\n\r\n.chart-accounts-grid-wrap {\r\n  background: #eef2f5;\r\n  min-height: 0;\r\n  overflow: auto;\r\n}\r\n\r\n.chart-accounts-grid {\r\n  border-collapse: collapse;\r\n  color: #071c2c;\r\n  font-size: 0.72rem;\r\n  line-height: 1.18;\r\n  min-width: 1920px;\r\n  table-layout: fixed;\r\n  width: 100%;\r\n}\r\n\r\n.chart-accounts-grid th {\r\n  background: #06466a;\r\n  border-bottom: 1px solid #122c3c;\r\n  border-right: 1px solid #8a9baa;\r\n  color: #fff;\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  padding: 3px;\r\n  text-align: center;\r\n}\r\n\r\n.chart-accounts-grid td {\r\n  background: #f4f7f9;\r\n  border-bottom: 1px solid #919ba5;\r\n  border-right: 1px solid #78838f;\r\n  cursor: pointer;\r\n  overflow-wrap: anywhere;\r\n  padding: 3px 4px;\r\n  text-align: center;\r\n  vertical-align: middle;\r\n}\r\n\r\n.chart-accounts-grid tbody tr:nth-child(even) td {\r\n  background: #e8edf2;\r\n}\r\n\r\n.chart-accounts-grid tbody tr.is-selected td {\r\n  background: #a8c2d5;\r\n}\r\n\r\n.chart-accounts-chip {\r\n  border-radius: 999px;\r\n  display: inline-flex;\r\n  font-size: 0.62rem;\r\n  font-weight: 800;\r\n  line-height: 1;\r\n  padding: 4px 7px;\r\n  text-transform: uppercase;\r\n  white-space: nowrap;\r\n}\r\n\r\n.chart-accounts-chip.tone-stable {\r\n  background: #d9f1e6;\r\n  color: #0d5b37;\r\n}\r\n\r\n.chart-accounts-chip.tone-attention {\r\n  background: #fff0d2;\r\n  color: #8a4d0f;\r\n}\r\n\r\n.chart-accounts-chip.tone-critical {\r\n  background: #fde1dc;\r\n  color: #9f2d1f;\r\n}\r\n\r\n.chart-accounts-detail {\r\n  background: #eef3f6;\r\n  border-left: 2px solid #0b4360;\r\n  box-shadow: -8px 0 20px rgba(0,0,0,0.14);\r\n  color: #0e2637;\r\n  display: grid;\r\n  gap: 10px;\r\n  grid-auto-rows: max-content;\r\n  overflow: auto;\r\n  padding: 10px;\r\n}\r\n\r\n.chart-accounts-detail-header {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.chart-accounts-detail-header span {\r\n  color: #315168;\r\n  font-size: 0.66rem;\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.chart-accounts-detail-header strong {\r\n  background: #0b4360;\r\n  color: #fff;\r\n  font-size: 0.72rem;\r\n  padding: 2px 8px;\r\n}\r\n\r\n.chart-accounts-detail h3 {\r\n  font-size: 1rem;\r\n  margin: 8px 0 12px;\r\n}\r\n\r\n.chart-accounts-detail-copy {\r\n  color: #415968;\r\n  font-size: 0.74rem;\r\n  line-height: 1.35;\r\n  margin: -6px 0 0;\r\n}\r\n\r\n.chart-accounts-alert-box {\r\n  background: #ecf5ef;\r\n  border: 1px solid #8fc3a4;\r\n  display: grid;\r\n  gap: 4px;\r\n  padding: 8px;\r\n}\r\n\r\n.chart-accounts-alert-box.tone-attention {\r\n  background: #fff6d8;\r\n  border-color: #c9a84b;\r\n}\r\n\r\n.chart-accounts-alert-box.tone-critical {\r\n  background: #fde8e4;\r\n  border-color: #d06c54;\r\n}\r\n\r\n.chart-accounts-alert-box strong {\r\n  font-size: 0.78rem;\r\n}\r\n\r\n.chart-accounts-alert-box p {\r\n  font-size: 0.72rem;\r\n  line-height: 1.35;\r\n  margin: 0;\r\n}\r\n\r\n.chart-accounts-detail-tabs {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 6px;\r\n}\r\n\r\n.chart-accounts-detail-tabs button {\r\n  background: #d7e6ef;\r\n  border: 1px solid #9ab1bf;\r\n  color: #204258;\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  min-height: 24px;\r\n  padding: 0 10px;\r\n}\r\n\r\n.chart-accounts-detail-tabs button.is-active {\r\n  background: #0b4360;\r\n  border-color: #062a3d;\r\n  color: #fff;\r\n}\r\n\r\n.chart-accounts-detail-grid {\r\n  display: grid;\r\n  gap: 7px;\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.chart-accounts-detail-grid span {\r\n  background: #fff;\r\n  border: 1px solid #bdc8cf;\r\n  color: #4d6474;\r\n  display: grid;\r\n  font-size: 0.66rem;\r\n  gap: 2px;\r\n  padding: 5px 6px;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.chart-accounts-detail-grid strong {\r\n  color: #0e2637;\r\n  font-size: 0.78rem;\r\n  text-transform: none;\r\n}\r\n\r\n.chart-accounts-detail-section {\r\n  background: #fff;\r\n  border: 1px solid #bdc8cf;\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 8px;\r\n}\r\n\r\n.chart-accounts-detail-section h4 {\r\n  font-size: 0.72rem;\r\n  letter-spacing: 0.04em;\r\n  margin: 0;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.chart-accounts-inline-note {\r\n  color: #415968;\r\n  font-size: 0.72rem;\r\n  line-height: 1.35;\r\n  margin: 0;\r\n}\r\n\r\n.chart-accounts-list {\r\n  color: #415968;\r\n  font-size: 0.72rem;\r\n  line-height: 1.4;\r\n  margin: 0;\r\n  padding-left: 18px;\r\n}\r\n\r\n.chart-accounts-source-table {\r\n  border-collapse: collapse;\r\n  font-size: 0.68rem;\r\n  width: 100%;\r\n}\r\n\r\n.chart-accounts-source-table th {\r\n  background: #063f5e;\r\n  border-right: 1px solid #9fb0bc;\r\n  color: #fff;\r\n  font-size: 0.66rem;\r\n  padding: 2px 4px;\r\n  text-align: left;\r\n}\r\n\r\n.chart-accounts-source-table td {\r\n  background: #eef3f6;\r\n  border-bottom: 1px solid #aab0b6;\r\n  border-right: 1px solid #aab0b6;\r\n  padding: 3px 4px;\r\n}\r\n\r\n.chart-accounts-reconciliation-box {\r\n  background: #ecf5ef;\r\n  border: 1px solid #8fc3a4;\r\n  display: grid;\r\n  gap: 2px;\r\n  padding: 8px;\r\n}\r\n\r\n.chart-accounts-reconciliation-box.tone-attention {\r\n  background: #fff6d8;\r\n  border-color: #c9a84b;\r\n}\r\n\r\n.chart-accounts-reconciliation-box.tone-critical {\r\n  background: #fde8e4;\r\n  border-color: #d06c54;\r\n}\r\n\r\n.chart-accounts-reconciliation-box strong {\r\n  font-size: 0.82rem;\r\n}\r\n\r\n.chart-accounts-reconciliation-box span {\r\n  color: #5d7482;\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.chart-accounts-reconciliation-box p {\r\n  font-size: 0.72rem;\r\n  line-height: 1.35;\r\n  margin: 2px 0 0;\r\n}\r\n\r\n.chart-accounts-exception-list,\r\n.chart-accounts-activity-stack {\r\n  display: grid;\r\n  gap: 8px;\r\n}\r\n\r\n.chart-accounts-exception-line,\r\n.chart-accounts-activity-line {\r\n  background: #f7fafc;\r\n  border: 1px solid #c3d0d8;\r\n  border-left: 4px solid #6f8795;\r\n  display: grid;\r\n  gap: 4px;\r\n  padding: 8px;\r\n}\r\n\r\n.chart-accounts-exception-line.tone-stable,\r\n.chart-accounts-activity-line.tone-stable {\r\n  border-left-color: #188a5c;\r\n}\r\n\r\n.chart-accounts-exception-line.tone-attention,\r\n.chart-accounts-activity-line.tone-attention {\r\n  border-left-color: #c75a27;\r\n}\r\n\r\n.chart-accounts-exception-line.tone-critical {\r\n  border-left-color: #b73a2a;\r\n}\r\n\r\n.chart-accounts-activity-line.tone-neutral {\r\n  border-left-color: #0b4360;\r\n}\r\n\r\n.chart-accounts-exception-line strong,\r\n.chart-accounts-activity-line strong {\r\n  font-size: 0.74rem;\r\n}\r\n\r\n.chart-accounts-exception-line p,\r\n.chart-accounts-activity-line p {\r\n  color: #415968;\r\n  font-size: 0.72rem;\r\n  line-height: 1.35;\r\n  margin: 0;\r\n}\r\n\r\n.chart-accounts-activity-header {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 8px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.chart-accounts-activity-header span,\r\n.chart-accounts-activity-line small {\r\n  color: #5d7482;\r\n  font-size: 0.66rem;\r\n}\r\n\r\n.chart-accounts-empty-state {\r\n  align-items: center;\r\n  color: #526978;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 6px;\r\n  justify-content: center;\r\n  min-height: 180px;\r\n  text-align: center;\r\n}\r\n\r\n.chart-accounts-empty-state p,\r\n.chart-accounts-empty-state strong {\r\n  margin: 0;\r\n}\r\n\r\n@media (max-width: 1100px) {\r\n  .chart-accounts-summary-strip { grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n  .legacy-boat-inventory-summary { grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n  .legacy-boat-inventory-layout { grid-template-columns: 1fr; }\r\n  .legacy-crm-pipeline { grid-template-columns: repeat(3, minmax(150px, 1fr)); }\r\n  .chart-accounts-body { grid-template-columns: 1fr; }\r\n  .chart-accounts-detail { border-left: 0; border-top: 2px solid #0b4360; }\r\n}\r\n\r\n@media (max-width: 760px) {\r\n  .chart-accounts-summary-strip { grid-template-columns: 1fr; }\r\n  .chart-accounts-detail-grid { grid-template-columns: 1fr; }\r\n  .chart-accounts-filter-strip input { min-width: 0; width: 100%; }\r\n}\r\n\r\n.profit-loss-title-bar {\r\n  align-items: center;\r\n  background: #ff7438;\r\n  border-bottom: 1px solid #9b351c;\r\n  color: #fff;\r\n  display: flex;\r\n  font-size: 0.86rem;\r\n  font-weight: 800;\r\n  justify-content: space-between;\r\n  min-height: 20px;\r\n  padding: 0 2px;\r\n}\r\n\r\n.profit-loss-title-actions {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 10px;\r\n  margin-right: 8px;\r\n}\r\n\r\n.profit-loss-title-actions button {\r\n  background: linear-gradient(#f7fbff, #8fa7b5 55%, #42606f);\r\n  border: 1px solid #4d5d64;\r\n  border-radius: 5px;\r\n  box-shadow: inset 0 1px 0 rgba(255,255,255,0.75);\r\n  color: #102432;\r\n  font-size: 0.58rem;\r\n  font-weight: 800;\r\n  min-height: 28px;\r\n  min-width: 52px;\r\n}\r\n\r\n.profit-loss-options-layout {\r\n  background: linear-gradient(#17394a, #e5ecee 34px);\r\n  display: grid;\r\n  gap: 6px;\r\n  grid-template-columns: 1fr 1fr;\r\n  padding: 52px 2px 4px;\r\n}\r\n\r\n.profit-loss-panel {\r\n  background: #eeeeee;\r\n  border: 1px solid #747474;\r\n  color: #111;\r\n  display: grid;\r\n  font-size: 0.68rem;\r\n  gap: 4px;\r\n  min-height: 92px;\r\n  padding: 4px;\r\n}\r\n\r\n.profit-loss-panel h3 {\r\n  font-size: 0.68rem;\r\n  margin: 0;\r\n}\r\n\r\n.profit-loss-panel label {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 4px;\r\n  min-height: 15px;\r\n}\r\n\r\n.profit-loss-panel input,\r\n.profit-loss-panel select {\r\n  border: 1px solid #a5aeb7;\r\n  border-radius: 0;\r\n  color: #0f1d26;\r\n  font-size: 0.68rem;\r\n  height: 17px;\r\n}\r\n\r\n.profit-loss-panel input[type=\"checkbox\"],\r\n.profit-loss-panel input[type=\"radio\"] {\r\n  accent-color: #0b4360;\r\n  height: 11px;\r\n  margin: 0;\r\n  width: 11px;\r\n}\r\n\r\n.profit-loss-radio-line select,\r\n.profit-loss-field-line select {\r\n  flex: 1;\r\n}\r\n\r\n.profit-loss-field-line {\r\n  display: grid !important;\r\n  gap: 4px !important;\r\n  grid-template-columns: 126px minmax(0, 1fr);\r\n}\r\n\r\n.profit-loss-field-line span {\r\n  text-align: right;\r\n}\r\n\r\n.profit-loss-field-line input {\r\n  text-align: right;\r\n}\r\n\r\n.profit-loss-checkbox-row {\r\n  align-items: center;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 10px;\r\n}\r\n\r\n.profit-loss-file-line {\r\n  align-items: center;\r\n  display: grid;\r\n  gap: 5px;\r\n  grid-template-columns: 70px minmax(0, 1fr);\r\n}\r\n\r\n.profit-loss-entity-panel,\r\n.profit-loss-store-panel {\r\n  min-height: 104px;\r\n}\r\n\r\n.profit-loss-panel table {\r\n  border-collapse: collapse;\r\n  font-size: 0.68rem;\r\n  width: 100%;\r\n}\r\n\r\n.profit-loss-panel th {\r\n  background: #063f5e;\r\n  border-right: 1px solid #9fb0bc;\r\n  color: #fff;\r\n  font-size: 0.66rem;\r\n  padding: 2px;\r\n}\r\n\r\n.profit-loss-panel td {\r\n  background: #e6e8eb;\r\n  border-bottom: 1px solid #aab0b6;\r\n  border-right: 1px solid #aab0b6;\r\n  padding: 1px 3px;\r\n}\r\n\r\n.profit-loss-panel tbody tr:first-child td {\r\n  background: #b5c6d6;\r\n}\r\n\r\n.profit-loss-preview-window {\r\n  background: #e8f4f4;\r\n  border-top: 1px solid #9fb4ba;\r\n  display: flex;\r\n  flex: 1;\r\n  flex-direction: column;\r\n  min-height: 0;\r\n}\r\n\r\n.profit-loss-preview-toolbar {\r\n  align-items: center;\r\n  background: #f2f2cf;\r\n  border-bottom: 1px solid #a9b1b6;\r\n  color: #111;\r\n  display: flex;\r\n  font-size: 0.68rem;\r\n  gap: 8px;\r\n  min-height: 24px;\r\n  padding: 2px 6px;\r\n}\r\n\r\n.profit-loss-preview-toolbar input {\r\n  border: 1px solid #9ca8b0;\r\n  font-size: 0.68rem;\r\n  height: 16px;\r\n  text-align: center;\r\n  width: 24px;\r\n}\r\n\r\n.profit-loss-preview-pages {\r\n  margin-left: auto;\r\n  padding-right: 10px;\r\n}\r\n\r\n.profit-loss-report-page {\r\n  background: #fff;\r\n  border: 1px solid #7f8b96;\r\n  box-shadow: 0 1px 2px rgba(0,0,0,0.24);\r\n  color: #111;\r\n  flex: 1;\r\n  margin: 8px 16px 14px 36px;\r\n  min-height: 0;\r\n  overflow: auto;\r\n  padding: 88px 82px 60px;\r\n}\r\n\r\n.profit-loss-report-header {\r\n  align-items: flex-start;\r\n  display: grid;\r\n  grid-template-columns: 1fr 1fr;\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.profit-loss-report-header > strong {\r\n  font-size: 1.45rem;\r\n  justify-self: center;\r\n}\r\n\r\n.profit-loss-report-header div {\r\n  text-align: center;\r\n}\r\n\r\n.profit-loss-report-header h2 {\r\n  font-size: 1.35rem;\r\n  margin: 0 0 8px;\r\n}\r\n\r\n.profit-loss-report-header p {\r\n  font-size: 0.98rem;\r\n  margin: 4px 0;\r\n}\r\n\r\n.profit-loss-report-page > h3 {\r\n  font-size: 1.14rem;\r\n  margin: 0 0 8px;\r\n  text-align: center;\r\n}\r\n\r\n.profit-loss-report-table {\r\n  border-collapse: collapse;\r\n  font-size: 0.94rem;\r\n  width: 100%;\r\n}\r\n\r\n.profit-loss-report-table th {\r\n  background: #cfcfcf;\r\n  color: #111;\r\n  font-weight: 500;\r\n  padding: 5px;\r\n  text-align: left;\r\n}\r\n\r\n.profit-loss-report-table th:last-child,\r\n.profit-loss-report-table td:last-child {\r\n  text-align: right;\r\n}\r\n\r\n.profit-loss-report-table td {\r\n  border-bottom: 1px solid #ededed;\r\n  padding: 4px 5px;\r\n}\r\n\r\n.profit-loss-report-table tr.is-total td {\r\n  border-top: 1px solid #b7b7b7;\r\n  font-weight: 800;\r\n}\r\n\r\n.profit-loss-shell.is-compact {\r\n  background: #dbe5e9;\r\n}\r\n\r\n.profit-loss-title-actions button.is-primary {\r\n  background: linear-gradient(#fffdf6, #ffca8f 58%, #d75f24);\r\n  border-color: #8f3c19;\r\n  color: #351304;\r\n  min-width: 96px;\r\n}\r\n\r\n.profit-loss-command-strip {\r\n  align-items: center;\r\n  background: linear-gradient(#17394a, #0d2d40);\r\n  border-bottom: 1px solid #071f2e;\r\n  color: #f4fbff;\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: minmax(360px, 1fr) 120px 82px 160px 120px auto;\r\n  min-height: 42px;\r\n  padding: 5px 8px;\r\n}\r\n\r\n.profit-loss-command-strip label {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 5px;\r\n  min-width: 0;\r\n}\r\n\r\n.profit-loss-command-strip label span,\r\n.profit-loss-store-picker summary {\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  white-space: nowrap;\r\n}\r\n\r\n.profit-loss-command-strip select {\r\n  background: #fff;\r\n  border: 1px solid #8294a2;\r\n  border-radius: 0;\r\n  color: #0e2637;\r\n  font-size: 0.7rem;\r\n  height: 20px;\r\n  min-width: 0;\r\n  width: 100%;\r\n}\r\n\r\n.profit-loss-department-pills {\r\n  display: flex;\r\n  gap: 4px;\r\n  min-width: 0;\r\n}\r\n\r\n.profit-loss-department-pills button {\r\n  background: rgba(255,255,255,0.12);\r\n  border: 1px solid rgba(255,255,255,0.22);\r\n  color: #eaf7ff;\r\n  font-size: 0.68rem;\r\n  font-weight: 800;\r\n  min-height: 22px;\r\n  padding: 0 8px;\r\n  white-space: nowrap;\r\n}\r\n\r\n.profit-loss-department-pills button.is-active {\r\n  background: #f3fbff;\r\n  border-color: #fff;\r\n  color: #0c354d;\r\n}\r\n\r\n.profit-loss-store-picker {\r\n  position: relative;\r\n}\r\n\r\n.profit-loss-store-picker summary {\r\n  background: rgba(255,255,255,0.13);\r\n  border: 1px solid rgba(255,255,255,0.24);\r\n  color: #fff;\r\n  cursor: pointer;\r\n  list-style: none;\r\n  min-height: 22px;\r\n  padding: 3px 8px;\r\n}\r\n\r\n.profit-loss-store-picker summary::-webkit-details-marker {\r\n  display: none;\r\n}\r\n\r\n.profit-loss-store-menu {\r\n  background: #f4f7f9;\r\n  border: 1px solid #657783;\r\n  box-shadow: 0 8px 18px rgba(0,0,0,0.22);\r\n  color: #0e2637;\r\n  display: grid;\r\n  gap: 2px;\r\n  left: 0;\r\n  min-width: 180px;\r\n  padding: 6px;\r\n  position: absolute;\r\n  top: calc(100% + 2px);\r\n  z-index: 20;\r\n}\r\n\r\n.profit-loss-store-menu label {\r\n  display: flex;\r\n  font-size: 0.7rem;\r\n  gap: 5px;\r\n}\r\n\r\n.profit-loss-account-toggle {\r\n  justify-content: end;\r\n}\r\n\r\n.profit-loss-account-toggle input,\r\n.profit-loss-store-menu input {\r\n  accent-color: #0b4360;\r\n}\r\n\r\n.profit-loss-summary-strip {\r\n  background: #edf2f5;\r\n  border-bottom: 1px solid #9baab4;\r\n  display: grid;\r\n  gap: 6px;\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n  padding: 6px 8px;\r\n}\r\n\r\n.profit-loss-summary-card {\r\n  background: #fff;\r\n  border: 1px solid #bdc9d0;\r\n  border-left: 4px solid #6f8795;\r\n  display: grid;\r\n  gap: 2px;\r\n  min-height: 48px;\r\n  padding: 5px 8px;\r\n}\r\n\r\n.profit-loss-summary-card.tone-stable {\r\n  border-left-color: #188a5c;\r\n}\r\n\r\n.profit-loss-summary-card.tone-attention {\r\n  border-left-color: #c75a27;\r\n}\r\n\r\n.profit-loss-summary-card span {\r\n  color: #526978;\r\n  font-size: 0.66rem;\r\n  font-weight: 800;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.profit-loss-summary-card strong {\r\n  color: #0e2637;\r\n  font-size: 1rem;\r\n}\r\n\r\n.profit-loss-summary-card small {\r\n  color: #5d7482;\r\n  font-size: 0.68rem;\r\n}\r\n\r\n.profit-loss-preview-window.is-report-first {\r\n  border-top: 0;\r\n}\r\n\r\n.profit-loss-report-stage {\r\n  display: grid;\r\n  flex: 1;\r\n  grid-template-columns: minmax(0, 1fr);\r\n  min-height: 0;\r\n  overflow: hidden;\r\n}\r\n\r\n.profit-loss-report-stage.has-detail {\r\n  grid-template-columns: minmax(0, 1fr) 260px;\r\n}\r\n\r\n.profit-loss-report-main {\r\n  display: flex;\r\n  flex-direction: column;\r\n  min-height: 0;\r\n  min-width: 0;\r\n  overflow: auto;\r\n}\r\n\r\n.profit-loss-report-stage .profit-loss-report-page {\r\n  margin: 8px 10px 12px 28px;\r\n  padding: 44px 58px 38px;\r\n}\r\n\r\n.profit-loss-report-table-shell {\r\n  max-height: 100%;\r\n  overflow: visible;\r\n}\r\n\r\n.profit-loss-report-table.is-collapsible thead {\r\n  position: sticky;\r\n  top: 0;\r\n  z-index: 3;\r\n}\r\n\r\n.profit-loss-report-table.is-collapsible tbody tr {\r\n  cursor: pointer;\r\n}\r\n\r\n.profit-loss-report-table.is-collapsible tr.is-selected td {\r\n  background: #d7e8f3;\r\n}\r\n\r\n.profit-loss-group-row td {\r\n  background: #e3e8ec !important;\r\n  border-bottom: 1px solid #b1bac0;\r\n  padding: 0 !important;\r\n}\r\n\r\n.profit-loss-group-row button {\r\n  align-items: center;\r\n  background: transparent;\r\n  border: 0;\r\n  color: #0e2637;\r\n  display: grid;\r\n  font-size: 0.82rem;\r\n  gap: 8px;\r\n  grid-template-columns: 18px 1fr auto;\r\n  min-height: 26px;\r\n  padding: 3px 6px;\r\n  text-align: left;\r\n  width: 100%;\r\n}\r\n\r\n.profit-loss-group-row button span {\r\n  background: #0b4360;\r\n  color: #fff;\r\n  display: inline-grid;\r\n  font-weight: 900;\r\n  height: 16px;\r\n  place-items: center;\r\n  width: 16px;\r\n}\r\n\r\n.profit-loss-group-row button em {\r\n  font-style: normal;\r\n  font-weight: 900;\r\n}\r\n\r\n.profit-loss-account-detail {\r\n  background: #eef3f6;\r\n  border-left: 2px solid #0b4360;\r\n  color: #0e2637;\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-auto-rows: max-content;\r\n  min-height: 0;\r\n  overflow: auto;\r\n  padding: 10px;\r\n}\r\n\r\n.profit-loss-account-detail > span,\r\n.profit-loss-account-detail-header span {\r\n  color: #315168;\r\n  font-size: 0.66rem;\r\n  font-weight: 900;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.profit-loss-account-detail strong {\r\n  font-size: 0.9rem;\r\n}\r\n\r\n.profit-loss-account-detail p {\r\n  color: #415968;\r\n  font-size: 0.74rem;\r\n  line-height: 1.35;\r\n  margin: 0;\r\n}\r\n\r\n.profit-loss-account-detail-header {\r\n  align-items: center;\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.profit-loss-account-detail-header button {\r\n  background: #0b4360;\r\n  border: 1px solid #062a3d;\r\n  color: #fff;\r\n  font-size: 0.66rem;\r\n  font-weight: 800;\r\n  min-height: 22px;\r\n}\r\n\r\n.profit-loss-account-transactions {\r\n  background: #fff;\r\n  border: 1px solid #bdc8cf;\r\n  display: grid;\r\n  gap: 4px;\r\n  padding: 8px;\r\n}\r\n\r\n.profit-loss-account-transactions span {\r\n  color: #315168;\r\n  font-size: 0.66rem;\r\n  font-weight: 900;\r\n  text-transform: uppercase;\r\n}\r\n\r\n.legacy-schema-health-panel { align-items: center; background: rgba(123,204,160,0.08); border: 1px solid rgba(123,204,160,0.24); border-radius: 9px; display: flex; justify-content: space-between; gap: 12px; margin: 10px 0; padding: 10px 12px; }\r\n\r\n.legacy-schema-health-panel span { color: rgba(255,255,255,0.55); display: block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }\r\n\r\n.legacy-schema-health-panel strong { display: block; font-size: 0.9rem; }\r\n\r\n.legacy-schema-health-panel small { color: rgba(255,255,255,0.55); display: block; font-size: 0.72rem; }\r\n\r\n.legacy-user-admin-table-wrap { border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; overflow: auto; }\r\n\r\n.legacy-user-admin-form { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; margin-top: 12px; padding: 12px; }\r\n\r\n.legacy-crm-pipeline { display: grid; gap: 10px; grid-template-columns: repeat(6, minmax(140px, 1fr)); overflow-x: auto; }\r\n\r\n.legacy-crm-stage { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; min-height: 150px; padding: 8px; }\r\n\r\n.legacy-crm-stage h4 { color: rgba(255,255,255,0.64); font-size: 0.76rem; margin: 0 0 8px; }\r\n\r\n.legacy-crm-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; color: inherit; display: grid; gap: 3px; margin-bottom: 6px; padding: 8px; text-align: left; width: 100%; }\r\n\r\n.legacy-crm-card strong { font-size: 0.82rem; }\r\n\r\n.legacy-crm-card span,\r\n.legacy-crm-card small { color: rgba(255,255,255,0.55); font-size: 0.72rem; }\r\n\r\n.legacy-crm-detail { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; margin-top: 10px; padding: 10px; }\r\n\r\n.legacy-crm-detail h3 { margin: 0; }\r\n\r\n.legacy-crm-timeline { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 8px; }\r\n\r\n.legacy-crm-timeline span { background: rgba(255,255,255,0.06); border-radius: 999px; color: rgba(255,255,255,0.68); font-size: 0.72rem; padding: 4px 8px; }\r\n\r\n.legacy-crm-form { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; margin-top: 10px; padding: 12px; }\r\n\r\n.legacy-fi-products-library { padding: 16px; }\r\n\r\n.legacy-fi-products-deal { border-bottom: 1px solid rgba(255,255,255,0.08); margin-bottom: 10px; padding-bottom: 10px; }\r\n\r\n.legacy-fi-products-list { display: grid; gap: 6px; }\r\n\r\n.legacy-fi-products-option { align-items: center; background: rgba(255,255,255,0.045); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; display: flex; gap: 8px; padding: 7px; }\r\n\r\n.legacy-fi-products-option.is-selected { border-color: rgba(123,204,160,0.6); box-shadow: inset 3px 0 0 #7bcca0; }\r\n\r\n.legacy-fi-products-option span { display: grid; }\r\n\r\n.legacy-fi-products-option small { color: rgba(255,255,255,0.52); font-size: 0.72rem; }\r\n\r\n.legacy-fi-products-totals { display: flex; gap: 10px; margin-top: 8px; }\r\n\r\n.legacy-fi-products-totals span { background: rgba(255,255,255,0.06); border-radius: 8px; color: rgba(255,255,255,0.6); font-size: 0.75rem; padding: 6px 8px; }\r\n\r\n.legacy-fi-products-totals strong { color: rgba(255,255,255,0.92); margin-left: 4px; }\r\n\r\n.legacy-report-real-panel { padding: 10px 0; }\r\n\r\n@media (max-width: 1100px) {\r\n  .legacy-boat-inventory-summary { grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n  .legacy-boat-inventory-layout { grid-template-columns: 1fr; }\r\n  .legacy-crm-pipeline { grid-template-columns: repeat(3, minmax(150px, 1fr)); }\r\n  .chart-accounts-body { grid-template-columns: 1fr; }\r\n  .chart-accounts-detail { border-left: 0; border-top: 2px solid #0b4360; }\r\n}\r\n\r\n/* Sprint 10 */\r\n\r\n.legacy-error-boundary { align-items: center; display: flex; flex-direction: column; gap: 12px; justify-content: center; min-height: 200px; padding: 32px; text-align: center; }\r\n\r\n.legacy-error-boundary-icon { font-size: 2rem; }\r\n\r\n.legacy-error-boundary-title { font-size: 1rem; font-weight: 700; }\r\n\r\n.legacy-error-boundary-detail { color: rgba(255,255,255,0.5); font-size: 0.82rem; max-width: 320px; }\r\n\r\n.legacy-empty-state { align-items: center; color: rgba(255,255,255,0.45); display: flex; flex-direction: column; gap: 8px; justify-content: center; min-height: 160px; padding: 24px; text-align: center; }\r\n\r\n.legacy-empty-state-icon { font-size: 1.8rem; opacity: 0.5; }\r\n\r\n.legacy-empty-state-title { color: rgba(255,255,255,0.6); font-size: 0.9rem; font-weight: 600; }\r\n\r\n.legacy-empty-state-detail { font-size: 0.78rem; max-width: 280px; }\r\n\r\n.legacy-parts-to-po-panel { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; display: grid; gap: 10px; margin-top: 10px; padding: 14px; }\r\n\r\n.legacy-parts-to-po-header { align-items: center; display: flex; font-size: 0.85rem; font-weight: 700; gap: 8px; justify-content: space-between; }\r\n\r\n.legacy-parts-to-po-meta { color: rgba(255,255,255,0.55); display: flex; flex-wrap: wrap; font-size: 0.8rem; gap: 10px; }\r\n\r\n.legacy-parts-to-po-form { display: grid; gap: 8px; grid-template-columns: 1fr 1fr 1fr; }\r\n\r\n.legacy-global-search-api-results { border-top: 1px solid rgba(255,255,255,0.08); margin-top: 8px; padding-top: 8px; }\r\n\r\n.legacy-global-search-section-label { color: rgba(255,255,255,0.4); font-size: 0.72rem; margin-bottom: 4px; text-transform: uppercase; }\r\n\r\n.legacy-global-search-api-row { color: rgba(255,255,255,0.7); font-size: 0.82rem; padding: 2px 0; }\r\n\r\n.legacy-invoice-print-area { }\r\n\r\n.legacy-parts-po-panel { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; margin-top: 10px; padding: 12px; }\r\n\r\n.legacy-parts-po-header { align-items: center; display: flex; font-size: 0.83rem; font-weight: 700; gap: 8px; justify-content: space-between; margin-bottom: 10px; }\r\n\r\n.legacy-parts-po-table { border-collapse: collapse; font-size: 0.78rem; width: 100%; }\r\n\r\n.legacy-parts-po-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.45); font-size: 0.7rem; font-weight: 700; padding: 5px 8px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-parts-po-table td { border-top: 1px solid rgba(255,255,255,0.06); padding: 5px 8px; }\r\n\r\n/* ── Profit & Loss enhanced: view tabs, charts, forecast, ops ─────────────── */\r\n\r\n.pl-title-left { align-items: center; display: flex; gap: 10px; }\r\n\r\n.pl-score-ring-wrap { align-items: center; background: rgba(255,255,255,0.16); border: 1px solid rgba(255,255,255,0.24); border-radius: 999px; color: #22c55e; display: flex; gap: 4px; padding: 1px 7px 1px 2px; }\r\n\r\n.pl-score-ring-wrap span { font-size: 0.58rem; font-weight: 900; text-shadow: 0 1px 0 rgba(0,0,0,0.25); }\r\n\r\n.pl-score-ring-wrap.is-excellent { color: #22c55e; }\r\n\r\n.pl-score-ring-wrap.is-healthy { color: #0d9488; }\r\n\r\n.pl-score-ring-wrap.is-moderate { color: #f59e0b; }\r\n\r\n.pl-score-ring-wrap.is-low { color: #f97316; }\r\n\r\n.pl-score-ring-wrap.is-loss { color: #ef4444; }\r\n\r\n.pl-view-tabs { background: #e4ecf0; border-bottom: 1px solid #9baab4; display: flex; gap: 0; }\r\n\r\n.pl-view-tabs button { background: transparent; border: 0; border-bottom: 3px solid transparent; color: #4a6372; font-size: 0.72rem; font-weight: 800; min-height: 32px; padding: 0 16px; }\r\n\r\n.pl-view-tabs button.is-active { border-bottom-color: #0b4360; color: #0b4360; }\r\n\r\n.pl-summary-card-head { align-items: center; display: flex; gap: 8px; justify-content: space-between; }\r\n\r\n.pl-summary-card-foot { align-items: end; display: flex; gap: 8px; justify-content: space-between; }\r\n\r\n.pl-summary-delta { border-radius: 999px; font-size: 0.6rem; font-weight: 900; padding: 2px 6px; }\r\n\r\n.pl-summary-delta.is-favorable { background: #dcfce7; color: #166534; }\r\n\r\n.pl-summary-delta.is-risk { background: #fee2e2; color: #991b1b; }\r\n\r\n.pl-summary-delta.is-neutral { background: #e2e8f0; color: #475569; }\r\n\r\n.pl-sparkline { flex: 0 0 78px; }\r\n\r\n.pl-analysis-board { background: #f2f6f8; border-bottom: 1px solid #c5d1d8; display: grid; gap: 10px; grid-template-columns: 1.2fr 1fr; padding: 10px 12px; }\r\n\r\n.pl-analysis-panel { background: #fff; border: 1px solid #cdd8df; border-radius: 6px; display: grid; gap: 10px; min-width: 0; padding: 10px 12px; }\r\n\r\n.pl-analysis-header { align-items: start; display: flex; gap: 10px; justify-content: space-between; }\r\n\r\n.pl-analysis-header strong { color: #0e2637; display: block; font-size: 0.8rem; }\r\n\r\n.pl-analysis-header span { color: #5d7482; display: block; font-size: 0.7rem; margin-top: 2px; }\r\n\r\n.pl-analysis-header button { background: #edf2f5; border: 1px solid #c6d3da; color: #0b4360; font-size: 0.68rem; font-weight: 800; min-height: 28px; padding: 0 10px; }\r\n\r\n.pl-variance-matrix { overflow: auto; }\r\n\r\n.pl-variance-matrix table { border-collapse: collapse; width: 100%; }\r\n\r\n.pl-variance-matrix th { color: #5d7482; font-size: 0.66rem; font-weight: 900; padding: 0 0 8px; text-align: left; text-transform: uppercase; }\r\n\r\n.pl-variance-matrix td { border-top: 1px solid #e2e8f0; color: #0e2637; font-size: 0.74rem; padding: 8px 0; vertical-align: top; }\r\n\r\n.pl-variance-row { cursor: pointer; }\r\n\r\n.pl-variance-row:hover td { background: #f8fafc; }\r\n\r\n.pl-variance-matrix td strong { display: block; font-size: 0.76rem; }\r\n\r\n.pl-variance-matrix td small { color: #64748b; display: block; font-size: 0.66rem; line-height: 1.35; margin-top: 3px; max-width: 220px; }\r\n\r\n.pl-variance-pill { border-radius: 999px; display: inline-block; font-size: 0.66rem; font-weight: 900; min-width: 64px; padding: 4px 8px; text-align: center; }\r\n\r\n.pl-variance-pill.is-favorable { background: #dcfce7; color: #166534; }\r\n\r\n.pl-variance-pill.is-risk { background: #fee2e2; color: #991b1b; }\r\n\r\n.pl-variance-pill.is-neutral { background: #e2e8f0; color: #475569; }\r\n\r\n.pl-driver-stack { display: grid; gap: 8px; grid-template-columns: repeat(5, minmax(0, 1fr)); }\r\n\r\n.pl-driver-chip { background: #f8fafc; border: 1px solid #d9e3ea; border-radius: 5px; display: grid; gap: 4px; padding: 8px; }\r\n\r\n.pl-driver-chip span { color: #64748b; font-size: 0.64rem; font-weight: 900; text-transform: uppercase; }\r\n\r\n.pl-driver-chip strong { color: #0e2637; font-size: 0.8rem; }\r\n\r\n.pl-driver-chip.is-up { border-color: #bbf7d0; background: #f0fdf4; }\r\n\r\n.pl-driver-chip.is-down { border-color: #fecaca; background: #fff7f7; }\r\n\r\n.pl-analysis-note { background: linear-gradient(135deg, #eff6ff, #f8fafc); border: 1px solid #dbeafe; border-radius: 5px; display: grid; gap: 3px; padding: 8px 10px; }\r\n\r\n.pl-analysis-note strong { color: #0f172a; font-size: 0.76rem; }\r\n\r\n.pl-analysis-note span { color: #475569; font-size: 0.68rem; }\r\n\r\n.pl-chart-type-tabs { border-bottom: 1px solid #c9d5dc; display: flex; gap: 0; margin-bottom: 8px; }\r\n\r\n.pl-chart-type-tabs button { background: transparent; border: 0; border-bottom: 2px solid transparent; color: #526978; font-size: 0.7rem; font-weight: 700; min-height: 28px; padding: 0 12px; }\r\n\r\n.pl-chart-type-tabs button.is-active { border-bottom-color: #3b82f6; color: #1e3a5f; }\r\n\r\n.pl-charts-view { display: flex; flex: 1; flex-direction: column; min-height: 0; overflow: auto; padding: 12px 16px; }\r\n\r\n.pl-chart-frame { background: #fff; border: 1px solid #cdd8df; border-radius: 4px; flex: 1; min-height: 260px; overflow: hidden; padding: 8px; }\r\n\r\n.pl-chart-svg { display: block; height: 100%; width: 100%; }\r\n\r\n.pl-chart-ya { fill: #526978; font-size: 9px; }\r\n\r\n.pl-chart-xa { fill: #526978; font-size: 9px; }\r\n\r\n.pl-chart-legend { fill: #0e2637; font-size: 9px; }\r\n\r\n.pl-forecast-view { display: flex; flex-direction: column; flex: 1; gap: 10px; min-height: 0; overflow: auto; padding: 12px 16px; }\r\n\r\n.pl-scenario-lab { background: #fff; border: 1px solid #cdd8df; border-radius: 6px; display: grid; gap: 12px; padding: 12px; }\r\n\r\n.pl-scenario-grid { display: grid; gap: 10px; grid-template-columns: repeat(4, minmax(0, 1fr)); }\r\n\r\n.pl-scenario-card { background: linear-gradient(180deg, #ffffff, #f8fafc); border: 1px solid #d4dee5; border-left: 4px solid #0b4360; border-radius: 6px; display: grid; gap: 6px; padding: 10px; text-align: left; }\r\n\r\n.pl-scenario-card.is-active { box-shadow: inset 0 0 0 1px #0b4360; transform: translateY(-1px); }\r\n\r\n.pl-scenario-card strong { color: #0f172a; font-size: 0.78rem; }\r\n\r\n.pl-scenario-card span { color: #4b5f6d; font-size: 0.7rem; line-height: 1.4; }\r\n\r\n.pl-scenario-card small { color: #5d7482; font-size: 0.66rem; }\r\n\r\n.pl-scenario-card.tone-current { border-left-color: #0b4360; }\r\n\r\n.pl-scenario-card.tone-board { border-left-color: #1d4ed8; }\r\n\r\n.pl-scenario-card.tone-conservative { border-left-color: #9a3412; }\r\n\r\n.pl-scenario-card.tone-summerPush { border-left-color: #0f766e; }\r\n\r\n.pl-driver-controls { display: grid; gap: 12px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.pl-driver-controls label { background: #f8fafc; border: 1px solid #d9e3ea; border-radius: 6px; display: grid; gap: 6px; padding: 10px; }\r\n\r\n.pl-driver-controls span { color: #64748b; font-size: 0.66rem; font-weight: 900; text-transform: uppercase; }\r\n\r\n.pl-driver-controls strong { color: #0e2637; font-size: 0.82rem; }\r\n\r\n.pl-driver-controls input { accent-color: #0b4360; width: 100%; }\r\n\r\n.pl-forecast-summary { display: grid; gap: 8px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.pl-forecast-card { background: #fff; border: 1px solid #c8d5dc; border-left: 4px solid #16a34a; display: grid; gap: 2px; padding: 8px 10px; }\r\n\r\n.pl-forecast-card span { color: #526978; font-size: 0.66rem; font-weight: 800; text-transform: uppercase; }\r\n\r\n.pl-forecast-card strong { color: #0e2637; font-size: 1rem; }\r\n\r\n.pl-forecast-card small { color: #5d7482; font-size: 0.68rem; }\r\n\r\n.pl-forecast-table tr.is-forecast-row td { background: #f0fdf4; color: #166534; font-style: italic; }\r\n\r\n.pl-commentary-banner { background: #fffbeb; border: 1px solid #fde68a; border-radius: 4px; color: #78350f; font-size: 0.76rem; margin: 8px 10px 0; padding: 6px 10px; }\r\n\r\n.pl-commentary-toggle { background: transparent; border: 0; color: #92400e; cursor: pointer; font-size: 0.7rem; font-weight: 800; padding: 0; }\r\n\r\n.pl-commentary-banner ul { margin: 4px 0 0 14px; padding: 0; }\r\n\r\n.pl-commentary-banner li { line-height: 1.5; }\r\n\r\n.pl-anomaly-tag { border-radius: 3px; font-size: 0.62rem; font-weight: 800; margin-left: 5px; padding: 1px 4px; }\r\n\r\n.pl-anomaly-tag.is-up { background: #dcfce7; color: #166534; }\r\n\r\n.pl-anomaly-tag.is-down { background: #fee2e2; color: #991b1b; }\r\n\r\n.profit-loss-report-table td.is-up { color: #166534; font-weight: 700; }\r\n\r\n.profit-loss-report-table td.is-down { color: #991b1b; font-weight: 700; }\r\n\r\n.pl-acct-compare { color: #315168; font-size: 0.74rem; }\r\n\r\n.pl-acct-alert { background: #fff7ed; border: 1px solid #fed7aa; border-radius: 3px; color: #9a3412; font-size: 0.72rem; padding: 5px 7px; }\r\n\r\n.pl-account-kpi-grid { display: grid; gap: 8px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.pl-account-kpi { background: #fff; border: 1px solid #d5dde3; border-radius: 5px; display: grid; gap: 3px; padding: 8px; }\r\n\r\n.pl-account-kpi span { color: #64748b; font-size: 0.63rem; font-weight: 900; text-transform: uppercase; }\r\n\r\n.pl-account-kpi strong { color: #0f172a; font-size: 0.75rem; }\r\n\r\n.pl-account-store-list { background: #fff; border: 1px solid #d5dde3; display: grid; gap: 6px; padding: 8px; }\r\n\r\n.pl-account-store-list > span { color: #315168; font-size: 0.66rem; font-weight: 900; text-transform: uppercase; }\r\n\r\n.pl-account-store-item { display: grid; gap: 2px; }\r\n\r\n.pl-account-store-item strong { font-size: 0.76rem; }\r\n\r\n.pl-account-store-item small { color: #5d7482; font-size: 0.68rem; }\r\n\r\n.pl-account-transaction-list { display: grid; gap: 6px; }\r\n\r\n.pl-account-transaction-item { background: #f8fafc; border: 1px solid #dbe4ea; border-radius: 5px; display: grid; gap: 4px; padding: 8px; }\r\n\r\n.pl-account-transaction-item > div { display: flex; gap: 8px; justify-content: space-between; }\r\n\r\n.pl-account-transaction-item small,\r\n.pl-account-transaction-item span { color: #5d7482; font-size: 0.68rem; }\r\n\r\n.pl-account-transaction-item strong { color: #0f172a; font-size: 0.74rem; }\r\n\r\n.pl-snapshot-board { background: #fff; border: 1px solid #cdd8df; border-radius: 6px; display: grid; gap: 10px; padding: 12px; }\r\n\r\n.pl-snapshot-list { display: grid; gap: 10px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.pl-snapshot-card { background: linear-gradient(180deg, #ffffff, #f8fafc); border: 1px solid #d4dee5; border-left: 4px solid #0b4360; border-radius: 6px; display: grid; gap: 6px; padding: 10px; }\r\n\r\n.pl-snapshot-card.is-active { box-shadow: inset 0 0 0 1px #0b4360; }\r\n\r\n.pl-snapshot-card strong { color: #0f172a; font-size: 0.78rem; }\r\n\r\n.pl-snapshot-card span { color: #4b5f6d; font-size: 0.69rem; }\r\n\r\n.pl-snapshot-card small { color: #64748b; font-size: 0.68rem; }\r\n\r\n.pl-snapshot-metrics { display: flex; flex-wrap: wrap; gap: 8px; }\r\n\r\n.pl-snapshot-metrics span { background: #eff6ff; border-radius: 999px; color: #1d4ed8; font-size: 0.64rem; font-weight: 800; padding: 4px 8px; }\r\n\r\n.pl-snapshot-actions { display: flex; gap: 8px; }\r\n\r\n.pl-snapshot-actions button { background: #edf2f5; border: 1px solid #c6d3da; color: #0b4360; font-size: 0.67rem; font-weight: 800; min-height: 26px; padding: 0 10px; }\r\n\r\n.pl-snapshot-empty { color: #64748b; font-size: 0.72rem; margin: 0; }\r\n\r\n.pl-title-left { min-width: 0; }\r\n\r\n.pl-title-copy { display: grid; gap: 2px; }\r\n\r\n.pl-title-copy strong { color: #0f172a; font-size: 1rem; letter-spacing: 0.01em; }\r\n\r\n.pl-title-copy span { color: #4f6a7a; font-size: 0.72rem; font-weight: 700; }\r\n\r\n.pl-report-toolbar { align-items: center; background: linear-gradient(180deg, #f8fbfd, #e8f0f4); border: 1px solid #d1dde4; border-radius: 10px; display: flex; flex-wrap: wrap; gap: 12px; padding: 10px 12px; }\r\n\r\n.pl-report-toolbar-group { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; }\r\n\r\n.pl-report-toolbar-group.is-layout-toggle { margin-left: auto; }\r\n\r\n.pl-report-toolbar-group > span { color: #526978; font-size: 0.67rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }\r\n\r\n.pl-report-toolbar-group button { background: #fff; border: 1px solid #c8d5dc; border-radius: 999px; color: #355166; font-size: 0.68rem; font-weight: 800; min-height: 30px; padding: 0 12px; }\r\n\r\n.pl-report-toolbar-group button.is-active { background: linear-gradient(135deg, #0b4360, #2563eb); border-color: #0b4360; box-shadow: 0 8px 20px rgba(37,99,235,0.18); color: #fff; }\r\n\r\n.pl-power-section-header { align-items: center; display: flex; gap: 14px; justify-content: space-between; }\r\n\r\n.pl-power-section-copy { display: grid; gap: 3px; }\r\n\r\n.pl-power-section-copy strong { color: #0f172a; font-size: 0.84rem; }\r\n\r\n.pl-power-section-copy span { color: #64748b; font-size: 0.72rem; line-height: 1.4; }\r\n\r\n.pl-power-section-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }\r\n\r\n.pl-power-section-actions small { color: #607889; font-size: 0.68rem; font-weight: 800; }\r\n\r\n.pl-focus-widget-switcher { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; }\r\n\r\n.pl-focus-widget-switcher button { background: #fff; border: 1px solid #c8d5dc; border-radius: 999px; color: #355166; font-size: 0.66rem; font-weight: 800; min-height: 30px; padding: 0 11px; }\r\n\r\n.pl-focus-widget-switcher button.is-active { background: linear-gradient(135deg, #0b4360, #2563eb); border-color: #0b4360; color: #fff; }\r\n\r\n.pl-power-kpi-strip { display: grid; gap: 10px; grid-template-columns: repeat(4, minmax(0, 1fr)); }\r\n\r\n.pl-power-kpi-card { background: linear-gradient(180deg, #ffffff, #f6fafc); border: 1px solid #d4dee5; border-radius: 10px; box-shadow: 0 10px 24px rgba(15,23,42,0.05); display: grid; gap: 4px; padding: 12px; }\r\n\r\n.pl-power-kpi-card span { color: #607889; font-size: 0.66rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }\r\n\r\n.pl-power-kpi-card strong { color: #0f172a; font-size: 1.05rem; }\r\n\r\n.pl-power-kpi-card small { color: #64748b; font-size: 0.7rem; line-height: 1.4; }\r\n\r\n.pl-power-kpi-card-foot { align-items: end; display: flex; gap: 10px; justify-content: space-between; }\r\n\r\n.pl-power-kpi-card-foot small { flex: 1 1 auto; }\r\n\r\n.pl-sparkline { flex: 0 0 78px; height: 24px; width: 78px; }\r\n\r\n.pl-charts-view,\r\n.pl-forecast-view { display: flex; flex: 1; flex-direction: column; gap: 12px; min-height: 0; overflow: auto; padding: 14px 16px 18px; }\r\n\r\n.pl-power-focus-layout { display: grid; gap: 12px; grid-template-columns: minmax(0, 1.7fr) minmax(280px, 1fr); align-items: start; }\r\n\r\n.pl-power-grid { display: grid; gap: 12px; grid-template-columns: repeat(2, minmax(0, 1fr)); align-items: start; }\r\n\r\n.pl-power-grid.is-dense { gap: 10px; grid-template-columns: repeat(4, minmax(0, 1fr)); }\r\n\r\n.pl-power-grid.is-report-pack { grid-template-columns: repeat(12, minmax(0, 1fr)); }\r\n\r\n.pl-power-grid.is-report-pack > * { grid-column: span 6; }\r\n\r\n.pl-power-grid.is-dense.is-report-pack { grid-template-columns: repeat(4, minmax(0, 1fr)); }\r\n\r\n.pl-power-grid.is-dense.is-report-pack > * { grid-column: auto; }\r\n\r\n.pl-power-panel { background: linear-gradient(180deg, #ffffff, #f8fbfd); border: 1px solid #d4dee5; border-radius: 10px; box-shadow: 0 14px 32px rgba(15,23,42,0.06); display: grid; gap: 12px; min-width: 0; padding: 14px; }\r\n\r\n.pl-power-panel.is-span-2 { grid-column: span 2; }\r\n\r\n.pl-widget-metrics-grid { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.pl-power-grid.is-report-pack .pl-power-panel.is-span-2 { grid-column: span 12; }\r\n\r\n.pl-power-side-stack { display: grid; gap: 12px; }\r\n\r\n.pl-power-grid.is-dense .pl-power-panel { gap: 10px; padding: 12px; }\r\n\r\n.pl-power-panel-header { align-items: start; display: flex; gap: 12px; justify-content: space-between; }\r\n\r\n.pl-power-panel-header strong { color: #0f172a; display: block; font-size: 0.84rem; }\r\n\r\n.pl-power-panel-header span { color: #64748b; display: block; font-size: 0.72rem; line-height: 1.4; margin-top: 2px; }\r\n\r\n.pl-power-panel-header button { background: #edf2f5; border: 1px solid #c6d3da; border-radius: 8px; color: #0b4360; font-size: 0.68rem; font-weight: 800; min-height: 30px; padding: 0 10px; }\r\n\r\n.pl-power-grid.is-dense .pl-power-panel-header { gap: 10px; }\r\n\r\n.pl-power-grid.is-dense .pl-power-panel-header strong { font-size: 0.78rem; }\r\n\r\n.pl-power-grid.is-dense .pl-power-panel-header span { font-size: 0.68rem; }\r\n\r\n.pl-power-panel.is-exporting .pl-widget-actions { visibility: hidden; }\r\n\r\n.pl-chart-frame { background: linear-gradient(180deg, #ffffff, #f8fbfd); border: 1px solid #d7e1e8; border-radius: 10px; flex: 1; min-height: 320px; overflow: hidden; padding: 12px; }\r\n\r\n.pl-chart-frame.is-report-panel { min-height: 360px; }\r\n\r\n.pl-power-grid.is-dense .pl-chart-frame { min-height: 250px; padding: 10px; }\r\n\r\n.pl-power-grid.is-dense .pl-chart-frame.is-report-panel { min-height: 260px; }\r\n\r\n.pl-chart-ya,\r\n.pl-chart-xa,\r\n.pl-chart-legend { font-size: 10px; }\r\n\r\n.pl-widget-delivery-notice { background: linear-gradient(135deg, #eff6ff, #f8fafc); border: 1px solid #bfdbfe; border-radius: 10px; color: #1d4ed8; font-size: 0.74rem; font-weight: 700; padding: 10px 12px; }\r\n\r\n.pl-widget-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; justify-content: flex-end; }\r\n\r\n.pl-widget-action-button { background: #edf2f5; border: 1px solid #c6d3da; border-radius: 999px; color: #0b4360; font-size: 0.67rem; font-weight: 800; min-height: 30px; padding: 0 12px; }\r\n\r\n.pl-power-grid.is-dense .pl-widget-actions { gap: 6px; }\r\n\r\n.pl-power-grid.is-dense .pl-widget-action-button { font-size: 0.62rem; min-height: 26px; padding: 0 9px; }\r\n\r\n.pl-widget-action-button:disabled { cursor: progress; opacity: 0.65; }\r\n\r\n.pl-widget-action-button.is-primary { background: linear-gradient(135deg, #0b4360, #2563eb); border-color: #0b4360; box-shadow: 0 10px 22px rgba(37,99,235,0.18); color: #fff; }\r\n\r\n.pl-widget-select-toggle { align-items: center; background: #f8fbfd; border: 1px solid #d4dee5; border-radius: 999px; color: #355166; display: inline-flex; gap: 6px; min-height: 30px; padding: 0 10px; }\r\n\r\n.pl-widget-select-toggle input { accent-color: #0b4360; }\r\n\r\n.pl-widget-select-toggle span { color: #355166; font-size: 0.66rem; font-weight: 800; margin: 0; }\r\n\r\n.pl-power-grid.is-dense .pl-widget-select-toggle { min-height: 26px; padding: 0 8px; }\r\n\r\n.pl-power-grid.is-dense .pl-widget-select-toggle span { font-size: 0.61rem; }\r\n\r\n.pl-report-delivery-modal { background: linear-gradient(180deg, #ffffff, #f8fbfd); border: 1px solid #d4dee5; box-shadow: 0 24px 60px rgba(15,23,42,0.22); color: #0f172a; max-width: 940px; width: min(100%, 940px); }\r\n\r\n.pl-report-delivery-eyebrow { color: #607889; display: block; font-size: 0.66rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }\r\n\r\n.pl-report-delivery-copy { color: #4f6a7a; font-size: 0.76rem; line-height: 1.5; margin: 0; }\r\n\r\n.pl-report-delivery-grid { display: grid; gap: 16px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.pl-report-delivery-section { background: #f8fbfd; border: 1px solid #dbe4ea; border-radius: 16px; display: grid; gap: 12px; padding: 14px; }\r\n\r\n.pl-report-delivery-section.is-full-width { grid-column: 1 / -1; }\r\n\r\n.pl-report-delivery-section h3 { color: #0f172a; font-size: 0.82rem; margin: 0; }\r\n\r\n.pl-report-delivery-field { display: grid; gap: 6px; }\r\n\r\n.pl-report-delivery-field > span { color: #607889; font-size: 0.66rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }\r\n\r\n.pl-report-delivery-field input,\r\n.pl-report-delivery-field select,\r\n.pl-report-delivery-field textarea { background: #fff; border: 1px solid #cbd5e1; border-radius: 10px; color: #0f172a; font-size: 0.75rem; min-height: 38px; padding: 10px 12px; width: 100%; }\r\n\r\n.pl-report-delivery-field textarea { min-height: 96px; resize: vertical; }\r\n\r\n.pl-report-delivery-field.is-readonly .pl-report-delivery-readout { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 10px; color: #1d4ed8; font-size: 0.75rem; font-weight: 700; min-height: 38px; padding: 10px 12px; }\r\n\r\n.pl-report-delivery-inline-actions { align-items: center; display: flex; flex-wrap: wrap; gap: 8px; }\r\n\r\n.pl-report-delivery-chip { background: #dcfce7; border-radius: 999px; color: #166534; font-size: 0.66rem; font-weight: 800; padding: 6px 10px; }\r\n\r\n.pl-report-delivery-widget-list { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.pl-report-delivery-widget-list.is-compact { grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.pl-report-delivery-check { align-items: center; background: #fff; border: 1px solid #dbe4ea; border-radius: 10px; display: flex; gap: 8px; min-height: 40px; padding: 8px 10px; }\r\n\r\n.pl-report-delivery-check input { accent-color: #0b4360; }\r\n\r\n.pl-report-delivery-check span { color: #355166; font-size: 0.72rem; font-weight: 700; }\r\n\r\n.pl-report-delivery-scope-switcher { display: grid; gap: 10px; grid-template-columns: repeat(3, minmax(0, 1fr)); }\r\n\r\n.pl-report-delivery-store-list { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.pl-widget-library-modal { max-width: 860px; width: min(100%, 860px); }\r\n\r\n.pl-widget-library-status { align-items: center; background: linear-gradient(180deg, #f8fbfd, #eef5f8); border: 1px solid #dbe4ea; border-radius: 12px; display: flex; gap: 12px; justify-content: space-between; padding: 10px 12px; }\r\n\r\n.pl-widget-library-status strong { color: #0f172a; font-size: 0.78rem; }\r\n\r\n.pl-widget-library-status span { color: #64748b; font-size: 0.72rem; }\r\n\r\n.pl-widget-library-list { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.pl-widget-library-option { align-items: start; background: #fff; border: 1px solid #dbe4ea; border-radius: 12px; display: grid; gap: 8px; grid-template-columns: auto minmax(0, 1fr) auto; min-height: 78px; padding: 12px; }\r\n\r\n.pl-widget-library-option input { accent-color: #0b4360; margin-top: 3px; }\r\n\r\n.pl-widget-library-option.is-selected { border-color: #93c5fd; box-shadow: 0 10px 26px rgba(37,99,235,0.12); }\r\n\r\n.pl-widget-library-option.is-disabled { opacity: 0.62; }\r\n\r\n.pl-widget-library-option small { color: #0b4360; font-size: 0.68rem; font-weight: 800; text-align: right; }\r\n\r\n.pl-widget-library-option-copy { display: grid; gap: 4px; }\r\n\r\n.pl-widget-library-option-copy strong { color: #0f172a; font-size: 0.78rem; }\r\n\r\n.pl-widget-library-option-copy span { color: #64748b; font-size: 0.71rem; line-height: 1.45; }\r\n\r\n.pl-report-delivery-schedule-header { align-items: center; display: flex; justify-content: space-between; }\r\n\r\n.pl-report-delivery-schedule-header span { color: #64748b; font-size: 0.72rem; }\r\n\r\n.pl-report-delivery-schedule-list { display: grid; gap: 10px; }\r\n\r\n.pl-report-delivery-schedule-card { background: #fff; border: 1px solid #dbe4ea; border-radius: 12px; display: grid; gap: 4px; padding: 12px; }\r\n\r\n.pl-report-delivery-schedule-card strong { color: #0f172a; font-size: 0.76rem; }\r\n\r\n.pl-report-delivery-schedule-card span { color: #355166; font-size: 0.71rem; }\r\n\r\n.pl-report-delivery-schedule-card small { color: #64748b; font-size: 0.68rem; }\r\n\r\n.pl-report-delivery-schedule-card button { justify-self: start; margin-top: 4px; }\r\n\r\n.pl-report-delivery-empty { color: #64748b; font-size: 0.74rem; margin: 0; }\r\n\r\n.pl-report-delivery-footer { align-items: center; display: flex; gap: 12px; justify-content: space-between; }\r\n\r\n.pl-report-delivery-footer small { color: #64748b; font-size: 0.7rem; line-height: 1.45; max-width: 520px; }\r\n\r\n.pl-report-delivery-actions { display: flex; gap: 8px; justify-content: flex-end; }\r\n\r\n.pl-power-list { display: grid; gap: 10px; }\r\n\r\n.pl-power-progress-row { display: grid; gap: 8px; }\r\n\r\n.pl-power-progress-copy { display: grid; gap: 2px; }\r\n\r\n.pl-power-progress-copy strong { color: #0f172a; font-size: 0.78rem; }\r\n\r\n.pl-power-progress-copy span { color: #64748b; font-size: 0.7rem; }\r\n\r\n.pl-power-progress-track { background: #dbe7ee; border-radius: 999px; height: 8px; overflow: hidden; }\r\n\r\n.pl-power-progress-track span { background: linear-gradient(90deg, #0b4360, #3b82f6); border-radius: inherit; display: block; height: 100%; }\r\n\r\n.pl-variance-board { display: grid; gap: 10px; grid-template-columns: repeat(2, minmax(0, 1fr)); }\r\n\r\n.pl-variance-card { background: #f8fbfd; border: 1px solid #dbe4ea; border-radius: 12px; display: grid; gap: 10px; padding: 12px; }\r\n\r\n.pl-variance-card > small { color: #64748b; font-size: 0.69rem; line-height: 1.45; }\r\n\r\n.pl-variance-card-head { align-items: center; display: flex; gap: 8px; justify-content: space-between; }\r\n\r\n.pl-variance-card-head strong { color: #0f172a; font-size: 0.8rem; }\r\n\r\n.pl-variance-card-head span { color: #355166; font-size: 0.72rem; font-weight: 800; }\r\n\r\n.pl-variance-chip-row { display: flex; flex-wrap: wrap; gap: 8px; }\r\n\r\n.pl-variance-chip { border-radius: 999px; font-size: 0.64rem; font-weight: 800; padding: 5px 8px; }\r\n\r\n.pl-variance-chip.tone-favorable { background: #dcfce7; color: #166534; }\r\n\r\n.pl-variance-chip.tone-risk { background: #ffedd5; color: #9a3412; }\r\n\r\n.pl-variance-chip.tone-neutral { background: #dbeafe; color: #1d4ed8; }\r\n\r\n.pl-variance-track-stack { display: grid; gap: 6px; 
ze: 1rem;\r\n  font-weight: 700;\r\n  margin: 0;\r\n}\r\n\r\n.management-activities-toolbar {\r\n  align-items: center;\r\n  background: linear-gradient(180deg, #4d7388 0%, #244f67 100%);\r\n  border-bottom: 1px solid #5d6c76;\r\n  color: #eef5f8;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  padding: 8px 10px;\r\n}\r\n\r\n.management-activities-toolbar-actions,\r\n.management-activities-toolbar-meta {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\n\r\n.management-activities-toolbar-meta {\r\n  font-size: 0.76rem;\r\n}\r\n\r\n.management-activities-toolbar-meta strong {\r\n  color: #ffffff;\r\n}\r\n\r\n.management-activities-toolbar-button,\r\n.management-activities-mini-button,\r\n.management-activities-view-toggle button,\r\n.management-activities-filter-toggle,\r\n.management-activities-kpi-card {\r\n  background: linear-gradient(180deg, #f4f6f7 0%, #a7b0b8 100%);\r\n  border: 1px solid #5f6970;\r\n  border-radius: 3px;\r\n  color: #1b3343;\r\n  font-size: 0.76rem;\r\n  font-weight: 700;\r\n  min-height: 28px;\r\n  padding: 0 12px;\r\n}\r\n\r\n.management-activities-summary-shell,\r\n.management-activities-kpi-strip,\r\n.management-activities-filter-shell,\r\n.management-activities-detail-card,\r\n.management-activities-grid-shell {\r\n  background: #e8ecef;\r\n  border-bottom: 1px solid #b6c1c8;\r\n  padding: 10px;\r\n}\r\n\r\n.management-activities-summary-shell,\r\n.management-activities-filter-shell,\r\n.management-activities-detail-card {\r\n  display: grid;\r\n  gap: 10px;\r\n}\r\n\r\n.management-activities-view-row {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 12px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.management-activities-view-toggle {\r\n  align-items: center;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 8px;\r\n}\r\n\r\n.management-activities-view-toggle > span {\r\n  color: #204459;\r\n  font-size: 0.74rem;\r\n  font-weight: 700;\r\n  letter-spacing: 0.05em;\r\n  text-transform: up
d .legacy-col-service-ro {\r\n  width: 62px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-type {\r\n  width: 82px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-customer {\r\n  width: 132px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-stock {\r\n  width: 80px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-model {\r\n  width: 94px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-writer {\r\n  width: 98px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-status {\r\n  width: 84px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-signals {\r\n  width: 108px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-category {\r\n  width: 84px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-maker {\r\n  width: 74px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid .legacy-col-service-note {\r\n  width: 176px;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-ro,\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-status,\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-category {\r\n  font-weight: 700;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-customer,\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-model,\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-note {\r\n  white-space: normal;\r\n}\r\n\r\n.legacy-data-window-service-list .legacy-grid td.legacy-col-service-note {\r\n  color: #3c5a6d;\r\n  font-size: 0.71rem;\r\n}\r\n\r\n.legacy-service-queue-summary-strip {\r\n  display: grid;\r\n  gap: 8px;\r\n  grid-template-columns: repeat(auto-fit, minmax(148px, 1fr));\r\n}\r\n\r\n.legacy-service-queue-summary-card {\r\n  background: linear-gradien
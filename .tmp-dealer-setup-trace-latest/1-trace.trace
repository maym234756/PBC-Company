.dealer-setup-progress-list,\r\n.dealer-setup-health-list {\r\n  display: grid;\r\n  gap: 10px;\r\n  list-style: none;\r\n  margin: 0;\r\n  padding: 0;\r\n}\r\n\r\n.dealer-setup-integration-row,\r\n.dealer-setup-activity-row,\r\n.dealer-setup-choice-card {\r\n  padding: 12px;\r\n}\r\n\r\n.dealer-setup-integration-row div {\r\n  display: grid;\r\n  gap: 4px;\r\n}\r\n\r\n.dealer-setup-choice-grid {\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n}\r\n\r\n.dealer-setup-choice-card {\r\n  color: #16374d;\r\n  display: grid;\r\n  gap: 8px;\r\n  text-align: left;\r\n}\r\n\r\n.dealer-setup-choice-card.is-selected {\r\n  background: rgba(231, 246, 238, 0.95);\r\n  border-color: rgba(35, 165, 111, 0.34);\r\n}\r\n\r\n.dealer-setup-onboarding-shell,\r\n.dealer-setup-onboarding-layout {\r\n  display: grid;\r\n  gap: 16px;\r\n}\r\n\r\n.dealer-setup-stepper {\r\n  display: grid;\r\n  gap: 12px;\r\n  grid-template-columns: repeat(6, minmax(0, 1fr));\r\n}\r\n\r\n.dealer-setup-step {\r\n  align-items: center;\r\n  color: #72889a;\r\n  display: grid;\r\n  gap: 8px;\r\n  justify-items: center;\r\n}\r\n\r\n.dealer-setup-step.is-active,\r\n.dealer-setup-step.is-complete {\r\n  color: #17384f;\r\n}\r\n\r\n.dealer-setup-step-number {\r\n  align-items: center;\r\n  background: #edf2f6;\r\n  border: 1px solid #ccdbe6;\r\n  border-radius: 999px;\r\n  display: inline-flex;\r\n  font-weight: 800;\r\n  height: 34px;\r\n  justify-content: center;\r\n  width: 34px;\r\n}\r\n\r\n.dealer-setup-step.is-active .dealer-setup-step-number,\r\n.dealer-setup-step.is-complete .dealer-setup-step-number {\r\n  background: #167b59;\r\n  border-color: #167b59;\r\n  color: #ffffff;\r\n}\r\n\r\n.dealer-setup-onboarding-layout {\r\n  align-items: start;\r\n  grid-template-columns: minmax(180px, 0.55fr) minmax(0, 1.4fr) minmax(260px, 0.7fr);\r\n}\r\n\r\n.dealer-setup-onboarding-form-grid {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.dealer-setup-onboarding-form-grid.is-two-column {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.dealer-setup-onboarding-stack,\r\n.dealer-setup-health-panel {\r\n  display: grid;\r\n  gap: 14px;\r\n}\r\n\r\n.dealer-setup-health-card,\r\n.dealer-setup-info-banner {\r\n  background: rgba(255, 255, 255, 0.82);\r\n  border: 1px solid rgba(17, 60, 90, 0.08);\r\n  border-radius: 14px;\r\n  padding: 14px;\r\n}\r\n\r\n.dealer-setup-health-list li,\r\n.dealer-setup-progress-list li,\r\n.dealer-setup-next-step-list li {\r\n  padding-left: 18px;\r\n  position: relative;\r\n}\r\n\r\n.dealer-setup-health-list li::before,\r\n.dealer-setup-progress-list li::before,\r\n.dealer-setup-next-step-list li::before {\r\n  background: #c5d4df;\r\n  border-radius: 999px;\r\n  content: \"\";\r\n  height: 8px;\r\n  left: 0;\r\n  position: absolute;\r\n  top: 8px;\r\n  width: 8px;\r\n}\r\n\r\n.dealer-setup-health-list li.is-complete::before,\r\n.dealer-setup-progress-list li.is-active::before {\r\n  background: #23a56f;\r\n}\r\n\r\n.dealer-setup-review-grid {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.dealer-setup-detail-actions {\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  gap: 10px;\r\n}\r\n\r\n@media (max-width: 1200px) {\r\n  .dealer-setup-summary-grid,\r\n  .dealer-setup-network-metrics,\r\n  .dealer-setup-checklist-grid,\r\n  .dealer-setup-chip-grid,\r\n  .dealer-setup-choice-grid,\r\n  .dealer-setup-review-grid,\r\n  .dealer-setup-onboarding-form-grid,\r\n  .dealer-setup-filter-bar,\r\n  .dealer-setup-main-grid,\r\n  .dealer-setup-onboarding-layout {\r\n    grid-template-columns: 1fr;\r\n  }\r\n\r\n  .dealer-setup-stepper {\r\n    grid-template-columns: repeat(3, minmax(0, 1fr));\r\n  }\r\n}\r\n\r\n@media (max-width: 720px) {\r\n  .dealer-setup-stepper {\r\n    grid-template-columns: repeat(2, minmax(0, 1fr));\r\n  }\r\n\r\n  .dealer-setup-hero,\r\n  .dealer-setup-network-card,\r\n  .dealer-setup-onboarding-footer,\r\n  .dealer-setup-onboarding-header,\r\n  .dealer-setup-detail-header {\r\n    align-items: start;\r\n    flex-direction: column;\r\n  }\r\n}\r\n\r\n.website-feed-panel-copy {\r\n  display: grid;\r\n  gap: 4px;\r\n}\r\n\r\n.website-feed-panel-copy p,\r\n.website-feed-panel-heading p {\r\n  margin: 0;\r\n}\r\n\r\n.website-feed-panel-heading > span:last-child {\r\n  color: #173446;\r\n  font-size: 0.78rem;\r\n  font-weight: 800;\r\n}\r\n\r\n.website-feed-generated-endpoint,\r\n.website-feed-contract-card {\r\n  display: grid;\r\n  gap: 6px;\r\n  padding: 10px;\r\n}\r\n\r\n.website-feed-generated-endpoint-header {\r\n  align-items: center;\r\n  display: flex;\r\n  gap: 8px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.website-feed-generated-endpoint.is-compact {\r\n  gap: 5px;\r\n}\r\n\r\n.website-feed-generated-endpoint code,\r\n.website-feed-contract-card code {\r\n  background: #ffffff;\r\n  border: 1px solid #dce7ed;\r\n  border-radius: 6px;\r\n  color: #234b60;\r\n  display: block;\r\n  font-size: 0.78rem;\r\n  overflow-wrap: anywhere;\r\n  padding: 7px 8px;\r\n}\r\n\r\n.website-feed-contract-list {\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-contract-summary {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-contract-summary-item,\r\n.website-feed-sidebar-monitor-card {\r\n  background: #f8fbfd;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 10px;\r\n  display: grid;\r\n  gap: 8px;\r\n  padding: 12px;\r\n}\r\n\r\n.website-feed-sidebar-tabs {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-sidebar-tabs button {\r\n  background: #ffffff;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 8px;\r\n  color: #173446;\r\n  cursor: pointer;\r\n  display: grid;\r\n  font: inherit;\r\n  gap: 4px;\r\n  padding: 10px;\r\n  text-align: left;\r\n}\r\n\r\n.website-feed-sidebar-tabs button.is-selected {\r\n  background: #edf6fa;\r\n  border-color: #7bb1c8;\r\n  box-shadow: inset 4px 0 0 #1f8aa7;\r\n}\r\n\r\n.website-feed-sidebar-workspace .website-feed-profile-grid.website-feed-sidebar-profile-grid {\r\n  grid-template-columns: repeat(2, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-sidebar-health-strip {\r\n  grid-template-columns: 1fr;\r\n}\r\n\r\n.website-feed-grid {\r\n  align-items: start;\r\n  grid-template-columns: minmax(300px, 0.72fr) minmax(0, 1fr);\r\n}\r\n\r\n/* ── Sprint 6: Vendor Management ── */\r\n\r\n.legacy-vendor-layout { display: grid; gap: 0; grid-template-columns: 220px 1fr; height: 100%; }\r\n\r\n.legacy-vendor-list { border-right: 1px solid rgba(255,255,255,0.08); display: grid; align-content: start; gap: 4px; overflow-y: auto; padding: 10px 8px; }\r\n\r\n.legacy-vendor-list-item { background: none; border: none; border-radius: 7px; color: rgba(255,255,255,0.7); cursor: pointer; display: grid; gap: 2px; padding: 8px 10px; text-align: left; width: 100%; }\r\n\r\n.legacy-vendor-list-item:hover { background: rgba(255,255,255,0.06); }\r\n\r\n.legacy-vendor-list-item.is-active { background: rgba(255,255,255,0.1); color: #fff; }\r\n\r\n.legacy-vendor-list-item strong { font-size: 0.82rem; }\r\n\r\n.legacy-vendor-list-item span { color: rgba(255,255,255,0.45); font-size: 0.72rem; }\r\n\r\n.legacy-vendor-detail { overflow-y: auto; padding: 16px; }\r\n\r\n.legacy-vendor-detail-header { font-size: 1rem; font-weight: 700; margin-bottom: 10px; }\r\n\r\n.legacy-vendor-meta-grid { display: grid; gap: 6px; grid-template-columns: 1fr 1fr; margin-bottom: 12px; }\r\n\r\n.legacy-vendor-meta-item label { color: rgba(255,255,255,0.45); display: block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }\r\n\r\n.legacy-vendor-meta-item span { font-size: 0.83rem; }\r\n\r\n.legacy-vendor-notes { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 6px; color: rgba(255,255,255,0.6); font-size: 0.8rem; margin-bottom: 12px; padding: 8px 10px; }\r\n\r\n.legacy-vendor-edit-form { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; display: grid; gap: 8px; margin-top: 10px; padding: 12px; }\r\n\r\n/* ── Sprint 6: Pricing Matrix ── */\r\n\r\n.legacy-pricing-matrix-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-pricing-matrix-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.5); font-size: 0.7rem; font-weight: 700; padding: 6px 10px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-pricing-matrix-table td { border-top: 1px solid rgba(255,255,255,0.06); cursor: pointer; padding: 7px 10px; }\r\n\r\n.legacy-pricing-matrix-table tr.is-selected td { background: rgba(255,165,80,0.1); }\r\n\r\n.legacy-pricing-markup-chip { background: rgba(123,204,160,0.12); border: 1px solid #7bcca0; border-radius: 4px; color: #7bcca0; font-size: 0.72rem; font-weight: 700; padding: 2px 6px; }\r\n\r\n.legacy-pricing-edit-form { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; display: grid; gap: 8px; grid-template-columns: repeat(3, 1fr); margin-top: 12px; padding: 12px; }\r\n\r\n.legacy-pricing-edit-field { display: grid; gap: 3px; font-size: 0.78rem; font-weight: 600; }\r\n\r\n.legacy-pricing-edit-field input, .legacy-pricing-edit-field select { border: 1px solid rgba(255,255,255,0.15); border-radius: 5px; background: rgba(255,255,255,0.06); color: inherit; font-size: 0.82rem; padding: 4px 7px; width: 100%; }\r\n\r\n/* ── Sprint 6: Sales Desking Tool ── */\r\n\r\n.legacy-desk-grid { display: grid; gap: 12px; grid-template-columns: repeat(3, 1fr); }\r\n\r\n.legacy-desk-scenario-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 10px; display: grid; gap: 8px; padding: 14px; }\r\n\r\n.legacy-desk-scenario-card.is-active { border-color: #e55a2b; }\r\n\r\n.legacy-desk-scenario-label { align-items: center; display: flex; font-size: 0.85rem; font-weight: 700; gap: 8px; justify-content: space-between; margin-bottom: 4px; }\r\n\r\n.legacy-desk-field { display: grid; gap: 3px; font-size: 0.78rem; font-weight: 600; }\r\n\r\n.legacy-desk-field input { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); border-radius: 5px; color: inherit; font-size: 0.85rem; padding: 4px 8px; width: 100%; }\r\n\r\n.legacy-desk-computed { border-top: 1px solid rgba(255,255,255,0.08); display: grid; gap: 4px; margin-top: 8px; padding-top: 8px; }\r\n\r\n.legacy-desk-computed-row { display: flex; font-size: 0.8rem; justify-content: space-between; }\r\n\r\n.legacy-desk-computed-row.is-highlight { color: #f0a830; font-weight: 700; }\r\n\r\n/* ── Sprint 6: Inventory Adjustment ── */\r\n\r\n.legacy-adjust-panel { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; display: grid; gap: 10px; margin: 8px; padding: 14px; }\r\n\r\n.legacy-adjust-panel-header { align-items: center; display: flex; font-size: 0.85rem; font-weight: 700; gap: 8px; justify-content: space-between; }\r\n\r\n.legacy-adjust-grid { display: grid; gap: 8px; grid-template-columns: repeat(3, 1fr); }\r\n\r\n.legacy-adjust-field { display: grid; font-size: 0.78rem; font-weight: 600; gap: 3px; }\r\n\r\n.legacy-adjust-field input, .legacy-adjust-field select, .legacy-adjust-field textarea { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); border-radius: 5px; color: inherit; font-size: 0.82rem; padding: 4px 8px; width: 100%; }\r\n\r\n.legacy-adjust-field textarea { min-height: 48px; resize: vertical; }\r\n\r\n.legacy-cycle-count-col { color: rgba(255,255,255,0.45); font-size: 0.72rem; text-align: center; width: 32px; }\r\n\r\n/* ── Sprint 6: Service Reminder Campaigns ── */\r\n\r\n.legacy-campaign-type-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }\r\n\r\n.legacy-campaign-type-btn { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; color: rgba(255,255,255,0.65); cursor: pointer; font-size: 0.8rem; padding: 6px 12px; }\r\n\r\n.legacy-campaign-type-btn.is-active { background: rgba(229,90,43,0.2); border-color: #e55a2b; color: #fff; font-weight: 600; }\r\n\r\n.legacy-campaign-count-badge { background: rgba(123,204,160,0.12); border: 1px solid #7bcca0; border-radius: 12px; color: #7bcca0; font-size: 0.78rem; font-weight: 700; padding: 3px 10px; }\r\n\r\n.legacy-campaign-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-campaign-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.45); font-size: 0.7rem; font-weight: 700; padding: 5px 10px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-campaign-table td { border-top: 1px solid rgba(255,255,255,0.06); padding: 6px 10px; }\r\n\r\n/* ── Sprint 6: Customer Portal Preview ── */\r\n\r\n.legacy-portal-overlay { align-items: center; background: rgba(0,0,0,0.6); bottom: 0; display: flex; justify-content: center; left: 0; position: fixed; right: 0; top: 0; z-index: 500; }\r\n\r\n.legacy-portal-preview { background: #0d1f2d; border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; box-shadow: 0 16px 60px rgba(0,0,0,0.5); display: grid; grid-template-rows: auto 1fr; max-height: 80vh; overflow: hidden; width: 360px; }\r\n\r\n.legacy-portal-preview-header { align-items: center; background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.08); display: flex; font-size: 0.85rem; font-weight: 700; gap: 10px; justify-content: space-between; padding: 12px 14px; }\r\n\r\n.legacy-portal-preview-body { display: grid; gap: 10px; overflow-y: auto; padding: 14px; }\r\n\r\n.legacy-portal-preview-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; padding: 12px; }\r\n\r\n.legacy-portal-preview-ro-header { align-items: baseline; display: flex; font-size: 1rem; gap: 8px; justify-content: space-between; margin-bottom: 8px; }\r\n\r\n.legacy-portal-preview-label { color: rgba(255,255,255,0.45); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; }\r\n\r\n.legacy-portal-preview-status-row { align-items: center; border-top: 1px solid rgba(255,255,255,0.06); display: flex; font-size: 0.82rem; justify-content: space-between; padding: 5px 0; }\r\n\r\n.legacy-portal-preview-section-label { color: rgba(255,255,255,0.4); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; }\r\n\r\n.legacy-portal-preview-job-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07); border-radius: 8px; display: grid; gap: 5px; padding: 10px 12px; }\r\n\r\n.legacy-portal-preview-job-title { font-size: 0.85rem; font-weight: 600; }\r\n\r\n.legacy-portal-preview-job-status { display: flex; }\r\n\r\n.legacy-portal-preview-job-desc { color: rgba(255,255,255,0.5); font-size: 0.78rem; }\r\n\r\n.legacy-portal-preview-totals { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 10px; display: grid; gap: 0; padding: 10px 12px; }\r\n\r\n.legacy-portal-preview-total-row { align-items: center; border-top: 1px solid rgba(255,255,255,0.06); display: flex; font-size: 0.82rem; justify-content: space-between; padding: 5px 0; }\r\n\r\n.legacy-portal-preview-total-row:first-child { border-top: none; }\r\n\r\n.legacy-portal-preview-total-row.is-due { color: #f0a830; font-size: 0.88rem; font-weight: 700; }\r\n\r\n/* ── Sprint 6: Audit Trail ── */\r\n\r\n.legacy-audit-table { border-collapse: collapse; font-size: 0.8rem; width: 100%; }\r\n\r\n.legacy-audit-table th { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.45); font-size: 0.7rem; font-weight: 700; padding: 5px 10px; text-align: left; text-transform: uppercase; }\r\n\r\n.legacy-audit-table td { border-top: 1px solid rgba(255,255,255,0.06); padding: 6px 10px; }\r\n\r\n.legacy-audit-row-stable td { border-left: 3px solid #7bcca0; }\r\n\r\n.legacy-audit-row-attention td { border-left: 3px solid #f0a830; }\r\n\r\n.legacy-audit-row-accent td { border-left: 3px solid #4a90c4; }\r\n\r\n.legacy-audit-row-neutral td { border-left: 3px solid rgba(255,255,255,0.2); }\r\n\r\n.legacy-audit-time { color: rgba(255,255,255,0.45); font-size: 0.75rem; white-space: nowrap; }\r\n\r\n.legacy-audit-actor { color: rgba(255,255,255,0.45); font-size: 0.75rem; }\r\n\r\n.website-feed-endpoints,\r\n.website-feed-focus,\r\n.website-feed-mapping,\r\n.website-feed-preview-panel {\r\n  min-width: 0;\r\n}\r\n\r\n.website-feed-endpoint {\r\n  color: #173446;\r\n  cursor: pointer;\r\n  display: grid;\r\n  font: inherit;\r\n  gap: 10px;\r\n  padding: 12px;\r\n  text-align: left;\r\n  width: 100%;\r\n}\r\n\r\n.website-feed-endpoint.is-selected {\r\n  background: #edf6fa;\r\n  border-color: #7bb1c8;\r\n  box-shadow: inset 4px 0 0 #1f8aa7;\r\n}\r\n\r\n.website-feed-endpoint-header,\r\n.website-feed-endpoint-meta {\r\n  align-items: start;\r\n  display: flex;\r\n  gap: 10px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.website-feed-endpoint-header div {\r\n  display: grid;\r\n  gap: 3px;\r\n  min-width: 0;\r\n}\r\n\r\n.website-feed-endpoint-header div span {\r\n  color: #567185;\r\n}\r\n\r\n.website-feed-endpoint-meter {\r\n  background: #dfe9ef;\r\n  border-radius: 999px;\r\n  height: 8px;\r\n  overflow: hidden;\r\n}\r\n\r\n.website-feed-endpoint-meter span {\r\n  background: linear-gradient(90deg, #1f8aa7 0%, #44c188 100%);\r\n  border-radius: inherit;\r\n  display: block;\r\n  height: 100%;\r\n}\r\n\r\n.website-feed-profile-grid {\r\n  grid-template-columns: repeat(3, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-mapper-shell {\r\n  gap: 10px;\r\n}\r\n\r\n.website-feed-mapper-lane-tabs {\r\n  grid-template-columns: repeat(4, minmax(0, 1fr));\r\n}\r\n\r\n.website-feed-mapper-lane-tabs button,\r\n.website-feed-mapper-panel {\r\n  background: #f8fbfd;\r\n  border: 1px solid #d7e1e8;\r\n  border-radius: 10px;\r\n}\r\n\r\n.website-feed-mapper-lane-tabs button {\r\n  cursor: pointer;\r\n  display: grid;\r\n  gap: 4px;\r\n  min-height: 64px;\r\n  
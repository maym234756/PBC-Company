rvice-cell-edit-button:disabled {\r\n  cursor: wait;\r\n}\r\n\r\n.legacy-service-grid-cell:hover .legacy-service-cell-edit-button,\r\n.legacy-service-grid-cell:focus-within .legacy-service-cell-edit-button {\r\n  opacity: 1;\r\n  pointer-events: auto;\r\n  transform: translateX(0);\r\n}\r\n\r\n.legacy-service-grid-cell:hover .legacy-service-cell-edit-button:disabled,\r\n.legacy-service-grid-cell:focus-within .legacy-service-cell-edit-button:disabled {\r\n  opacity: 0.65;\r\n}\r\n\r\n@media (hover: none) {\r\n  .legacy-service-cell-edit-button {\r\n    opacity: 1;\r\n    pointer-events: auto;\r\n    transform: none;\r\n  }\r\n}\r\n\r\n.legacy-service-cell-editor {\r\n  display: grid;\r\n  gap: 6px;\r\n}\r\n\r\n.legacy-service-cell-input {\r\n  background: #ffffff;\r\n  border: 1px solid #c6d2d9;\r\n  border-radius: 10px;\r\n  color: #173446;\r\n  font: inherit;\r\n  min-height: 28px;\r\n  padding: 6px 8px;\r\n  width: 100%;\r\n}\r\n\r\n.legacy-service-cell-input:focus {\r\n  border-color: #0d3b5b;\r\n  box-shadow: 0 0 0 3px rgba(13, 59, 91, 0.12);\r\n  outline: none;\r\n}\r\n\r\n.legacy-service-cell-editor textarea.legacy-service-cell-input {\r\n  min-height: 72px;\r\n  resize: vertical;\r\n}\r\n\r\n.legacy-service-note-editor-backdrop {\r\n  align-items: center;\r\n  background: rgba(14, 33, 47, 0.34);\r\n  display: flex;\r\n  inset: 0;\r\n  justify-content: center;\r\n  padding: 24px;\r\n  position: fixed;\r\n  z-index: 12;\r\n}\r\n\r\n.legacy-service-note-editor-panel {\r\n  background: #f7fafc;\r\n  border: 1px solid #c6d2d9;\r\n  border-radius: 16px;\r\n  box-shadow: 0 28px 60px rgba(8, 23, 35, 0.24);\r\n  color: #173446;\r\n  display: grid;\r\n  gap: 12px;\r\n  max-width: min(760px, calc(100vw - 48px));\r\n  padding: 18px;\r\n  width: min(100%, 760px);\r\n}\r\n\r\n.legacy-service-note-editor-header {\r\n  align-items: start;\r\n  display: flex;\r\n  gap: 12px;\r\n  justify-content: space-between;\r\n}\r\n\r\n.legacy-service-note-editor-header > div {\r\n  displ